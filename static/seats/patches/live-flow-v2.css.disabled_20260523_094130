/* =========================================================
   LIVE FLOW V2
   Sadece .live-flow-v2 kapsamını etkiler.
========================================================= */

.route-strip-shell.live-flow-v2{
  --lf-ink:#0a0a0f;
  --lf-card:#13131a;
  --lf-card2:#1a1a24;
  --lf-line:rgba(255,255,255,.06);
  --lf-red:#ff2d55;
  --lf-amber:#ffcc00;
  --lf-blue:#0a84ff;
  --lf-green:#30d158;
  --lf-white:#ffffff;
  --lf-dim:rgba(255,255,255,.42);

  margin:0 0 14px !important;
  padding:14px !important;
  border-radius:28px !important;
  background:
    radial-gradient(circle at 16% 0%, rgba(10,132,255,.13), transparent 34%),
    linear-gradient(180deg, rgba(10,10,15,.98), rgba(10,10,15,.94)) !important;
  border:1px solid var(--lf-line) !important;
  box-shadow:0 22px 60px rgba(0,0,0,.42), inset 0 1px 0 rgba(255,255,255,.05) !important;
  overflow:hidden !important;
  font-family:system-ui,-apple-system,Segoe UI,Roboto,Arial,sans-serif !important;
}

.route-strip-shell.live-flow-v2 .route-strip-head{
  display:flex !important;
  align-items:center !important;
  justify-content:space-between !important;
  gap:10px !important;
  margin-bottom:12px !important;
}

.route-strip-shell.live-flow-v2 .route-strip-title{
  font-size:10px !important;
  font-weight:900 !important;
  letter-spacing:.18em !important;
  text-transform:uppercase !important;
  color:var(--lf-dim) !important;
}

.route-strip-shell.live-flow-v2 .route-strip-meta{
  width:auto !important;
  display:flex !important;
  align-items:center !important;
  justify-content:flex-end !important;
  gap:7px !important;
  overflow:hidden !important;
}

.route-strip-shell.live-flow-v2 .route-pill{
  min-height:32px !important;
  max-width:142px !important;
  padding:7px 10px !important;
  border-radius:999px !important;
  background:var(--lf-card) !important;
  border:1px solid var(--lf-line) !important;
  color:var(--lf-white) !important;
  box-shadow:none !important;
  display:inline-flex !important;
  align-items:center !important;
  gap:6px !important;
  overflow:hidden !important;
}

.route-strip-shell.live-flow-v2 .route-pill-live{
  background:rgba(48,209,88,.10) !important;
  border-color:rgba(48,209,88,.25) !important;
}

.route-strip-shell.live-flow-v2 .route-pill-next{
  background:rgba(255,204,0,.08) !important;
  border-color:rgba(255,204,0,.20) !important;
}

.route-strip-shell.live-flow-v2 .route-mini-dot{
  width:7px !important;
  height:7px !important;
  border-radius:50% !important;
  background:var(--lf-green) !important;
  box-shadow:0 0 12px var(--lf-green) !important;
  flex:0 0 auto !important;
}

.route-strip-shell.live-flow-v2 .route-mini-label{
  font-size:9px !important;
  font-weight:900 !important;
  letter-spacing:.08em !important;
  text-transform:uppercase !important;
  color:var(--lf-dim) !important;
  white-space:nowrap !important;
}

.route-strip-shell.live-flow-v2 .route-name-window{
  min-width:0 !important;
  overflow:hidden !important;
}

.route-strip-shell.live-flow-v2 .route-name-window b,
.route-strip-shell.live-flow-v2 .route-pill b{
  display:block !important;
  min-width:0 !important;
  overflow:hidden !important;
  text-overflow:ellipsis !important;
  white-space:nowrap !important;
  color:var(--lf-white) !important;
  font-size:11px !important;
  font-weight:950 !important;
}

.route-strip-shell.live-flow-v2 .night-voice-toggle{
  min-height:32px !important;
  padding:7px 10px !important;
  border-radius:999px !important;
  background:var(--lf-card) !important;
  border:1px solid var(--lf-line) !important;
  color:var(--lf-white) !important;
  font-size:11px !important;
  font-weight:900 !important;
  box-shadow:none !important;
  white-space:nowrap !important;
}

.route-strip-shell.live-flow-v2 .route-strip{
  display:flex !important;
  gap:10px !important;
  overflow-x:auto !important;
  overflow-y:hidden !important;
  padding:0 0 3px !important;
  scroll-snap-type:x proximity !important;
  scrollbar-width:none !important;
}

.route-strip-shell.live-flow-v2 .route-strip::-webkit-scrollbar{
  display:none !important;
}

.route-strip-shell.live-flow-v2 .route-stop{
  appearance:none !important;
  -webkit-appearance:none !important;
  border:1px solid var(--lf-line) !important;
  background:var(--lf-card) !important;
  color:var(--lf-white) !important;
  box-shadow:none !important;
  text-align:left !important;
  font:inherit !important;
  cursor:pointer !important;
  position:relative !important;
  overflow:hidden !important;
  scroll-snap-align:start !important;
  transition:transform .12s ease, border-color .12s ease, background .12s ease !important;
}

.route-strip-shell.live-flow-v2 .route-stop:active{
  transform:scale(.985) !important;
}

.route-strip-shell.live-flow-v2 .route-stop.v2-current{
  flex:0 0 min(326px, calc(100vw - 54px)) !important;
  min-width:min(326px, calc(100vw - 54px)) !important;
  min-height:214px !important;
  padding:0 !important;
  border-radius:28px !important;
  background:var(--lf-card) !important;
  border-color:rgba(255,45,85,.22) !important;
}

.route-strip-shell.live-flow-v2 .route-stop.v2-current::before{
  content:"" !important;
  position:absolute !important;
  left:0 !important;
  top:20% !important;
  bottom:20% !important;
  width:3px !important;
  border-radius:0 3px 3px 0 !important;
  background:var(--lf-red) !important;
  box-shadow:0 0 16px var(--lf-red) !important;
}

.route-strip-shell.live-flow-v2 .v2-current-top{
  padding:20px 20px 0 !important;
  display:flex !important;
  align-items:flex-start !important;
  justify-content:space-between !important;
  gap:12px !important;
}

.route-strip-shell.live-flow-v2 .v2-current-tag{
  display:flex !important;
  align-items:center !important;
  gap:7px !important;
  font-size:10px !important;
  font-weight:950 !important;
  letter-spacing:.13em !important;
  text-transform:uppercase !important;
  color:var(--lf-red) !important;
}

.route-strip-shell.live-flow-v2 .v2-tag-dot{
  width:8px !important;
  height:8px !important;
  border-radius:50% !important;
  background:var(--lf-red) !important;
  box-shadow:0 0 12px var(--lf-red) !important;
}

.route-strip-shell.live-flow-v2 .v2-current-eta{
  max-width:112px !important;
  overflow:hidden !important;
  text-overflow:ellipsis !important;
  white-space:nowrap !important;
  font-size:11px !important;
  font-weight:850 !important;
  color:var(--lf-dim) !important;
  background:rgba(255,255,255,.06) !important;
  border-radius:10px !important;
  padding:5px 9px !important;
}

.route-strip-shell.live-flow-v2 .v2-current-name{
  padding:11px 20px 5px !important;
  font-size:clamp(32px, 11vw, 46px) !important;
  line-height:.96 !important;
  letter-spacing:-.045em !important;
  font-weight:1000 !important;
  color:var(--lf-white) !important;
  overflow:hidden !important;
  text-overflow:ellipsis !important;
  white-space:nowrap !important;
}

.route-strip-shell.live-flow-v2 .v2-current-dist{
  padding:0 20px 16px !important;
  font-size:12px !important;
  color:var(--lf-dim) !important;
  font-weight:750 !important;
  overflow:hidden !important;
  text-overflow:ellipsis !important;
  white-space:nowrap !important;
}

.route-strip-shell.live-flow-v2 .v2-current-dist span{
  color:var(--lf-white) !important;
  font-weight:950 !important;
}

.route-strip-shell.live-flow-v2 .v2-tiles{
  display:grid !important;
  grid-template-columns:1fr 1fr !important;
  border-top:1px solid var(--lf-line) !important;
}

.route-strip-shell.live-flow-v2 .v2-tile{
  min-height:84px !important;
  padding:14px 16px !important;
  border-right:1px solid var(--lf-line) !important;
  display:flex !important;
  flex-direction:column !important;
  gap:5px !important;
  position:relative !important;
}

.route-strip-shell.live-flow-v2 .v2-tile:last-child{
  border-right:0 !important;
}

.route-strip-shell.live-flow-v2 .v2-tile.v2-hot{
  background:radial-gradient(circle at 20% 0%, rgba(255,45,85,.18), transparent 62%) !important;
}

.route-strip-shell.live-flow-v2 .v2-tile-icon{
  font-size:21px !important;
  line-height:1 !important;
}

.route-strip-shell.live-flow-v2 .v2-tile-count{
  font-size:30px !important;
  line-height:.9 !important;
  font-weight:1000 !important;
  letter-spacing:-.04em !important;
  color:var(--lf-white) !important;
}

.route-strip-shell.live-flow-v2 .v2-tile-count.red{
  color:var(--lf-red) !important;
}

.route-strip-shell.live-flow-v2 .v2-tile-label{
  font-size:9px !important;
  font-weight:900 !important;
  letter-spacing:.10em !important;
  text-transform:uppercase !important;
  color:var(--lf-dim) !important;
}

.route-strip-shell.live-flow-v2 .v2-tile-cta{
  position:absolute !important;
  right:12px !important;
  bottom:12px !important;
  font-size:10px !important;
  font-weight:950 !important;
  color:var(--lf-red) !important;
  background:rgba(255,45,85,.12) !important;
  border-radius:8px !important;
  padding:4px 7px !important;
}

.route-strip-shell.live-flow-v2 .v2-tile-cta.grey{
  color:var(--lf-dim) !important;
  background:rgba(255,255,255,.05) !important;
}

.route-strip-shell.live-flow-v2 .route-stop.v2-compact{
  flex:0 0 214px !important;
  min-width:214px !important;
  min-height:92px !important;
  padding:14px 15px !important;
  border-radius:20px !important;
  display:flex !important;
  align-items:center !important;
  justify-content:space-between !important;
  gap:12px !important;
}

.route-strip-shell.live-flow-v2 .route-stop.v2-next{
  border-color:rgba(255,204,0,.20) !important;
  background:linear-gradient(180deg, rgba(255,204,0,.055), rgba(19,19,26,1)) !important;
}

.route-strip-shell.live-flow-v2 .route-stop.v2-done{
  opacity:.46 !important;
}

.route-strip-shell.live-flow-v2 .v2-next-info{
  min-width:0 !important;
}

.route-strip-shell.live-flow-v2 .v2-next-tag{
  margin-bottom:5px !important;
  font-size:9px !important;
  font-weight:950 !important;
  letter-spacing:.15em !important;
  text-transform:uppercase !important;
  color:var(--lf-blue) !important;
  white-space:nowrap !important;
}

.route-strip-shell.live-flow-v2 .route-stop.v2-next .v2-next-tag{
  color:var(--lf-amber) !important;
}

.route-strip-shell.live-flow-v2 .v2-next-name{
  font-size:21px !important;
  line-height:1 !important;
  letter-spacing:-.035em !important;
  font-weight:1000 !important;
  color:var(--lf-white) !important;
  overflow:hidden !important;
  text-overflow:ellipsis !important;
  white-space:nowrap !important;
}

.route-strip-shell.live-flow-v2 .route-stop.v2-waiting .v2-next-name,
.route-strip-shell.live-flow-v2 .route-stop.v2-done .v2-next-name{
  color:rgba(255,255,255,.56) !important;
}

.route-strip-shell.live-flow-v2 .v2-next-detail{
  margin-top:6px !important;
  font-size:11px !important;
  line-height:1.2 !important;
  color:var(--lf-dim) !important;
  font-weight:750 !important;
  overflow:hidden !important;
  text-overflow:ellipsis !important;
  white-space:nowrap !important;
}

.route-strip-shell.live-flow-v2 .v2-next-right{
  flex:0 0 auto !important;
  text-align:right !important;
  max-width:76px !important;
}

.route-strip-shell.live-flow-v2 .v2-next-distance{
  font-size:15px !important;
  line-height:1 !important;
  font-weight:1000 !important;
  letter-spacing:-.02em !important;
  color:var(--lf-blue) !important;
  white-space:nowrap !important;
}

.route-strip-shell.live-flow-v2 .route-stop.v2-next .v2-next-distance{
  color:var(--lf-amber) !important;
}

.route-strip-shell.live-flow-v2 .v2-next-small{
  margin-top:4px !important;
  display:block !important;
  font-size:10px !important;
  color:var(--lf-dim) !important;
  font-weight:750 !important;
  white-space:nowrap !important;
}

@media(max-width:430px){
  .route-strip-shell.live-flow-v2{
    padding:12px !important;
    border-radius:24px !important;
  }

  .route-strip-shell.live-flow-v2 .route-strip-head{
    align-items:flex-start !important;
    flex-direction:column !important;
  }

  .route-strip-shell.live-flow-v2 .route-strip-meta{
    width:100% !important;
    justify-content:stretch !important;
  }

  .route-strip-shell.live-flow-v2 .route-pill{
    flex:1 1 0 !important;
    max-width:none !important;
  }

  .route-strip-shell.live-flow-v2 .night-voice-toggle{
    flex:0 0 auto !important;
    max-width:96px !important;
    overflow:hidden !important;
    text-overflow:ellipsis !important;
  }

  .route-strip-shell.live-flow-v2 .route-stop.v2-current{
    flex-basis:calc(100vw - 48px) !important;
    min-width:calc(100vw - 48px) !important;
  }

  .route-strip-shell.live-flow-v2 .route-stop.v2-compact{
    flex-basis:205px !important;
    min-width:205px !important;
  }
}
