/* =========================================================
   SEAT BOTTOM FAB + 51-54 + 54 FINAL FIX
   Amaç:
   - 43 ile 51 arasındaki hızlı FAB panelini hizalamak
   - 51-52-53-54 alt sıra hizasını toparlamak
   - 54 numaralı koltuğun özel sağ hizasını geri almak
   Bu dosya en son CSS katmanlarından biri olarak yüklenmelidir.
========================================================= */

/* Ayar değişkenleri */
.deck{
  --bottom-fab-left: 62px;
  --bottom-fab-bottom: 118px;
  --bottom-fab-scale: .92;
  --seat54-shift: 16px;
}

/* 43 ile 51 arasındaki hızlı işlem paneli */
.fab-column.fab-left-gap-moved{
  left: var(--bottom-fab-left) !important;
  right: auto !important;
  bottom: calc(var(--bottom-fab-bottom) + env(safe-area-inset-bottom, 0px)) !important;
  top: auto !important;
  transform: scale(var(--bottom-fab-scale)) !important;
  transform-origin: bottom center !important;
  z-index: 120 !important;
}

/* Panel içini biraz sıkılaştır */
.fab-column.fab-left-gap-moved{
  gap: 5px !important;
  padding: 6px 7px !important;
  border-radius: 22px !important;
}

.fab-column.fab-left-gap-moved .fab{
  width: 46px !important;
  height: 46px !important;
  min-width: 46px !important;
  min-height: 46px !important;
  border-radius: 16px !important;
  font-size: 19px !important;
}

/* Hızlı başlığı çok yer kaplamasın */
.fab-column.fab-left-gap-moved .fab-title,
.fab-column.fab-left-gap-moved .fab-label,
.fab-column.fab-left-gap-moved small{
  font-size: 10px !important;
  line-height: 1.05 !important;
}

/* 51-52-53-54 alt sırada önce tüm özel kaydırmaları sıfırla */
.deck .cell[style*="grid-row:14"],
.deck .cell[style*="grid-row: 14"]{
  transform: none !important;
}

/* Sadece 54 numarayı sağ kolon hizasına geri al */
.deck .cell[style*="grid-row:14"][style*="grid-column:4"],
.deck .cell[style*="grid-row:14"][style*="grid-column: 4"],
.deck .cell[style*="grid-row: 14"][style*="grid-column:4"],
.deck .cell[style*="grid-row: 14"][style*="grid-column: 4"]{
  transform: translateX(var(--seat54-shift)) !important;
}

/* Sürüş modunda da aynı mantık */
body.drive-mode .deck{
  --bottom-fab-bottom: 112px;
  --seat54-shift: 18px;
}

body.drive-mode .deck .cell[style*="grid-row:14"],
body.drive-mode .deck .cell[style*="grid-row: 14"]{
  transform: none !important;
}

body.drive-mode .deck .cell[style*="grid-row:14"][style*="grid-column:4"],
body.drive-mode .deck .cell[style*="grid-row:14"][style*="grid-column: 4"],
body.drive-mode .deck .cell[style*="grid-row: 14"][style*="grid-column:4"],
body.drive-mode .deck .cell[style*="grid-row: 14"][style*="grid-column: 4"]{
  transform: translateX(var(--seat54-shift)) !important;
}

/* Dar ekran ince ayar */
@media(max-width:430px){
  .deck{
    --bottom-fab-left: 58px;
    --bottom-fab-bottom: 116px;
    --bottom-fab-scale: .90;
    --seat54-shift: 14px;
  }
}

@media(max-width:380px){
  .deck{
    --bottom-fab-left: 54px;
    --bottom-fab-bottom: 112px;
    --bottom-fab-scale: .86;
    --seat54-shift: 12px;
  }
}
