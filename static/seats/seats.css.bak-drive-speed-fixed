/* =========================================================
   DURAK AKIŞI CANLI / SIRADAKİ TIKLANABİLİR PILL
========================================================= */

.route-pill{
  cursor:pointer;
  user-select:none;
  transition:.16s ease;
}

.route-pill:hover{
  transform:translateY(-1px);
  filter:brightness(1.08);
}

.route-pill:active{
  transform:scale(.98);
}

.route-stop.route-focus-flash{
  animation:routeFocusFlash 1.1s ease-in-out 1;
}

@keyframes routeFocusFlash{
  0%,100%{
    box-shadow:
      0 12px 24px rgba(0,0,0,.18),
      0 0 0 1px rgba(255,255,255,.08) inset;
  }
  45%{
    box-shadow:
      0 0 0 3px rgba(96,165,250,.80),
      0 0 28px rgba(96,165,250,.58),
      0 12px 24px rgba(0,0,0,.18);
    filter:brightness(1.25);
  }
}


/* =========================================================
   SÜRÜŞ MODU HIZ KUTUSU
   Normal butonunun altında gösterilir
========================================================= */

#driveSpeedChip{
  display:none;
}

/* Sadece sürüş modunda görünür */
body.drive-mode #driveSpeedChip{
  display:flex;
  position:fixed;
  right:16px;
  top:calc(68px + env(safe-area-inset-top));
  z-index:1600;

  width:190px;
  min-height:58px;
  padding:9px 13px;
  border-radius:22px;

  flex-direction:column;
  justify-content:center;
  gap:4px;

  background:linear-gradient(180deg, rgba(15,23,42,.92), rgba(2,6,23,.92));
  border:1px solid rgba(255,255,255,.14);
  box-shadow:
    0 14px 30px rgba(0,0,0,.34),
    0 0 0 1px rgba(255,255,255,.04) inset;
  backdrop-filter:blur(12px);

  color:#fff;
  pointer-events:none;
}

.drive-speed-top{
  display:flex;
  align-items:flex-end;
  gap:6px;
  line-height:1;
  font-weight:900;
}

.drive-speed-top b{
  font-size:27px;
  line-height:.9;
  font-weight:950;
  letter-spacing:-.03em;
}

.drive-speed-top span{
  font-size:13px;
  font-weight:900;
  opacity:.95;
}

.drive-speed-ico{
  font-size:17px !important;
  line-height:1;
}

.drive-speed-sub{
  font-size:12px;
  font-weight:850;
  color:#cbd5e1;
  white-space:nowrap;
  overflow:hidden;
  text-overflow:ellipsis;
}

/* Renk durumları */
.drive-speed-chip.ok{
  border-color:rgba(34,197,94,.42) !important;
  box-shadow:
    0 14px 30px rgba(0,0,0,.34),
    0 0 0 2px rgba(34,197,94,.20) inset !important;
}

.drive-speed-chip.warn{
  border-color:rgba(245,158,11,.55) !important;
  box-shadow:
    0 14px 30px rgba(0,0,0,.34),
    0 0 0 2px rgba(245,158,11,.24) inset !important;
}

.drive-speed-chip.bad{
  border-color:rgba(239,68,68,.62) !important;
  animation:driveSpeedBadPulse 1s ease-in-out infinite;
}

@keyframes driveSpeedBadPulse{
  0%,100%{
    box-shadow:
      0 14px 30px rgba(0,0,0,.34),
      0 0 0 2px rgba(239,68,68,.25) inset;
  }
  50%{
    box-shadow:
      0 14px 30px rgba(0,0,0,.34),
      0 0 0 2px rgba(239,68,68,.42) inset,
      0 0 18px rgba(239,68,68,.35);
  }
}

/* Dar ekranda biraz küçült */
@media (max-width:420px){
  body.drive-mode #driveSpeedChip{
    right:14px;
    top:calc(64px + env(safe-area-inset-top));
    width:174px;
    min-height:54px;
    padding:8px 12px;
    border-radius:20px;
  }

  .drive-speed-top b{
    font-size:24px;
  }

  .drive-speed-sub{
    font-size:11px;
  }
}

