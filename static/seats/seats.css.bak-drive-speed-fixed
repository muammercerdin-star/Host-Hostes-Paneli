:root{
    --bg:#07101d;
    --bg-soft:#0d1726;
    --card:#121d2d;
    --card-2:#192638;
    --card-3:#223248;
    --line:rgba(255,255,255,.08);
    --line-2:rgba(255,255,255,.05);
    --text:#edf3fb;
    --muted:#97a9bf;
    --muted-2:#b8c7d7;

    --brand:#16a34a;
    --brand-2:#22c55e;
    --primary:#2563eb;
    --accent:#0ea5e9;
    --warn:#f59e0b;
    --danger:#ef4444;
    --purple:#7c3aed;
    --pink:#ec4899;

    --shadow:0 22px 50px rgba(0,0,0,.34);
    --shadow-soft:0 14px 34px rgba(0,0,0,.22);

    --radius:24px;
    --radius-lg:30px;
    --radius-md:18px;
    --radius-sm:14px;

    --topbar-h:78px;
    --seat-w:66px;
    --seat-h:66px;
    --seat-gap-y:18px;
    --seat-gap-x:18px;

    --mobile-safe-bottom:112px;
    --mobile-fab-offset:12px;
    --mobile-panel-peek:108px;
  }

  *{ box-sizing:border-box; }
  html,body{ margin:0; padding:0; }

  body{
    color:var(--text);
    font-family:Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    background:
      radial-gradient(circle at top left, rgba(37,99,235,.15), transparent 20%),
      radial-gradient(circle at top right, rgba(14,165,233,.12), transparent 18%),
      radial-gradient(circle at bottom right, rgba(124,58,237,.10), transparent 24%),
      linear-gradient(180deg, #06101c 0%, #0a1422 100%);
  }

  .glass{
    background:linear-gradient(180deg, rgba(255,255,255,.055), rgba(255,255,255,.025));
    border:1px solid var(--line);
    box-shadow:var(--shadow);
    backdrop-filter:blur(12px);
  }

  .seats-shell{
    width:min(1480px, 100%);
    margin:0 auto;
    padding:12px 12px 18px;
  }

  .topbar{
    position:sticky;
    top:8px;
    z-index:1200;
    display:grid;
    grid-template-columns:minmax(0,1fr) auto;
    gap:14px;
    align-items:start;
    min-height:var(--topbar-h);
    padding:14px;
    border-radius:28px;
  }

  .route-meta{
    min-width:0;
    display:flex;
    flex-direction:column;
    gap:8px;
  }

  .route-title-row{
    display:flex;
    align-items:center;
    gap:10px;
    min-width:0;
  }

  .route-badge{
    flex:0 0 auto;
    width:52px;
    height:52px;
    border-radius:18px;
    display:flex;
    align-items:center;
    justify-content:center;
    font-size:24px;
    background:linear-gradient(180deg, rgba(37,99,235,.28), rgba(14,165,233,.18));
    border:1px solid rgba(255,255,255,.10);
    box-shadow:0 12px 24px rgba(0,0,0,.22);
  }

  .route-title-wrap{
    min-width:0;
  }

  .route-title{
    font-size:clamp(24px, 3.5vw, 36px);
    font-weight:900;
    line-height:1.02;
    letter-spacing:-.03em;
    margin:0;
  }

  .route-sub{
    color:var(--muted);
    font-size:13px;
    line-height:1.45;
    margin-top:4px;
  }

  .route-live-row{
    display:flex;
    flex-wrap:wrap;
    gap:8px;
  }

  .mini-chip{
    display:inline-flex;
    align-items:center;
    gap:8px;
    min-height:38px;
    padding:8px 12px;
    border-radius:999px;
    background:rgba(255,255,255,.045);
    border:1px solid var(--line);
    color:#fff;
    font-size:13px;
    font-weight:800;
    line-height:1;
    white-space:nowrap;
    box-shadow:0 10px 20px rgba(0,0,0,.16);
  }

  .mini-chip b{
    font-weight:900;
    color:#fff;
  }

  .top-actions{
    display:grid;
    grid-template-columns:repeat(5, 50px);
    gap:10px;
    align-content:start;
  }

  .top-actions form{
    margin:0;
    display:flex;
  }

  .icon-btn,
  .btn{
    border:none;
    cursor:pointer;
    color:#fff;
    font-weight:900;
    transition:.16s ease;
    text-decoration:none;
  }

  .icon-btn:hover,
  .btn:hover,
  .seat:hover,
  .fab:hover,
  .tab-btn:hover,
  .voice-command-btn:hover{
    transform:translateY(-1px);
    filter:brightness(1.04);
  }

  .icon-btn{
    width:50px;
    height:50px;
    display:flex;
    align-items:center;
    justify-content:center;
    border-radius:18px;
    background:rgba(255,255,255,.055);
    border:1px solid var(--line);
    font-size:21px;
    box-shadow:0 12px 26px rgba(0,0,0,.24);
  }

  .status-row{
    display:grid;
    grid-template-columns:repeat(6, minmax(0,1fr));
    gap:10px;
    margin:14px 0 12px;
  }

  .status-pill{
    display:flex;
    align-items:center;
    justify-content:space-between;
    gap:10px;
    min-height:64px;
    padding:12px 14px;
    border-radius:20px;
    background:rgba(255,255,255,.04);
    border:1px solid var(--line);
    box-shadow:var(--shadow-soft);
    overflow:hidden;
  }

  .status-pill .k{
    color:var(--muted);
    font-size:12px;
    font-weight:700;
    line-height:1.15;
  }

  .status-pill .v{
    font-size:24px;
    font-weight:900;
    line-height:1;
    text-align:right;
    white-space:nowrap;
  }

  .status-pill.total{ background:linear-gradient(135deg, rgba(37,99,235,.18), rgba(37,99,235,.07)); }
  .status-pill.empty{ background:linear-gradient(135deg, rgba(34,197,94,.16), rgba(34,197,94,.06)); }
  .status-pill.standing{ background:linear-gradient(135deg, rgba(239,68,68,.16), rgba(239,68,68,.06)); cursor:pointer; }
  .status-pill.cash{ background:linear-gradient(135deg, rgba(124,58,237,.18), rgba(124,58,237,.06)); }
  .status-pill.service{ background:linear-gradient(135deg, rgba(14,165,233,.18), rgba(14,165,233,.06)); }
  .status-pill.parcel{ background:linear-gradient(135deg, rgba(245,158,11,.17), rgba(245,158,11,.06)); }

  .pulse{
    animation:pulseGlow 1.7s ease-in-out infinite;
  }

  @keyframes pulseGlow{
    0%,100%{ transform:scale(1); }
    50%{ transform:scale(1.012); }
  }

  .layout{
    display:grid;
    gap:12px;
    align-items:start;
  }

  .board-card,
  .panel-card,
  .modal,
  .sheet-modal{
    border-radius:28px;
  }

  .board-card{
    position:relative;
    padding:16px;
    overflow:hidden;
  }

  .board-card::before{
    content:"";
    position:absolute;
    inset:0;
    background:
      radial-gradient(circle at 20% 0%, rgba(59,130,246,.10), transparent 28%),
      radial-gradient(circle at 100% 20%, rgba(14,165,233,.08), transparent 24%);
    pointer-events:none;
  }

  .board-inner{
    position:relative;
    z-index:1;
  }

  .board-head{
    display:grid;
    grid-template-columns:minmax(0,1fr) auto;
    gap:14px;
    align-items:start;
    margin-bottom:12px;
  }

  .board-title{
    min-width:0;
    display:flex;
    flex-direction:column;
    gap:10px;
  }

  .board-kicker{
    display:inline-flex;
    align-items:center;
    gap:8px;
    width:fit-content;
    padding:7px 10px;
    border-radius:999px;
    font-size:11px;
    font-weight:900;
    color:#d8e4f0;
    background:rgba(255,255,255,.045);
    border:1px solid var(--line);
    letter-spacing:.04em;
    text-transform:uppercase;
  }

  .board-title h2{
    margin:0;
    font-size:32px;
    line-height:1;
    letter-spacing:-.03em;
    font-weight:900;
  }

  .board-title small{
    color:var(--muted);
    font-size:13px;
    line-height:1.4;
  }

  .board-head-right{
    min-width:0;
    display:flex;
    flex-direction:column;
    align-items:flex-end;
    gap:10px;
  }

  .voice-row{
    display:flex;
    align-items:center;
    gap:10px;
    flex-wrap:wrap;
    justify-content:flex-end;
  }

  .voice-command-btn{
    display:inline-flex;
    align-items:center;
    justify-content:center;
    gap:8px;
    height:44px;
    min-width:152px;
    padding:0 14px;
    border:none;
    border-radius:15px;
    cursor:pointer;
    color:#fff;
    font-size:13px;
    font-weight:900;
    white-space:nowrap;
    background:linear-gradient(180deg, #8b5cf6, #6d28d9);
    border:1px solid rgba(255,255,255,.16);
    box-shadow:
      0 12px 24px rgba(0,0,0,.24),
      0 0 0 1px rgba(255,255,255,.05) inset;
    transition:.16s ease;
  }

  .voice-command-btn.listening{
    animation:micPulse 1s ease-in-out infinite;
    background:linear-gradient(180deg, #ef4444, #b91c1c);
  }

  .voice-state{
    display:inline-flex;
    align-items:center;
    gap:8px;
    min-height:40px;
    padding:8px 12px;
    border-radius:999px;
    background:rgba(255,255,255,.045);
    border:1px solid var(--line);
    color:#dbe7f4;
    font-size:12px;
    font-weight:800;
  }

  .legend{
    display:flex;
    flex-wrap:wrap;
    gap:8px;
    justify-content:flex-end;
  }

  .legend .mini-chip{
    min-height:34px;
    padding:7px 11px;
    font-size:12px;
  }

  .selected-stop-chip{
    display:inline-flex;
    align-items:center;
    gap:8px;
    min-height:40px;
    padding:9px 13px;
    border-radius:999px;
    background:rgba(255,255,255,.05);
    border:1px solid var(--line);
    color:#fff;
    font-weight:900;
    font-size:13px;
    width:fit-content;
    max-width:100%;
    box-shadow:0 10px 22px rgba(0,0,0,.18);
  }

  .route-strip-shell{
    margin-bottom:12px;
    padding:12px;
    border-radius:22px;
    background:linear-gradient(180deg, rgba(255,255,255,.04), rgba(255,255,255,.02));
    border:1px solid var(--line);
    box-shadow:var(--shadow-soft);
  }

  .route-strip-head{
    display:flex;
    align-items:center;
    justify-content:space-between;
    gap:10px;
    flex-wrap:wrap;
    margin-bottom:10px;
  }

  .route-strip-title{
    font-size:13px;
    font-weight:900;
    color:#dce6f0;
  }

  .route-strip-meta{
    display:flex;
    align-items:center;
    gap:8px;
    flex-wrap:wrap;
  }

  .route-pill{
    display:inline-flex;
    align-items:center;
    gap:6px;
    min-height:30px;
    padding:6px 10px;
    border-radius:999px;
    font-size:11px;
    font-weight:900;
    color:#dfe9f5;
    background:rgba(255,255,255,.04);
    border:1px solid var(--line);
  }

  .route-strip{
    display:flex;
    gap:8px;
    overflow:auto;
    padding-bottom:2px;
    scrollbar-width:none;
  }

  .route-strip::-webkit-scrollbar{ display:none; }

  .route-stop{
    flex:0 0 auto;
    min-width:138px;
    min-height:84px;
    padding:10px 12px;
    border-radius:18px;
    background:rgba(255,255,255,.04);
    border:1px solid var(--line);
    display:flex;
    flex-direction:column;
    justify-content:space-between;
    gap:6px;
    box-shadow:0 10px 20px rgba(0,0,0,.16);
    text-align:left;
  }

  .route-stop .name{
    font-size:12px;
    font-weight:900;
    color:#ecf3fb;
    line-height:1.25;
  }

  .route-stop .meta{
    font-size:10px;
    color:var(--muted);
    line-height:1.2;
  }

  .route-stop .extra{
    display:grid;
    gap:4px;
    margin-top:2px;
  }

  .route-stop .extra-line{
    display:flex;
    align-items:center;
    justify-content:space-between;
    gap:8px;
    font-size:10px;
    line-height:1.2;
  }

  .route-stop .extra-k{
    color:var(--muted);
    font-weight:700;
    white-space:nowrap;
  }

  .route-stop .extra-v{
    color:#dfe9f5;
    font-weight:900;
    text-align:right;
    white-space:nowrap;
  }

  .route-stop.active{
    background:linear-gradient(180deg, rgba(37,99,235,.22), rgba(37,99,235,.10));
    border-color:rgba(96,165,250,.35);
    box-shadow:
    0 12px 24px rgba(0,0,0,.18),
    0 0 0 1px rgba(96,165,250,.16) inset;
  }

  .route-stop.done{
    opacity:.58;
  }

  .board-stage{
    position:relative;
    border-radius:26px;
    padding:14px 12px 12px;
    background:
      linear-gradient(180deg, rgba(255,255,255,.03), rgba(255,255,255,.015)),
      radial-gradient(circle at center, rgba(37,99,235,.04), transparent 60%);
    border:1px solid var(--line-2);
    overflow:auto;
    overflow-x:auto;
    overflow-y:visible;
    scroll-margin-top:12px;
  }

  .deck-wrap{
    position:relative;
    width:max-content;
    min-width:100%;
    margin:0 auto;
  }

  .deck{
    position:relative;
    display:grid;
    grid-template-columns:var(--seat-w) var(--seat-w) var(--seat-w) var(--seat-w);
    grid-auto-rows:calc(var(--seat-h) + 24px);
    column-gap:var(--seat-gap-x);
    row-gap:var(--seat-gap-y);
    justify-content:center;
    min-height:auto;
    padding:14px 8px 8px;
  }

  .corr{
    grid-column:2;
    grid-row:1/15;
    width:58px;
    justify-self:center;
    border-radius:20px;
    background:linear-gradient(180deg,#7b1d1d,#8f2525 55%, #7b1d1d);
    box-shadow:0 20px 40px rgba(0,0,0,.25);
    display:flex;
    align-items:center;
    justify-content:center;
    writing-mode:vertical-rl;
    letter-spacing:5px;
    font-size:12px;
    font-weight:900;
    color:#fff;
    opacity:.94;
  }

  .door{
    grid-column:3/5;
    grid-row:7;
    align-self:center;
    height:28px;
    border-radius:12px;
    background:linear-gradient(180deg,#a16d24,#7b551b);
    color:#fff;
    display:flex;
    align-items:center;
    justify-content:center;
    font-size:12px;
    font-weight:900;
    letter-spacing:.06em;
    box-shadow:0 10px 22px rgba(0,0,0,.22);
  }

  .cell{
    position:relative;
    z-index:1;
    display:flex;
    flex-direction:column;
    align-items:center;
    gap:7px;
  }

  .seat{
    position:relative;
    z-index:1;
    width:var(--seat-w);
    height:var(--seat-h);
    border-radius:22px;
    display:flex;
    align-items:center;
    justify-content:center;
    font-size:20px;
    font-weight:900;
    color:#fff;
    cursor:pointer;
    user-select:none;
    transition:.16s ease;
    background:linear-gradient(180deg, #1ea34f, #16763a);
    border:1px solid rgba(255,255,255,.12);
    box-shadow:
      inset 0 -10px 18px rgba(0,0,0,.14),
      0 14px 28px rgba(0,0,0,.34);
  }

  .seat.selected{ outline:3px solid #7fc7ff; }
  .seat.isAssigned{ background:linear-gradient(180deg, #465b70, #304455); }
  .seat.male{ background:linear-gradient(180deg, #2970e0, #1c4ca8); }
  .seat.female{ background:linear-gradient(180deg, #eb5aa6, #c82773); }
  .seat.multi-picked{ outline:3px dashed #92b7ff; }
  .seat.has-stop{
    box-shadow:
      0 0 0 2px rgba(245,158,11,.42) inset,
      0 14px 28px rgba(0,0,0,.34);
  }

  .seat.blink-yellow{
    animation:blinkWarn 1s linear infinite;
    outline:3px solid rgba(245,158,11,.95);
  }

  @keyframes blinkWarn{
    0%,100%{
      box-shadow:
        0 0 0 0 rgba(245,158,11,0),
        inset 0 -10px 18px rgba(0,0,0,.14),
        0 14px 28px rgba(0,0,0,.34);
    }
    50%{
      box-shadow:
        0 0 0 10px rgba(245,158,11,.20),
        inset 0 -10px 18px rgba(0,0,0,.14),
        0 14px 28px rgba(0,0,0,.34);
    }
  }

  .label{
    min-height:30px;
    width:88px;
    text-align:center;
    font-size:11px;
    line-height:1.22;
    color:#dce6ef;
    opacity:.96;
  }

  .svc-badge,
  .bag-badge,
  .stop-badge{
    position:absolute;
    display:none;
    align-items:center;
    justify-content:center;
    border-radius:999px;
    font-size:11px;
    font-weight:900;
    color:#fff;
    box-shadow:0 8px 18px rgba(0,0,0,.26);
  }

  .svc-badge{
    left:-7px;
    top:-7px;
    min-width:22px;
    min-height:22px;
    padding:3px 7px;
    background:var(--accent);
  }

  .bag-badge{
    right:-9px;
    top:-8px;
    min-height:23px;
    min-width:23px;
    padding:3px 7px;
    gap:4px;
    background:var(--primary);
  }

  .stop-badge{
    left:-7px;
    bottom:-7px;
    min-height:22px;
    padding:3px 7px;
    background:var(--warn);
    color:#1f1f1f;
  }

  .seat.has-service .svc-badge{ display:flex; }
  .seat.has-bag .bag-badge{ display:inline-flex; }
  .seat.has-stop .stop-badge{ display:flex; }

  .fab-column{
    position:absolute;
    right:14px;
    bottom:14px;
    z-index:40;
    display:flex;
    flex-direction:column;
    gap:10px;
  }

  .fab{
    width:58px;
    height:58px;
    border:none;
    border-radius:50%;
    color:#fff;
    font-size:22px;
    font-weight:900;
    cursor:pointer;
    box-shadow:0 16px 32px rgba(0,0,0,.32);
  }

  .fab.primary{ background:linear-gradient(180deg, #3b82f6, #1d4ed8); }
  .fab.green{ background:linear-gradient(180deg, #22c55e, #16843f); }
  .fab.purple{ background:linear-gradient(180deg, #8b5cf6, #6d28d9); }
  .fab.orange{ background:linear-gradient(180deg, #f59e0b, #d97706); }

  .fab.listening{
    animation:micPulse 1s ease-in-out infinite;
    background:linear-gradient(180deg, #ef4444, #b91c1c);
  }

  @keyframes micPulse{
    0%,100%{
      box-shadow:0 0 0 0 rgba(239,68,68,0), 0 14px 30px rgba(0,0,0,.3);
    }
    50%{
      box-shadow:0 0 0 11px rgba(239,68,68,.20), 0 14px 30px rgba(0,0,0,.3);
    }
  }

  .panel-card{
    position:relative;
    padding:14px;
    overflow:hidden;
  }

  .panel-handle{
    display:none;
    width:54px;
    height:5px;
    border-radius:999px;
    background:rgba(255,255,255,.18);
    margin:0 auto 12px;
  }

  .panel-tabs{
    display:grid;
    grid-template-columns:repeat(5, minmax(0,1fr));
    gap:8px;
    margin-bottom:12px;
  }

  .tab-btn{
    min-height:44px;
    border:none;
    border-radius:16px;
    padding:8px 10px;
    background:rgba(255,255,255,.045);
    border:1px solid var(--line);
    color:#dce7f2;
    font-weight:800;
    font-size:13px;
    cursor:pointer;
    transition:.16s ease;
  }

  .tab-btn.active{
    background:linear-gradient(180deg, rgba(37,99,235,.28), rgba(37,99,235,.14));
    border-color:rgba(96,165,250,.42);
    color:#fff;
    box-shadow:0 10px 20px rgba(0,0,0,.14);
  }

  .tab-pane{ display:none; }
  .tab-pane.active{ display:block; }

  .pane-grid{
    display:grid;
    gap:12px;
  }

  .section-box{
    border-radius:22px;
    padding:14px;
    background:rgba(255,255,255,.04);
    border:1px solid var(--line);
    box-shadow:0 12px 24px rgba(0,0,0,.10);
  }

  .section-head{
    display:flex;
    align-items:center;
    justify-content:space-between;
    gap:10px;
    margin-bottom:12px;
  }

  .section-head h3{
    margin:0;
    font-size:18px;
    line-height:1;
    font-weight:900;
  }

  .section-head small{
    color:var(--muted);
    font-size:12px;
    font-weight:700;
  }

  .metrics-grid{
    display:grid;
    grid-template-columns:1fr 1fr;
    gap:10px;
  }

  .metric-card{
    min-height:92px;
    border-radius:18px;
    padding:12px;
    background:rgba(255,255,255,.03);
    border:1px solid var(--line);
  }

  .metric-card .k{
    color:var(--muted);
    font-size:12px;
    font-weight:700;
    margin-bottom:6px;
  }

  .metric-card .v{
    font-size:17px;
    font-weight:900;
    line-height:1.15;
  }

  .metric-card .s{
    color:var(--muted);
    font-size:12px;
    margin-top:8px;
    line-height:1.35;
  }

  .clock-big{
    font-size:46px;
