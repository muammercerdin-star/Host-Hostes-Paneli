/* =========================================================
   CANLI DURAK 5 KM UYARI RENKLERİ
========================================================= */

.route-stop.live-danger{
  background:linear-gradient(135deg, rgba(127,29,29,.98), rgba(239,68,68,.55)) !important;
  border-color:rgba(248,113,113,.95) !important;
  box-shadow:
    0 0 0 1px rgba(248,113,113,.55),
    0 0 22px rgba(239,68,68,.55),
    inset 0 1px 0 rgba(255,255,255,.14) !important;
  animation:liveStopBlink .85s linear infinite;
}

.route-stop.live-danger .name,
.route-stop.live-danger .meta,
.route-stop.live-danger .extra-k,
.route-stop.live-danger .extra-v{
  color:#fff !important;
}

@keyframes liveStopBlink{
  0%,100%{
    filter:brightness(1);
    transform:scale(1);
  }
  50%{
    filter:brightness(1.35);
    transform:scale(1.025);
  }
}

.route-stop.next-warning{
  background:linear-gradient(135deg, rgba(120,75,0,.96), rgba(245,158,11,.55)) !important;
  border-color:rgba(251,191,36,.9) !important;
  box-shadow:
    0 0 0 1px rgba(251,191,36,.42),
    0 0 18px rgba(245,158,11,.35),
    inset 0 1px 0 rgba(255,255,255,.12) !important;
}

.route-stop.next-warning .name,
.route-stop.next-warning .meta,
.route-stop.next-warning .extra-k,
.route-stop.next-warning .extra-v{
  color:#fff !important;
}

.route-stop.flow-green{
  background:linear-gradient(135deg, rgba(20,83,45,.94), rgba(34,197,94,.44)) !important;
  border-color:rgba(74,222,128,.75) !important;
  box-shadow:
    0 0 0 1px rgba(74,222,128,.32),
    0 0 14px rgba(34,197,94,.22),
    inset 0 1px 0 rgba(255,255,255,.10) !important;
}

