/* =========================================================
   DRIVE MODE MODULE
   Sürüş modu + hız kutusu + gece ses kontrolü
========================================================= */

(function(){
  const $d = document;
  const KEY_TRIP = (typeof TRIP_KEY !== "undefined" && TRIP_KEY) ? TRIP_KEY : "default";
  const DRIVE_MODE_KEY = "driveMode:" + KEY_TRIP;
  const VOICE_SOUND_KEY = "voiceSoundEnabled:" + KEY_TRIP;

  function qs(sel){
    return $d.querySelector(sel);
  }

  function safeToast(msg, ms){
    try{
      if(typeof toast === "function") toast(msg, ms || 1800);
    }catch(_){}
  }

  function safeSpeak(msg){
    try{
      if(typeof speak === "function") speak(msg);
    }catch(_){}
  }

  function getLiveStopText(){
    try{
      if(typeof getDisplayLiveStop === "function"){
        return getDisplayLiveStop() || "";
      }
    }catch(_){}
    try{
      return speedState?.liveStop || "";
    }catch(_){}
    return "";
  }

  function getSpeedInfo(){
    let speed = 0;
    let limit = 0;

    try{
      speed = Math.round(Number(speedState?.current || 0));
      limit = Number(speedState?.lastLimitValue || speedState?.lastLimitObj?.limit || 0);
    }catch(_){}

    return { speed, limit };
  }

  function ensureDriveInlineDock(){
    let dock = $d.getElementById("driveInlineDock");

    if(!dock){
      dock = $d.createElement("div");
      dock.id = "driveInlineDock";

      const board = qs(".board-card .board-inner") || qs(".board-card") || qs(".seats-shell");
      if(board){
        board.prepend(dock);
      }else{
        $d.body.appendChild(dock);
      }
    }

    return dock;
  }

  function ensureDriveModeButton(){
    const dock = ensureDriveInlineDock();
    let btn = $d.getElementById("driveModeToggle");

    if(!btn){
      btn = $d.createElement("button");
      btn.id = "driveModeToggle";
      btn.type = "button";
      btn.className = "drive-mode-toggle";
      dock.appendChild(btn);
    }else if(btn.parentElement !== dock){
      dock.appendChild(btn);
    }

    if(btn.dataset.driveBound !== "1"){
      btn.dataset.driveBound = "1";
      btn.addEventListener("click", () => {
        setDriveMode(!$d.body.classList.contains("drive-mode"));
      });
    }

    syncDriveModeButton();
    return btn;
  }

  function syncDriveModeButton(){
    const btn = $d.getElementById("driveModeToggle");
    if(!btn) return;

    const on = $d.body.classList.contains("drive-mode");
    btn.innerHTML = on ? "↩ Normal" : "🚘 Sürüş";
    btn.title = on ? "Normal moda dön" : "Sürüş moduna geç";
  }

  function setDriveMode(on){
    const enabled = !!on;

    $d.body.classList.toggle("drive-mode", enabled);
    localStorage.setItem(DRIVE_MODE_KEY, enabled ? "1" : "0");

    syncDriveModeButton();
    ensureDriveSpeedChip();
    updateDriveSpeedChip();

    safeToast(enabled ? "Sürüş modu açıldı" : "Normal moda dönüldü", 1500);
  }

  function loadDriveMode(){
    const saved = localStorage.getItem(DRIVE_MODE_KEY);
    if(saved === "1"){
      $d.body.classList.add("drive-mode");
    }else{
      $d.body.classList.remove("drive-mode");
    }
    syncDriveModeButton();
  }

  function ensureDriveSpeedChip(){
    const dock = ensureDriveInlineDock();
    let chip = $d.getElementById("driveSpeedChip");

    if(!chip){
      chip = $d.createElement("div");
      chip.id = "driveSpeedChip";
      chip.className = "drive-speed-chip neutral";
      dock.appendChild(chip);
    }else if(chip.parentElement !== dock){
      dock.appendChild(chip);
    }

    return chip;
  }

  function updateDriveSpeedChip(){
    const chip = ensureDriveSpeedChip();
    const { speed, limit } = getSpeedInfo();
    const liveStop = getLiveStopText();

    let cls = "neutral";
    if(limit > 0){
      if(speed <= limit) cls = "ok";
      else if(speed <= limit + 10) cls = "warn";
      else cls = "bad";
    }

    chip.className = "drive-speed-chip " + cls;

    const limitText = limit > 0 ? `Limit: ${limit}` : "Limit: —";
    const stopText = liveStop ? ` · ${liveStop}` : "";

    chip.innerHTML = `
      <div class="drive-speed-top">
        <span class="drive-speed-ico">🚦</span>
        <b>${speed}</b>
        <span>km/h</span>
      </div>
      <div class="drive-speed-sub">${limitText}${stopText}</div>
    `;
  }

  function getVoiceEnabled(){
    const saved = localStorage.getItem(VOICE_SOUND_KEY);
    if(saved !== null) return saved === "1";

    const cb = $d.getElementById("soundToggle");
    if(cb) return cb.checked !== false;

    return true;
  }

  function updateNightVoiceToggle(){
    const btn = $d.getElementById("nightVoiceToggle");
    if(!btn) return;

    const on = getVoiceEnabled();

    btn.classList.toggle("is-off", !on);
    btn.innerHTML = on
      ? `<span class="nv-ico">🔊</span><span>Ses Açık</span>`
      : `<span class="nv-ico">🔇</span><span>Sessiz</span>`;

    btn.title = on
      ? "Sesli robot açık. Kapatmak için dokun."
      : "Sesli robot kapalı. Açmak için dokun.";
  }

  function setVoiceEnabled(on, opts){
    const options = opts || {};
    const enabled = !!on;

    localStorage.setItem(VOICE_SOUND_KEY, enabled ? "1" : "0");

    const cb = $d.getElementById("soundToggle");
    if(cb) cb.checked = enabled;

    updateNightVoiceToggle();

    if(!options.silent){
      safeToast(enabled ? "Sesli robot açıldı" : "Sesli robot kapatıldı", 1600);
    }

    if(enabled && options.announce){
      setTimeout(() => safeSpeak("Sesli robot açık."), 80);
    }
  }

  function ensureNightVoiceToggle(){
    let btn = $d.getElementById("nightVoiceToggle");

    if(!btn){
      btn = $d.createElement("button");
      btn.id = "nightVoiceToggle";
      btn.type = "button";
      btn.className = "night-voice-toggle";

      const meta = qs(".route-strip-meta");
      const head = qs(".route-strip-head");

      if(meta){
        meta.appendChild(btn);
      }else if(head){
        head.appendChild(btn);
      }else{
        $d.body.appendChild(btn);
      }

      btn.addEventListener("click", () => {
        setVoiceEnabled(!getVoiceEnabled(), { announce:true });
      });
    }

    const saved = localStorage.getItem(VOICE_SOUND_KEY);
    const cb = $d.getElementById("soundToggle");

    if(saved !== null && cb){
      cb.checked = saved === "1";
    }

    if(cb && cb.dataset.voiceBound !== "1"){
      cb.dataset.voiceBound = "1";
      cb.addEventListener("change", () => {
        setVoiceEnabled(cb.checked, { silent:true });
      });
    }

    updateNightVoiceToggle();
  }

  function bootDriveMode(){
    ensureDriveInlineDock();
    ensureDriveModeButton();
    ensureDriveSpeedChip();
    ensureNightVoiceToggle();
    loadDriveMode();
    updateDriveSpeedChip();
  }

  bootDriveMode();

  window.addEventListener("load", bootDriveMode);
  window.addEventListener("resize", bootDriveMode);

  setTimeout(bootDriveMode, 400);
  setTimeout(bootDriveMode, 1200);

  setInterval(updateDriveSpeedChip, 1000);

  window.DriveModeModule = {
    boot: bootDriveMode,
    updateSpeed: updateDriveSpeedChip,
    setDriveMode,
    setVoiceEnabled
  };
})();
