<!doctype html>
<html lang="tr">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Muavin Paneli</title>

  <style>
    :root{
      --bg:#eef6ff;
      --text:#0d1b33;
      --muted:#61728a;
      --line:#e5edf6;
      --blue:#1677ff;
      --purple:#6d5dfc;
    }

    *{
      box-sizing:border-box;
    }

    body{
      margin:0;
      min-height:100vh;
      background:
        radial-gradient(circle at 20% 0%, rgba(22,119,255,.14), transparent 32%),
        linear-gradient(180deg,#f8fbff,#eaf3ff);
      font-family:system-ui,-apple-system,"Segoe UI",Roboto,Arial,sans-serif;
      color:var(--text);
    }

    .home-shell{
      width:min(94vw,720px);
      margin:18px auto 28px;
      padding:16px;
      border-radius:28px;
      background:linear-gradient(180deg,#f8fbff,#edf6ff);
      border:1px solid rgba(148,163,184,.18);
      box-shadow:0 24px 60px rgba(15,23,42,.16);
    }

    .route-card{
      height:54px;
      display:flex;
      align-items:center;
      gap:12px;
      padding:0 18px;
      margin-bottom:14px;
      border-radius:19px;
      background:#fff;
      border:1px solid rgba(148,163,184,.22);
      box-shadow:0 10px 24px rgba(15,23,42,.08);
      font-weight:900;
      font-size:17px;
      color:#0f172a;
    }

    .route-card .pin{
      color:#1677ff;
      font-size:22px;
    }

    .route-card .caret{
      margin-left:auto;
      color:#334155;
      font-size:16px;
    }

    .hero-link{
      display:block;
      width:100%;
      height:118px;
      margin-bottom:10px;
      border-radius:21px;
      overflow:hidden;
      text-decoration:none;
      box-shadow:0 16px 34px rgba(15,23,42,.16);
      background:#dbeafe;
      -webkit-tap-highlight-color:transparent;
    }

    .hero-link:active{
      transform:scale(.99);
    }

    .hero-link img{
      width:100%;
      height:100%;
      display:block;
      object-fit:cover;
    }

    .menu-list{
      margin-top:12px;
      overflow:hidden;
      border-radius:22px;
      background:#fff;
      border:1px solid rgba(226,232,240,.92);
      box-shadow:0 14px 34px rgba(15,23,42,.10);
    }

    .menu-item{
      min-height:58px;
      display:grid;
      grid-template-columns:42px 1fr 26px;
      align-items:center;
      gap:0;
      padding:8px 12px 8px 14px;
      color:#10203a;
      text-decoration:none;
      border-bottom:1px solid var(--line);
      -webkit-tap-highlight-color:transparent;
    }

    .menu-item:last-child{
      border-bottom:none;
    }

    .menu-item:active{
      background:#f1f7ff;
    }

    .ico{
      width:30px;
      height:30px;
      display:grid;
      place-items:center;
      font-size:21px;
    }

    .menu-title{
      font-size:16px;
      line-height:1.05;
      font-weight:950;
      color:#10203a;
      margin-bottom:3px;
    }

    .menu-desc{
      font-size:13px;
      line-height:1.15;
      font-weight:600;
      color:var(--muted);
    }

    .arrow{
      justify-self:end;
      font-size:30px;
      line-height:1;
      font-weight:800;
      color:#64748b;
    }

    .lock-btn{
      margin-top:14px;
      min-height:58px;
      display:flex;
      align-items:center;
      justify-content:center;
      gap:10px;
      width:100%;
      border-radius:21px;
      background:#fff;
      color:var(--purple);
      border:1px solid rgba(226,232,240,.95);
      box-shadow:0 12px 28px rgba(15,23,42,.10);
      text-decoration:none;
      font-size:17px;
      font-weight:950;
      letter-spacing:.2px;
    }

    .lock-btn:active{
      transform:scale(.99);
    }

    @media(max-width:420px){
      .home-shell{
        width:calc(100vw - 24px);
        margin:14px auto 24px;
        padding:14px;
        border-radius:26px;
      }

      .hero-link{
        height:112px;
        border-radius:20px;
      }

      .menu-item{
        min-height:55px;
      }

      .menu-title{
        font-size:15.5px;
      }

      .menu-desc{
        font-size:12.8px;
      }
    }
  </style>
</head>

<body>
  <main class="home-shell">

    {% set current_route = selected_route if selected_route is defined and selected_route else (active_trip.route if active_trip is defined and active_trip else 'Denizli – İstanbul') %}

    <div class="route-form">
      <label class="route-picker" for="homeRouteSelect">
        <span class="pin">📍</span>

        <select id="homeRouteSelect" name="route">
          {% if all_routes is defined and all_routes %}
            {% for r in all_routes %}
              <option value="{{ r }}" {% if r == current_route %}selected{% endif %}>{{ r }}</option>
            {% endfor %}
          {% else %}
            <option value="{{ current_route }}">{{ current_route }}</option>
          {% endif %}
        </select>

        <span class="caret">⌄</span>
      </label>
    </div>

<a id="homeTripStart" class="hero-link" data-base="{{ url_for('trip_start') }}" href="{{ url_for('trip_start') }}" aria-label="Sefer Başlat">
      <img src="{{ url_for('static', filename='img/home-bus-card.jpg') }}" alt="Sefer Başlat">
    </a>

    <a class="hero-link" href="{{ url_for('continue_trip') }}" aria-label="Devam Eden Sefer">
      <img src="{{ url_for('static', filename='img/home-seat-card.jpg') }}" alt="Devam Eden Sefer">
    </a>

    <section class="menu-list">
      <a class="menu-item" href="{{ url_for('seats_page') }}">
        <span class="ico">💺</span>
        <span>
          <div class="menu-title">HIZLI KOLTUK</div>
          <div class="menu-desc">Koltuk ekranına git</div>
        </span>
        <span class="arrow">›</span>
      </a>

      <a class="menu-item" href="{{ url_for('passenger_control') }}">
        <span class="ico">👥</span>
        <span>
          <div class="menu-title">YOLCU KONTROLÜ</div>
          <div class="menu-desc">Koltuk kontrol ekranı</div>
        </span>
        <span class="arrow">›</span>
      </a>

      <a class="menu-item" href="{{ url_for('hesap_page') }}">
        <span class="ico">💵</span>
        <span>
          <div class="menu-title">HESAP</div>
          <div class="menu-desc">Sefer kasa / giriş-çıkış / kalan</div>
        </span>
        <span class="arrow">›</span>
      </a>

      <a class="menu-item" href="{{ url_for('consignments_page') }}">
        <span class="ico">📦</span>
        <span>
          <div class="menu-title">EMANETLER</div>
          <div class="menu-desc">Emanet kayıt ve teslim işlemleri</div>
        </span>
        <span class="arrow">›</span>
      </a>

      <a class="menu-item" href="{{ url_for('add_route') }}">
        <span class="ico">🛣️</span>
        <span>
          <div class="menu-title">HAT EKLE</div>
          <div class="menu-desc">Yeni hat ve durakları tanımla</div>
        </span>
        <span class="arrow">›</span>
      </a>

      <a class="menu-item" href="{{ url_for('routes_list') }}">
        <span class="ico">🗺️</span>
        <span>
          <div class="menu-title">HATLAR</div>
          <div class="menu-desc">Hatları listele / düzenle</div>
        </span>
        <span class="arrow">›</span>
      </a>

      <a class="menu-item" href="/sefer-raporu-son">
        <span class="ico">📁</span>
        <span>
          <div class="menu-title">SEFER RAPORLARI</div>
          <div class="menu-desc">Biten sefer raporlarını aç</div>
        </span>
        <span class="arrow">›</span>
      </a>

      <a class="menu-item" href="{{ url_for('fare_query') }}">
        <span class="ico">🏷️</span>
        <span>
          <div class="menu-title">FİYAT SORGU</div>
          <div class="menu-desc">Biniş/iniş seç, fiyatı gör</div>
        </span>
        <span class="arrow">›</span>
      </a>
    </section>

    <form class="lock-form" method="post" action="{{ url_for('logout') }}">
      {% if csrf_token is defined %}
        <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
      {% endif %}
      <button class="lock-btn" type="submit">🔒 KİLİTLE</button>
    </form>

</main>

<style id="home-route-lock-fix">
.route-form{
  margin-bottom:14px;
}

.route-picker{
  height:54px;
  display:flex;
  align-items:center;
  gap:12px;
  padding:0 16px;
  border-radius:19px;
  background:#fff;
  border:1px solid rgba(148,163,184,.22);
  box-shadow:0 10px 24px rgba(15,23,42,.08);
}

.route-picker .pin{
  font-size:22px;
}

#homeRouteSelect{
  flex:1;
  min-width:0;
  border:0;
  outline:0;
  background:transparent;
  color:#0f172a;
  font-family:system-ui,-apple-system,"Segoe UI",Roboto,Arial,sans-serif;
  font-size:17px;
  font-weight:900;
  appearance:none;
  -webkit-appearance:none;
}

.route-picker .caret{
  color:#334155;
  font-size:18px;
  pointer-events:none;
}

.lock-form{
  margin:0;
  padding:0;
}

.lock-form .lock-btn{
  cursor:pointer;
}
</style>

<script id="home-route-link-fix">
(function(){
  const routeSelect = document.getElementById("homeRouteSelect");
  const startLink = document.getElementById("homeTripStart");

  function syncStartLink(){
    if(!routeSelect || !startLink) return;

    const route = routeSelect.value || "";
    const base = startLink.dataset.base || startLink.getAttribute("href") || "/sefer-baslat";

    startLink.href = base + "?route=" + encodeURIComponent(route);

    try{
      localStorage.setItem("homeSelectedRoute", route);
    }catch(_){}
  }

  if(routeSelect){
    try{
      const saved = localStorage.getItem("homeSelectedRoute");
      if(saved){
        const opt = Array.from(routeSelect.options).find(o => o.value === saved);
        if(opt) routeSelect.value = saved;
      }
    }catch(_){}

    routeSelect.addEventListener("change", syncStartLink);
    syncStartLink();
  }
})();
</script>

</body>
</html>
