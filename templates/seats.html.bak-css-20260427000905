{% extends "base.html" %}
{% block content %}

<link rel="stylesheet" href="/static/style.css">
<link rel="stylesheet" href="/static/seats/seats.css?v=1">



<div class="seats-shell">
  <div class="topbar glass">
    <div class="route-meta">
      <div class="route-title-row">
        <div class="route-badge">🚌</div>
        <div class="route-title-wrap">
          <div class="route-title">{{ trip['route'] }}</div>
          <div class="route-sub">
            Plaka: <b>{{ trip['plate'] or '-' }}</b>
            · Sefer Tarihi: <b>{{ trip['date'] or '-' }}</b>
            · Çıkış: <b>{{ trip['departure_time'] or '-' }}</b>
          </div>
        </div>
      </div>

      <div class="route-live-row">
        <div class="mini-chip">📍 <span>Durak</span> <b id="topLiveStop">—</b></div>
        <div class="mini-chip">🚦 <span>Hız</span> <b id="topSpeed">0 km/h</b></div>
        <div class="mini-chip">🕒 <span>Saat</span> <b id="topClock">--:--</b></div>
        <div class="mini-chip">🎯 <span>Doluluk</span> <b id="topOcc">0%</b></div>
      </div>
    </div>

    <div class="top-actions">
      <a href="{{ url_for('index') }}" class="icon-btn" title="Ana Sayfa">🏠</a>
      <a href="{{ url_for('hesap_page') }}" class="icon-btn" title="Hesap">💵</a>
      <a href="{{ url_for('consignments_page') }}" class="icon-btn" title="Emanetler">📦</a>
      <a href="{{ url_for('ai_console_page') }}" class="icon-btn" title="AI Console">🧠</a>
      <form method="post" action="{{ url_for('end_trip') }}" onsubmit="return confirm('Sefer sonlandırılsın mı?')">
        <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
        <button type="submit" class="icon-btn" title="Seferi Sonlandır">⛔</button>
      </form>
    </div>
  </div>

  <div class="status-row">
    <div class="status-pill total">
      <div class="k">Toplam Yolcu</div>
      <div class="v" id="pillTotal">0</div>
    </div>
    <div class="status-pill empty">
      <div class="k">Boş Koltuk</div>
      <div class="v" id="pillEmpty">0</div>
    </div>
    <div class="status-pill standing" id="standingCard" role="button" tabindex="0">
      <div class="k">Ayakta</div>
      <div class="v" id="pillStanding">0</div>
    </div>
    <div class="status-pill cash">
      <div class="k">Ayakta Tahsilat</div>
      <div class="v" id="pillCash">₺0.00</div>
    </div>
    <div class="status-pill service">
      <div class="k">Servis</div>
      <div class="v" id="pillService">0</div>
    </div>
    <div class="status-pill parcel">
      <div class="k">Emanet</div>
      <div class="v" id="pillParcel">0</div>
    </div>
  </div>

  <div class="layout">
    <section class="board-card glass">
      <div class="board-inner">
        <div class="board-head">
          <div class="board-title">
            <div class="board-kicker">Canlı Operasyon Paneli</div>
            <h2>Koltuk Planı</h2>
            <small>Tek ekrandan yolcu, durak, iniş ve hızlı işlemleri yönet.</small>
            <div class="selected-stop-chip">🎯 Seçili durak: <b id="selectedStopBadge">—</b></div>
          </div>

          <div class="board-head-right">
            <div class="voice-row">
              <button class="voice-command-btn" id="btnDeckAI" type="button" title="Sesli Komut">
                🎤 <span>Sesli Komut</span>
              </button>
              <div class="voice-state" id="voiceStateBadge">Hazır</div>
            </div>

            <div class="legend">
              <div class="mini-chip">🟢 Boş</div>
              <div class="mini-chip">🔵 Bay</div>
              <div class="mini-chip">🩷 Bayan</div>
              <div class="mini-chip">🧳 Bagaj</div>
              <div class="mini-chip">🔔 İniş</div>
              <div class="mini-chip">🚌 Servis</div>
            </div>
          </div>
        </div>

        <div class="route-strip-shell">
          <div class="route-strip-head">
            <div class="route-strip-title">Durak Akışı</div>
            <div class="route-strip-meta">
              <div class="route-pill">Canlı: <b id="routeMiniLive">—</b></div>
              <div class="route-pill">Sıradaki: <b id="routeMiniNext">—</b></div>
            </div>
          </div>

          <div class="route-strip" id="routeStrip">
            <div class="route-stop active">
              <div class="name">Rota hazırlanıyor</div>
              <div class="meta">Duraklar yüklenecek</div>
            </div>
          </div>
        </div>

        <div class="board-stage">
          <div class="deck-wrap">
            <div class="deck" id="deck">
              <div class="corr">KORİDOR</div>

              {% for n, pos in seat_positions.items() %}
                {% if n == 29 %}
                  <div class="door">KAPI</div>
                {% endif %}

                <div class="cell" style="grid-row:{{ pos[0] }}; grid-column:{{ pos[1] }};">
                  <div class="seat" id="seat-{{ n }}" data-seat="{{ n }}" role="button" aria-label="Koltuk {{ n }}">
                    {{ n }}
                    <span class="svc-badge" title="Servis">🚌</span>
                    <span class="bag-badge" title="Bagaj"><span class="bag-dir"></span><span class="bag-count">0</span></span>
                    <span class="stop-badge" title="Bu durakta inecek">🔔</span>
                  </div>
                  <div class="label" id="label-{{ n }}"></div>
                </div>
              {% endfor %}
            </div>

            <div class="fab-column" aria-label="Hızlı işlemler">
              <button class="fab primary" id="fabBulk" type="button" title="Toplu Giriş">＋</button>
              <button class="fab green" id="fabCash" type="button" title="Hızlı Tahsilat">₺</button>
              <button class="fab orange" id="btnOffloadNow" type="button" title="İndir">⇩</button>
            </div>
          </div>
        </div>
      </div>
    </section>

    <aside class="panel-card glass">
      <div class="panel-handle"></div>

      <div class="panel-tabs">
        <button class="tab-btn active" type="button" data-tab="overview">Genel</button>
        <button class="tab-btn" type="button" data-tab="route">Durak</button>
        <button class="tab-btn" type="button" data-tab="eta">ETA</button>
        <button class="tab-btn" type="button" data-tab="quick">İşlem</button>
        <button class="tab-btn" type="button" data-tab="ai">Asistan</button>
      </div>

      <div class="tab-pane active" data-pane="overview">
        <div class="pane-grid">
          <div class="section-box">
            <div class="section-head">
              <h3>Operasyon Özeti</h3>
              <small id="miniLiveState">Hazır</small>
            </div>

            <div class="metrics-grid">
              <div class="metric-card">
                <div class="k">Canlı Durak</div>
                <div class="v" id="miniStop">—</div>
                <div class="s">GPS veya manuel seçime göre</div>
              </div>
              <div class="metric-card">
                <div class="k">Sonraki İşlem</div>
                <div class="v" id="aiNextAction">—</div>
                <div class="s">Sistem önerisi</div>
              </div>
            </div>
          </div>

          <div class="section-box">
            <div class="section-head">
              <h3>Saat</h3>
              <small id="clockSub">—</small>
            </div>
            <div class="clock-big" id="clockMain">--:--:--</div>
            <div class="clock-date" id="clockDate">—</div>
          </div>

          <div class="section-box">
            <div class="section-head">
              <h3>Namaz Vakti</h3>
              <small>Canlı</small>
            </div>
            <div class="prayer-line" id="prLine">Konum alınıyor…</div>
          </div>

          <div class="section-box">
            <div class="speed-box" id="speedBox">
              <div class="speed-left">
                <div class="k">Hız / Limit</div>
                <div class="speed-value"><b id="spVal">0</b><span>km/h</span></div>
                <div class="speed-meta" id="spLimit">Limit: —</div>
              </div>
              <button class="tts-btn" id="ttsToggle" title="Sesli uyarı">🔊</button>
            </div>
          </div>

          <div class="section-box">
            <div class="section-head">
              <h3>Rötar / ETA</h3>
              <small id="routeNextTimed">—</small>
            </div>
            <div class="delay-main warn" id="delayMain">—</div>
            <div class="delay-sub" id="delaySub">Saatli durak bekleniyor</div>
          </div>

          <div class="section-box">
            <div class="section-head">
              <h3>Ekip</h3>
              <small>Aktif sefer</small>
            </div>
            <div class="crew-list">
              <div class="crew-item">🧑‍✈️ 1. Kaptan: <b>{{ trip['captain1'] or '-' }}</b></div>
              <div class="crew-item">🧑‍✈️ 2. Kaptan: <b>{{ trip['captain2'] or '-' }}</b></div>
              <div class="crew-item">🤝 Muavin: <b>{{ trip['attendant'] or '-' }}</b></div>
            </div>
          </div>
        </div>
      </div>

      <div class="tab-pane" data-pane="route">
        <div class="pane-grid">
          <div class="section-box">
            <div class="section-head">
              <h3>Canlı Durak Yönetimi</h3>
              <small id="routeLiveStop">—</small>
            </div>

            <div class="field-grid">
              <label class="field">
                <span>Sıradaki Durak</span>
                <select id="alertStop">
                  <option value="">—</option>
                </select>
              </label>

              <div class="field-row">
                <label class="field">
                  <span>Eşik (km)</span>
                  <input type="number" id="alertRadius" min="0.1" step="0.1" value="3">
                </label>

                <label class="field">
                  <span>Konum İzleme</span>
                  <button class="btn primary" type="button" id="btnGeoWatch">KAPALI</button>
                </label>
              </div>

              <div class="toggle-line">
                <label><input type="checkbox" id="soundToggle" checked> Sesli yanıt</label>
                <label><input type="checkbox" id="autoAdvanceToggle" checked> Oto ilerle</label>
              </div>

              <div class="action-grid">
                <button class="btn warn" type="button" id="btnTriggerNow">Şimdi Uyar</button>
                <button class="btn danger" type="button" id="btnOffloadNowPane">İnecekleri İndir</button>
              </div>

              <div class="muted" id="geoHint">Durak seç.</div>
            </div>
          </div>

          <div class="section-box">
            <div class="section-head">
              <h3>Koordinat</h3>
              <small>route_stop_coords</small>
            </div>

            <div class="field-grid">
              <label class="field">
                <span>Seçili Durak</span>
                <input type="text" id="coordStopName" readonly>
              </label>

              <div class="field-row">
                <label class="field">
                  <span>Lat</span>
                  <input type="number" id="coordLat" step="0.000001" placeholder="37.xxxxxx">
                </label>
                <label class="field">
                  <span>Lng</span>
                  <input type="number" id="coordLng" step="0.000001" placeholder="29.xxxxxx">
                </label>
              </div>

              <button class="btn accent" type="button" id="btnSaveCoord">Koordinatı Kaydet</button>
              <div class="muted">Bu kayıt route_stop_coords tablosuna yazılır.</div>
            </div>
          </div>
        </div>
      </div>

      <div class="tab-pane" data-pane="eta">
        <div class="pane-grid">
          <div class="section-box">
            <div class="section-head">
              <h3>Saatli Garaj / Rötar</h3>
              <small id="stEtaHint">Plan / ETA</small>
            </div>

            <div class="metrics-grid">
              <div class="metric-card">
                <div class="k">Canlı Durak</div>
                <div class="v" id="routeLiveStopCard">—</div>
              </div>
              <div class="metric-card">
                <div class="k">Sonraki Saatli</div>
                <div class="v" id="stEtaTarget">—</div>
              </div>
            </div>

            <div class="timeline-list" id="etaTimeline" style="margin-top:12px;"></div>
          </div>
        </div>
      </div>

      <div class="tab-pane" data-pane="quick">
        <div class="pane-grid">
          <div class="section-box">
            <div class="section-head">
              <h3>Hızlı İşlemler</h3>
              <small>Tek dokunuş</small>
            </div>

            <div class="action-grid">
              <button class="btn primary" type="button" id="fabBulkPane">Toplu Giriş</button>
              <button class="btn green" type="button" id="fabCashPane">Hızlı Tahsilat</button>
              <button class="btn ghost" type="button" id="openStandingModalBtn">Ayakta Listesi</button>
              <button class="btn dark" type="button" id="btnOpenRouteTab">Durak Sekmesi</button>
            </div>
          </div>

          <div class="section-box">
            <div class="section-head">
              <h3>Ayakta Yolcular</h3>
              <small id="quickStandingMeta">0 kişi</small>
            </div>
            <div class="standing-list" id="quickStandingList"></div>
          </div>
        </div>
      </div>

      <div class="tab-pane" data-pane="ai">
        <div class="pane-grid">
          <div class="section-box">
            <div class="section-head">
              <h3>🧠 Operasyon Asistanı</h3>
              <small>Canlı analiz</small>
            </div>

            <div class="ai-main" id="aiMain">Veriler hazırlanıyor…</div>
            <div class="ai-sub" id="aiSub">Sistem canlı rota, durak ve rötar özetini hazırlıyor.</div>

            <div class="ai-list" style="margin-top:12px;">
              <div class="ai-item"><b>Sıradaki İşlem</b><span id="aiNextActionMirror">—</span></div>
              <div class="ai-item"><b>Canlı Durak</b><span id="aiLiveStop">—</span></div>
              <div class="ai-item"><b>Rötar Durumu</b><span id="aiDelay">—</span></div>
              <div class="ai-item"><b>Yoğunluk</b><span id="aiDensity">—</span></div>
              <div class="ai-item"><b>Servis</b><span id="aiService">—</span></div>
              <div class="ai-item"><b>Emanet</b><span id="aiParcel">—</span></div>
            </div>
          </div>
        </div>
      </div>
    </aside>
  </div>
</div>

<div class="modal-backdrop" id="seatBackdrop"></div>
<div class="modal glass" id="seatModal">
  <h3 id="seatTitle">Koltuk</h3>

  <div class="field-grid">
    <div class="field-row">
      <label class="field">
        <span>Biniş Yeri</span>
        <select id="pickup"><option value="">—</option></select>
      </label>
      <label class="field">
        <span>İniş Yeri</span>
        <select id="dropoff"><option value="">—</option></select>
      </label>
    </div>

    <div>
      <div class="muted" style="margin-bottom:8px">Bilet Türü</div>
      <div class="radio-row">
        <label><input type="radio" name="ticket" value="biletli"> Biletli</label>
        <label><input type="radio" name="ticket" value="biletsiz" checked> Biletsiz</label>
        <label><input type="radio" name="ticket" value="ucretsiz"> Ücretsiz</label>
      </div>
    </div>

    <div>
      <div class="muted" style="margin-bottom:8px">Ödeme</div>
      <div class="radio-row">
        <label><input type="radio" name="pay" value="nakit" checked> Nakit</label>
        <label><input type="radio" name="pay" value="iban"> IBAN</label>
        <label><input type="radio" name="pay" value="online"> Online</label>
        <label><input type="radio" name="pay" value="pos"> POS</label>
        <label><input type="radio" name="pay" value="ucretsiz"> Ücretsiz</label>
      </div>
    </div>

    <div class="field-row">
      <label class="field">
        <span>Tutar (₺)</span>
        <input type="number" id="price" value="0.00" step="0.01">
      </label>
      <label class="field">
        <span>Servis Notu</span>
        <input type="text" id="service_note" placeholder="Not / konum / açıklama">
      </label>
    </div>

    <div>
      <div class="muted" style="margin-bottom:8px">Cinsiyet</div>
      <div class="radio-row">
        <label><input type="radio" name="gender" value="bay"> Bay</label>
        <label><input type="radio" name="gender" value="bayan"> Bayan</label>
        <label><input type="radio" name="gender" value=""> Boş</label>
      </div>
    </div>

    <div class="check-row">
      <label><input type="checkbox" id="pairOk"> Yan yana istisna</label>
      <label><input type="checkbox" id="service"> Servis kullanacak</label>
    </div>

    <div class="action-grid">
      <button class="btn primary" type="button" id="btnBagAdd">🧳 Bagaj Ekle</button>
      <button class="btn dark" type="button" id="btnBagView">📸 Bagaj Gör</button>
    </div>
  </div>

  <div class="modal-actions">
    <button class="btn green" type="button" id="btnSeatSave">Kaydet</button>
    <button class="btn danger" type="button" id="btnSeatOffload">İniş (Boşalt)</button>
    <button class="btn ghost" type="button" id="btnSeatClose">Kapat</button>
  </div>
</div>

<div class="modal-backdrop" id="bulkBackdrop"></div>
<div class="sheet-modal glass" id="bulkModal">
  <h3>Toplu Giriş</h3>

  <div class="field-grid">
    <div class="field-row">
      <label class="field">
        <span>Nereden</span>
        <select id="bulkFrom"><option value="">—</option></select>
      </label>
      <label class="field">
        <span>Nereye</span>
        <select id="bulkTo"><option value="">—</option></select>
      </label>
    </div>

    <div class="field-row">
      <label class="field">
        <span>Adet</span>
        <input type="number" id="bulkCount" min="1" value="1">
      </label>

      <div class="field">
        <span>Bilet</span>
        <div class="radio-row" style="padding-top:8px">
          <label><input type="radio" name="bulkTicket" value="biletsiz" checked> Biletsiz</label>
          <label><input type="radio" name="bulkTicket" value="biletli"> Biletli</label>
        </div>
      </div>
    </div>

    <div class="check-row">
      <label><input type="checkbox" id="multiPick"> Çoklu seçim</label>
      <label><input type="checkbox" id="bulkService"> Servis</label>
    </div>

    <div class="muted">Çoklu seçim açıksa koltukları elle seçersin. Kapalıysa sistem boş koltuklardan yerleştirir.</div>
  </div>

  <div class="modal-actions">
    <button class="btn ghost" type="button" id="bulkClose">Kapat</button>
    <button class="btn primary" type="button" id="bulkSave">Kaydet</button>
  </div>
</div>

<div class="modal-backdrop" id="cashBackdrop"></div>
<div class="sheet-modal glass" id="cashModal">
  <h3>Hızlı Tahsilat (Ayakta)</h3>

  <div class="field-grid">
    <div class="field-row">
      <label class="field">
        <span>Adet</span>
        <input type="number" id="cashCount" min="1" value="1">
      </label>
      <label class="field">
        <span>Tutar (₺ / kişi)</span>
        <input type="number" id="cashPrice" min="0" step="0.01" value="0">
      </label>
    </div>

    <div class="field-row">
      <label class="field">
        <span>Nereden</span>
        <select id="cashFrom"><option value="">—</option></select>
      </label>
      <label class="field">
        <span>Nereye</span>
        <select id="cashTo"><option value="">—</option></select>
      </label>
    </div>

    <label class="field">
      <span>Ödeme</span>
      <select id="cashPay">
        <option value="nakit">Nakit</option>
        <option value="iban">IBAN</option>
        <option value="pos">POS</option>
        <option value="online">Online</option>
      </select>
    </label>

    <label class="field">
      <span>Not</span>
      <input type="text" id="cashNote" placeholder="Kısa not">
    </label>
  </div>

  <div class="modal-actions">
    <button class="btn ghost" type="button" id="cashClose">Kapat</button>
    <button class="btn primary" type="button" id="cashSave">Ekle</button>
  </div>
</div>

<div class="modal-backdrop" id="approachBackdrop"></div>
<div class="sheet-modal glass" id="approachModal">
  <h3 id="approachTitle">Durak Yaklaşıyor</h3>
  <div class="muted" id="approachInfo">—</div>
  <div class="approach-list" id="approachList"></div>

  <div class="modal-actions">
    <button class="btn danger" type="button" id="approachOffload">Toplu İndir</button>
    <button class="btn ghost" type="button" id="approachSnooze">Ertele (5 dk)</button>
    <button class="btn ghost" type="button" id="approachClose">Kapat</button>
  </div>
</div>

<div class="modal-backdrop" id="standingBackdrop"></div>
<div class="sheet-modal glass" id="standingModal">
  <h3>Ayakta Yolcular</h3>
  <div class="muted" id="standingSummary">—</div>
  <div class="standing-list" id="standingList" style="margin-top:12px;"></div>

  <div class="modal-actions">
    <button class="btn danger" type="button" id="standingBulkOff" style="display:none">Toplu İndir</button>
    <button class="btn ghost" type="button" id="standingClose">Kapat</button>
  </div>
</div>

<div id="toast"></div>

<script>
  window.SEATS_BOOT = {
    csrf: {{ csrf_token | tojson | safe }},
    routeName: {{ trip['route'] | tojson | safe }},
    tripDate: {{ trip['date'] | tojson | safe }},
    departureTime: {{ trip['departure_time'] | tojson | safe }},
    tripKey: {{ ((trip['route'] ~ '|' ~ trip['plate'])|replace(' ','_')) | tojson | safe }},

    seatPositions: {{ seat_positions | tojson | safe }},
    assigned: {{ assigned | tojson | safe }},
    stopsMap: {{ stops_map | tojson | safe }},
    boardsMapServer: {{ boards_map | tojson | safe }},
    genders: {{ genders | tojson | safe }},
    serviceMap: {{ service_map | tojson | safe }},
    serviceNotes: {{ service_notes | tojson | safe }},
    serverStops: {{ stops | tojson | safe }},

    urls: {
      hesap: {{ url_for('hesap_page') | tojson | safe }},
      consignments: {{ url_for('consignments_page') | tojson | safe }}
    }
  };
</script>

<script src="/static/seats/seats.js?v=1"></script>
{% endblock %}
