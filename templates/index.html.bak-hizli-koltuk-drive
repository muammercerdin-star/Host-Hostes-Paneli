<body>
  <main class="home-shell">

    {% set current_route = selected_route if selected_route is defined and selected_route else (active_trip.route if active_trip is defined and active_trip else 'Denizli – İstanbul') %}

    {% set current_route = selected_route if selected_route is defined and selected_route else (active_trip.route if active_trip is defined and active_trip else 'Denizli – İstanbul') %}

    <div class="route-form route-premium">
      <button class="route-picker-premium" id="routePickerBtn" type="button">
