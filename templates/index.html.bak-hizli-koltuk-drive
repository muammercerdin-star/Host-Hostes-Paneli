<script id="premium-route-picker-script">
(function(){
  const btn = document.getElementById("routePickerBtn");
  const text = document.getElementById("routePickerText");
  const select = document.getElementById("homeRouteSelect");
  const sheet = document.getElementById("routeSheet");
  const backdrop = document.getElementById("routeSheetBackdrop");
  const closeBtn = document.getElementById("routeSheetClose");
  const startLink = document.getElementById("homeTripStart");

  if(!btn || !select || !sheet || !backdrop) return;

  function openSheet(){
    backdrop.classList.add("show");
    sheet.classList.add("show");
    sheet.setAttribute("aria-hidden", "false");
  }

  function closeSheet(){
    sheet.classList.remove("show");
    backdrop.classList.remove("show");
    sheet.setAttribute("aria-hidden", "true");
  }

  function syncStartLink(route){
    if(!startLink) return;
    const base = startLink.dataset.base || startLink.getAttribute("href") || "/sefer-baslat";
    startLink.href = base.split("?")[0] + "?route=" + encodeURIComponent(route || "");
  }

  function setRoute(route){
    if(!route) return;

    select.value = route;
    if(text) text.textContent = route;

    document.querySelectorAll(".route-option").forEach(x => {
      x.classList.toggle("active", x.dataset.route === route);
    });

    try{
      localStorage.setItem("homeSelectedRoute", route);
    }catch(_){}

    syncStartLink(route);
  }

  btn.addEventListener("click", openSheet);
  backdrop.addEventListener("click", closeSheet);
  if(closeBtn) closeBtn.addEventListener("click", closeSheet);

  document.querySelectorAll(".route-option").forEach(opt => {
    opt.addEventListener("click", () => {
      setRoute(opt.dataset.route || "");
      closeSheet();
    });
  });

  try{
    const saved = localStorage.getItem("homeSelectedRoute");
    if(saved && Array.from(select.options).some(o => o.value === saved)){
      setRoute(saved);
    }else{
      setRoute(select.value);
    }
  }catch(_){
    setRoute(select.value);
  }
})();
</script>


