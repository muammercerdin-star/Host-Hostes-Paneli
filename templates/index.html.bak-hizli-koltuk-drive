<script id="home-route-link-fix">
(function(){
  const routeSelect = document.getElementById("homeRouteSelect");
  const startLink = document.getElementById("homeTripStart");

  function syncStartLink(){
    if(!routeSelect || !startLink) return;

    const route = routeSelect.value || "";
    const base = startLink.dataset.base || startLink.getAttribute("href") || "/sefer-baslat";

    startLink.href = base + "?route=" + encodeURIComponent(route);

    try{
      localStorage.setItem("homeSelectedRoute", route);
    }catch(_){}
  }

  if(routeSelect){
    try{
      const saved = localStorage.getItem("homeSelectedRoute");
      if(saved){
        const opt = Array.from(routeSelect.options).find(o => o.value === saved);
        if(opt) routeSelect.value = saved;
      }
    }catch(_){}

    routeSelect.addEventListener("change", syncStartLink);
    syncStartLink();
  }
})();
</script>


