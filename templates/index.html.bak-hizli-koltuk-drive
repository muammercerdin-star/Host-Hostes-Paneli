  <title>Muavin Paneli</title>

  <style>
    :root{
      --bg:#eef6ff;
      --text:#0d1b33;
      --muted:#61728a;
      --line:#e5edf6;
      --blue:#1677ff;
      --purple:#6d5dfc;
    }

    *{
      box-sizing:border-box;
    }

    body{
      margin:0;
      min-height:100vh;
      background:
        radial-gradient(circle at 20% 0%, rgba(22,119,255,.14), transparent 32%),
        linear-gradient(180deg,#f8fbff,#eaf3ff);
      font-family:system-ui,-apple-system,"Segoe UI",Roboto,Arial,sans-serif;
      color:var(--text);
    }

    .home-shell{
      width:min(94vw,720px);
      margin:18px auto 28px;
      padding:16px;
      border-radius:28px;
      background:linear-gradient(180deg,#f8fbff,#edf6ff);
      border:1px solid rgba(148,163,184,.18);
      box-shadow:0 24px 60px rgba(15,23,42,.16);
    }

    .route-card{
      height:54px;
      display:flex;
      align-items:center;
      gap:12px;
      padding:0 18px;
      margin-bottom:14px;
      border-radius:19px;
      background:#fff;
      border:1px solid rgba(148,163,184,.22);
      box-shadow:0 10px 24px rgba(15,23,42,.08);
      font-weight:900;
      font-size:17px;
      color:#0f172a;
    }

    .route-card .pin{
      color:#1677ff;
      font-size:22px;
    }

    .route-card .caret{
      margin-left:auto;
      color:#334155;
      font-size:16px;
    }

    .hero-link{
      display:block;
      width:100%;
      height:118px;
      margin-bottom:10px;
      border-radius:21px;
      overflow:hidden;
      text-decoration:none;
      box-shadow:0 16px 34px rgba(15,23,42,.16);
      background:#dbeafe;
      -webkit-tap-highlight-color:transparent;
    }

    .hero-link:active{
      transform:scale(.99);
    }

    .hero-link img{
      width:100%;
      height:100%;
      display:block;
      object-fit:cover;
    }

    .menu-list{
      margin-top:12px;
      overflow:hidden;
      border-radius:22px;
      background:#fff;
      border:1px solid rgba(226,232,240,.92);
      box-shadow:0 14px 34px rgba(15,23,42,.10);
    }

    .menu-item{
      min-height:58px;
      display:grid;
      grid-template-columns:42px 1fr 26px;
      align-items:center;
      gap:0;
      padding:8px 12px 8px 14px;
      color:#10203a;
      text-decoration:none;
      border-bottom:1px solid var(--line);
      -webkit-tap-highlight-color:transparent;
    }

    .menu-item:last-child{
      border-bottom:none;
    }

    .menu-item:active{
      background:#f1f7ff;
    }

    .ico{
      width:30px;
      height:30px;
      display:grid;
      place-items:center;
      font-size:21px;
    }

    .menu-title{
      font-size:16px;
      line-height:1.05;
      font-weight:950;
      color:#10203a;
      margin-bottom:3px;
    }

    .menu-desc{
      font-size:13px;
      line-height:1.15;
      font-weight:600;
      color:var(--muted);
    }

    .arrow{
      justify-self:end;
      font-size:30px;
      line-height:1;
      font-weight:800;
      color:#64748b;
    }

    .lock-btn{
      margin-top:14px;
      min-height:58px;
      display:flex;
      align-items:center;
      justify-content:center;
      gap:10px;
      width:100%;
      border-radius:21px;
      background:#fff;
      color:var(--purple);
      border:1px solid rgba(226,232,240,.95);
      box-shadow:0 12px 28px rgba(15,23,42,.10);
      text-decoration:none;
      font-size:17px;
      font-weight:950;
      letter-spacing:.2px;
    }

    .lock-btn:active{
      transform:scale(.99);
    }

