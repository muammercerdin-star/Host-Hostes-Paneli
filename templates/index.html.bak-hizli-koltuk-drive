.trip-guard-modal p{
  margin:0;
  color:#64748b;
  font-size:16px;
  line-height:1.35;
  font-weight:650;
}

.trip-guard-actions{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:10px;
  margin-top:18px;
}

.trip-guard-actions button,
.trip-guard-actions a{
  min-height:54px;
  border-radius:18px;
  border:0;
  display:flex;
  align-items:center;
  justify-content:center;
  text-decoration:none;
  font-size:15px;
  font-weight:950;
  font-family:system-ui,-apple-system,"Segoe UI",Roboto,Arial,sans-serif;
}

.trip-guard-go{
  background:linear-gradient(145deg,#22c55e,#0f9f6e);
  color:#fff;
  box-shadow:0 14px 30px rgba(34,197,94,.22);
}

.trip-guard-ok{
  background:#e2e8f0;
  color:#334155;
}

@media(max-width:420px){
  .trip-guard-modal{
    border-radius:26px;
    padding:20px;
  }

  .trip-guard-actions{
    grid-template-columns:1fr;
  }
}
</style>

<script id="active-trip-guard-script">
(function(){
  const HAS_ACTIVE_TRIP = {% if active_trip is defined and active_trip %}true{% else %}false{% endif %};
  const ACTIVE_TRIP_ROUTE = {% if active_trip is defined and active_trip %}{{ active_trip.route|tojson }}{% else %}""{% endif %};

  if(!HAS_ACTIVE_TRIP) return;

  const startLink =
    document.getElementById("homeTripStart") ||
    document.querySelector(".hero-link");

  const continueLink =
    Array.from(document.querySelectorAll(".hero-link"))[1] ||
    document.querySelector('a[href*="continue"]') ||
    document.querySelector('a[href*="seats"]');

  const routeBtn = document.getElementById("routePickerBtn");
  const routeText = document.getElementById("routePickerText");
  const routeSelect = document.getElementById("homeRouteSelect");

  /* Aktif sefer varsa üst rota yazısı aktif seferin rotası olsun */
  if(ACTIVE_TRIP_ROUTE){
    if(routeText) routeText.textContent = ACTIVE_TRIP_ROUTE;
    if(routeSelect){
      const opt = Array.from(routeSelect.options).find(o => o.value === ACTIVE_TRIP_ROUTE);
      if(opt) routeSelect.value = ACTIVE_TRIP_ROUTE;
    }
    try{
      localStorage.setItem("homeSelectedRoute", ACTIVE_TRIP_ROUTE);
    }catch(_){}
  }

  if(startLink){
    startLink.classList.add("active-trip-locked");
    startLink.setAttribute("aria-disabled", "true");
  }

  function ensureModal(){
    let backdrop = document.getElementById("tripGuardBackdrop");
    let modal = document.getElementById("tripGuardModal");

    if(backdrop && modal) return {backdrop, modal};

    backdrop = document.createElement("div");
    backdrop.id = "tripGuardBackdrop";
    backdrop.className = "trip-guard-backdrop";

    modal = document.createElement("section");
    modal.id = "tripGuardModal";
    modal.className = "trip-guard-modal";
    modal.innerHTML = `
      <div class="trip-guard-icon">⚠️</div>
      <h2>Aktif sefer var</h2>
      <p>Yeni sefer başlatmadan önce mevcut seferi devam ettirmen veya seferi sonlandırman gerekir.</p>
      <div class="trip-guard-actions">
        <a class="trip-guard-go" id="tripGuardGo" href="#">Devam eden sefere git</a>
        <button class="trip-guard-ok" id="tripGuardOk" type="button">Tamam</button>
      </div>
    `;

    document.body.appendChild(backdrop);
    document.body.appendChild(modal);

    const close = () => {
      backdrop.classList.remove("show");
      modal.classList.remove("show");
    };

    backdrop.addEventListener("click", close);
    modal.querySelector("#tripGuardOk").addEventListener("click", close);

    const go = modal.querySelector("#tripGuardGo");
    if(go && continueLink){
      go.href = continueLink.getAttribute("href") || "/seats";
    }

    return {backdrop, modal};
  }

  function showGuard(){
    const {backdrop, modal} = ensureModal();
    backdrop.classList.add("show");
    modal.classList.add("show");
  }

  /* Sefer başlatı engelle */
  if(startLink){
    startLink.addEventListener("click", function(e){
      e.preventDefault();
      e.stopPropagation();
      e.stopImmediatePropagation();
      showGuard();
      return false;
    }, true);
  }

  /* Aktif sefer varken rota listesini de açtırma */
  if(routeBtn){
    routeBtn.addEventListener("click", function(e){
      e.preventDefault();
      e.stopPropagation();
      e.stopImmediatePropagation();
      showGuard();
      return false;
    }, true);
  }
})();
</script>

</body>
</html>
