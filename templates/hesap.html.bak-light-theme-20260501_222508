<!doctype html>
<html lang="tr">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover">
  <title>Hesap — Sefer Kasa</title>

  <style>
    :root{
      --bg:#0b1115;
      --card:#11171c;
      --card2:#0f161b;
      --border:#22303a;
      --border2:#2a3946;
      --text:#e6edf3;
      --muted:#a8b3bd;
      --muted2:#7f8b96;
      --primary:#1f6b2d;
      --primary2:#2a8d3d;
      --danger:#7b1f1f;
      --danger2:#9a2a2a;
      --warn:#d4a100;
      --shadow:0 0 12px #0004;
      --radius:14px;
      --radius2:12px;
      --pad:14px;
      --tap:44px;
    }

    *{box-sizing:border-box}
    html,body{height:100%}
body{
  margin:0;
  font-family:system-ui,-apple-system,Roboto,Segoe UI,Arial;
  background:var(--bg);
  color:var(--text);
  -webkit-font-smoothing:antialiased;
  padding-bottom: 0 !important; /* artık buraya güvenmiyoruz */
}
    a{color:inherit;text-decoration:none}

.container{
  max-width:980px;
  margin:auto;
  padding:14px 14px calc(18px + var(--footer-h, 140px)) ; /* 👈 EN ÖNEMLİSİ */
}
    .row{display:flex;gap:10px;align-items:center;justify-content:space-between;flex-wrap:wrap}

    /* ✅ Sticky Topbar */
    .topbar{
      position:sticky; top:0; z-index:20;
      background:rgba(11,17,21,.86);
      backdrop-filter: blur(10px);
      border-bottom:1px solid var(--border);
      padding:10px 0 10px;
      margin:0 0 12px;
    }
    .topbar-inner{max-width:980px;margin:auto;padding:0 14px;display:flex;gap:10px;align-items:center;justify-content:space-between;flex-wrap:wrap}
    .topbar-left{display:flex;gap:10px;align-items:center;flex-wrap:wrap}
    .topbar-title{font-weight:900;letter-spacing:.2px}
    .meta-line{display:flex;gap:8px;flex-wrap:wrap;align-items:center}
    .pill{
      font-size:12px;color:var(--muted);
      border:1px solid var(--border);
      background:#0c141a;
      padding:6px 10px;border-radius:999px;
    }
    .kalan-pill{
      display:flex;gap:8px;align-items:center;
      border:1px solid var(--border2);
      background:linear-gradient(180deg,#0c141a,#0b1217);
      padding:10px 12px;border-radius:999px;
      box-shadow:var(--shadow);
      font-weight:900;
    }
    .kalan-pill small{color:var(--muted);font-weight:700}
    .pos{color:#29d884}
    .neg{color:#ff5454}
    .warn{color:var(--warn)}

    .card{
      background:var(--card);
      border:1px solid var(--border);
      border-radius:var(--radius);
      padding:var(--pad);
      margin:12px 0;
      box-shadow:var(--shadow);
    }
    .muted{color:var(--muted);font-size:12px}
    .muted2{color:var(--muted2);font-size:12px}
    .h{font-weight:900;letter-spacing:.2px;margin:0 0 10px;font-size:14px}

    .badge{
      display:inline-flex;gap:6px;align-items:center;
      background:#0c141a;border:1px solid #2b3a46;color:#c8d1d9;
      padding:6px 10px;border-radius:999px;font-size:12px;
      margin:6px 6px 0 0;
    }

    /* Özet kutuları */
    .kasa{
      display:grid;
      grid-template-columns:repeat(4,1fr);
      gap:10px;
      margin-bottom:10px;
    }
    .box{
      background:var(--card2);
      border:1px solid var(--border);
      border-radius:var(--radius2);
      padding:10px 10px 8px;
      min-height:74px;
      display:flex;flex-direction:column;justify-content:space-between;
    }
    .box .label{font-size:12px;color:var(--muted)}
    .box .num{font-size:18px;font-weight:900;letter-spacing:.3px}

    .alertbar{
      display:flex;align-items:center;justify-content:space-between;gap:10px;
      padding:10px 12px;border-radius:12px;margin-top:10px;
      border:1px solid #3a2b2b;
      background:linear-gradient(180deg,#1a1111,#120c0c);
    }
    .alertbar strong{color:#ff6b6b}
    .alertbar .mini{font-size:12px;color:#f0baba}

    label{font-size:12px;color:var(--muted);display:block;margin:10px 0 6px}
    input,select,textarea,button{
      width:100%;
      padding:12px 12px;
      border-radius:12px;
      border:1px solid var(--border2);
      background:#0b1217;
      color:var(--text);
      outline:none;
      min-height:var(--tap);
    }
    textarea{resize:vertical}
    input:focus,select:focus,textarea:focus{border-color:#3a5466;box-shadow:0 0 0 3px #0ea5e91c}

    .grid2{display:grid;grid-template-columns:1fr 1fr;gap:10px}
    @media (max-width: 900px){
      .kasa{grid-template-columns:repeat(2,1fr)}
      .grid2{grid-template-columns:1fr}
    }

    .btnrow{display:flex;gap:8px;flex-wrap:wrap}
    .btn{
      display:inline-flex;align-items:center;justify-content:center;
      min-height:var(--tap);
      padding:10px 12px;border-radius:12px;
      border:1px solid var(--border2);
      background:#0b1217;
      cursor:pointer;
      user-select:none;
      transition:.15s;
      font-weight:800;
      font-size:14px;
    }
    .btn:hover{transform:translateY(-1px)}
    .btn.primary{background:var(--primary);border-color:#2a7b3a}
    .btn.primary:hover{background:var(--primary2)}
    .btn.danger{background:var(--danger);border-color:#8a2a2a}
    .btn.danger:hover{background:var(--danger2)}
    .btn.ghost{background:transparent}
    .btn.small{font-size:12px;padding:8px 10px;min-height:38px;border-radius:10px;font-weight:800}

    .quick{display:flex;gap:8px;flex-wrap:wrap;margin-top:10px}
    .chip{
      border:1px solid #2f4353;background:#0c141a;color:#cfe3f2;
      padding:8px 10px;border-radius:999px;font-size:12px;
      cursor:pointer;user-select:none;
      transition:.15s;
      font-weight:800;
    }
    .chip:hover{transform:translateY(-1px);border-color:#3b5870}
    .chip.warn{border-color:#5c4a1a;color:#ffe39a}

    /* ✅ Tek panel / tablar */
    .tabs{display:flex;gap:8px;flex-wrap:wrap;margin:0 0 10px}
    .tab{
      border:1px solid var(--border2);
      background:#0c141a;
      color:#cfe3f2;
      padding:10px 12px;border-radius:999px;
      font-weight:900;font-size:13px;
      cursor:pointer;user-select:none;
      transition:.15s;
    }
    .tab.active{
      background:linear-gradient(180deg,#1f6b2d,#174f22);
      border-color:#2a7b3a;
    }
    .tab small{color:#d8e7dd;font-weight:700}
    .tabpanels > .panel{display:none}
    .tabpanels > .panel.active{display:block}

    /* Toolbar / arama */
    .toolbar{
      display:flex;gap:8px;flex-wrap:wrap;align-items:center;justify-content:space-between;
      margin:14px 0 6px;
    }
    .toolbar .left{display:flex;gap:8px;align-items:center;flex-wrap:wrap}
    .toolbar .right{display:flex;gap:8px;align-items:center;flex-wrap:wrap}
    .searchwrap{
      display:flex;gap:8px;align-items:center;flex-wrap:wrap;
      width:min(540px,100%);
    }
    .searchwrap input{min-height:40px;padding:10px 12px;border-radius:12px}

    /* ✅ Hareketler: masaüstünde tablo, mobilde kart */
    .table{width:100%;border-collapse:collapse}
    th,td{border-bottom:1px solid var(--border);padding:10px 8px;text-align:left;font-size:13px;vertical-align:top}
    th{color:var(--muted);font-weight:800}
    tr.in td{color:#44d38f}
    tr.out td{color:#ff7070}
    td.amount{white-space:nowrap;font-weight:900}
    td.note{color:var(--text)}
    .right{display:flex;gap:8px;align-items:center;justify-content:flex-end}

    .moves-cards{display:none}
    .move-card{
      background:var(--card2);
      border:1px solid var(--border);
      border-radius:14px;
      padding:12px;
      display:flex;gap:10px;align-items:flex-start;justify-content:space-between;
      margin:10px 0;
    }
    .move-left{min-width:0}
    .move-top{display:flex;gap:8px;align-items:center;flex-wrap:wrap}
    .move-dir{font-weight:900}
    .move-cat{font-weight:900}
    .move-note{color:var(--text);opacity:.92;margin-top:4px;font-size:13px;word-break:break-word}
    .move-time{color:var(--muted2);font-size:12px;margin-top:6px}
    .move-amt{font-weight:1000;white-space:nowrap}

    @media (max-width: 720px){
      .moves-table{display:none}
      .moves-cards{display:block}
    }

    /* fixed footer */
    .footerbar{
      position:fixed;
      left:0;right:0;bottom:0;
      background:rgba(11,17,21,.92);
      backdrop-filter: blur(10px);
      border-top:1px solid var(--border);
      padding:10px max(10px, env(safe-area-inset-left)) calc(10px + env(safe-area-inset-bottom)) max(10px, env(safe-area-inset-right));
    }
    .footergrid{
      max-width:980px;margin:auto;
      display:grid;grid-template-columns:repeat(4,1fr);gap:8px;
    }
    .footergrid .btn{font-size:14px;padding:12px;border-radius:14px}

    .fadeIn{animation:fadein .35s ease}
    @keyframes fadein{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:none}}
  </style>
</head>

<body>
  <!-- ✅ Sticky Topbar -->
  <div class="topbar">
    <div class="topbar-inner">
      <div class="topbar-left">
        <a href="/" class="btn small ghost">🏠 Ana Sayfa</a>
        <div>
          <div class="topbar-title">🧾 Hesap / Aktif Sefer</div>
          <div class="meta-line">
            {% if trip.route %}<span class="pill">🚌 {{ trip.route }}</span>{% endif %}
            {% if trip.date %}<span class="pill">📅 {{ trip.date }}</span>{% endif %}
            {% if trip.departure_time %}<span class="pill">⏱️ {{ trip.departure_time }}</span>{% endif %}
          </div>
        </div>
      </div>

      <div class="kalan-pill">
        <small>KALAN</small>
        <span class="{{ 'pos' if sums.kalan >= 0 else 'neg' }}">{{ sums.kalan|tl }}</span>
      </div>
    </div>
  </div>

  <div class="container fadeIn">

    <!-- ✅ Sunucudan gelen verileri JS’e güvenli şekilde aktar -->
    <script>
      const MOVES = {{ moves|tojson|safe }};
      const SUMS  = {{ sums|tojson|safe }};
      const TRIP  = {{ trip|tojson|safe }};
    </script>

    <!-- ÖZET -->
    <div class="card">
      <div class="kasa">
        <div class="box">
          <div class="label">Başlangıç (Devir)</div>
          <div class="num">{{ sums.devir|tl }}</div>
        </div>
        <div class="box">
          <div class="label">Toplam Giriş</div>
          <div class="num pos">{{ sums.giris|tl }}</div>
        </div>
        <div class="box">
          <div class="label">Toplam Çıkış</div>
          <div class="num neg">{{ sums.cikis|tl }}</div>
        </div>
        <div class="box">
          <div class="label">Kalan</div>
          <div class="num {{ 'pos' if sums.kalan >= 0 else 'neg' }}">{{ sums.kalan|tl }}</div>
        </div>
      </div>

      {% if sums.kalan < 0 %}
      <div class="alertbar">
        <div>
          <div><strong>⚠️ KASA EKSİ!</strong> <span class="mini">Giriş/çıkışları kontrol et.</span></div>
          <div class="muted2">Kalan: {{ sums.kalan|tl }}</div>
        </div>
        <button class="btn small ghost" type="button"
          onclick="window.scrollTo({top: document.body.scrollHeight, behavior:'smooth'})">Aşağı in</button>
      </div>
      {% endif %}
    </div>

    <!-- ✅ HIZLI İŞLEM (Tab’li tek panel) -->
    <div class="card">
      <div class="row" style="margin-bottom:10px">
        <div class="h" style="margin:0">⚡ Hızlı İşlem</div>
        <span class="muted2">Devir / Giriş / Çıkış</span>
      </div>

      <div class="tabs" role="tablist" aria-label="Hızlı işlem sekmeleri">
        <button class="tab active" type="button" data-tab="panel-in">➕ Giriş <small>(hasılat)</small></button>
        <button class="tab" type="button" data-tab="panel-out">➖ Çıkış <small>(masraf)</small></button>
        <button class="tab" type="button" data-tab="panel-devir">⬆️ Devir <small>(başlangıç)</small></button>
      </div>

      <div class="tabpanels">
        <!-- GİRİŞ -->
        <div class="panel active" id="panel-in">
          <form method="post" action="{{ url_for('hesap_giris') }}">
            <input type="hidden" name="csrf_token" value="{{ csrf_token }}">

            <label>Kategori</label>
            <select name="category" id="cat_in">
              {% for k in categories_in %}<option value="{{k}}">{{k}}</option>{% endfor %}
            </select>

            <label>Tutar (TL)</label>
            <input id="in_amount" type="number" name="amount" min="0" step="1" inputmode="numeric" placeholder="0" required>

            <div class="quick">
              <span class="chip" onclick="addAmount('in_amount', 10)">+10</span>
              <span class="chip" onclick="addAmount('in_amount', 20)">+20</span>
              <span class="chip" onclick="addAmount('in_amount', 50)">+50</span>
              <span class="chip" onclick="addAmount('in_amount', 100)">+100</span>
              <span class="chip" onclick="addAmount('in_amount', 200)">+200</span>
              <span class="chip warn" onclick="fillAmount('in_amount')">Tutar yaz</span>
            </div>

            <label>Açıklama</label>
            <input type="text" name="note" placeholder="örn. Harem hesabı">

            <div class="btnrow" style="margin-top:10px">
              <button class="btn primary" type="submit">✅ Kaydet</button>
              <button class="btn ghost" type="reset">Temizle</button>
            </div>
          </form>
        </div>

        <!-- ÇIKIŞ -->
        <div class="panel" id="panel-out">
          <form method="post" action="{{ url_for('hesap_cikis') }}">
            <input type="hidden" name="csrf_token" value="{{ csrf_token }}">

            <label>Kategori</label>
            <select name="category" id="cat_out">
              {% for k in categories_out %}<option value="{{k}}">{{k}}</option>{% endfor %}
            </select>

            <label>Tutar (TL)</label>
            <input id="out_amount" type="number" name="amount" min="0" step="1" inputmode="numeric" placeholder="0" required>

            <div class="quick">
              <span class="chip" onclick="addAmount('out_amount', 10)">+10</span>
              <span class="chip" onclick="addAmount('out_amount', 20)">+20</span>
              <span class="chip" onclick="addAmount('out_amount', 50)">+50</span>
              <span class="chip" onclick="addAmount('out_amount', 100)">+100</span>
              <span class="chip" onclick="addAmount('out_amount', 200)">+200</span>
              <span class="chip warn" onclick="fillAmount('out_amount')">Tutar yaz</span>
            </div>

            <label>Açıklama</label>
            <input type="text" name="note" placeholder="örn. Yıkama">

            <div class="btnrow" style="margin-top:10px">
              <button class="btn primary" type="submit">✅ Kaydet</button>
              <button class="btn ghost" type="reset">Temizle</button>
            </div>
          </form>
        </div>

        <!-- DEVİR -->
        <div class="panel" id="panel-devir">
          <form method="post" action="{{ url_for('hesap_devir') }}">
            <input type="hidden" name="csrf_token" value="{{ csrf_token }}">

            <label>Tutar (TL)</label>
            <input id="devir_amount" type="number" name="amount" min="0" step="1" inputmode="numeric" placeholder="0" required>

            <div class="quick" aria-label="Hızlı tutar seçenekleri">
              <span class="chip" onclick="addAmount('devir_amount', 10)">+10</span>
              <span class="chip" onclick="addAmount('devir_amount', 20)">+20</span>
              <span class="chip" onclick="addAmount('devir_amount', 50)">+50</span>
              <span class="chip" onclick="addAmount('devir_amount', 100)">+100</span>
              <span class="chip" onclick="addAmount('devir_amount', 200)">+200</span>
              <span class="chip warn" onclick="fillAmount('devir_amount')">Tutar yaz</span>
            </div>

            <label>Not (opsiyonel)</label>
            <input type="text" name="note" placeholder="Garaj avansı">

            <div class="btnrow" style="margin-top:10px">
              <button class="btn primary" type="submit">✅ Kaydet</button>
              <button class="btn ghost" type="reset">Temizle</button>
            </div>
          </form>
        </div>
      </div>
    </div>

    <!-- KATEGORİLER -->
    <form class="card" method="post" action="{{ url_for('hesap_kategoriler_kaydet') }}">
      <div class="row">
        <div class="h">⚙️ Kategoriler</div>
        <span class="muted2">Virgülle ayır • hızlı düzenle</span>
      </div>

      <input type="hidden" name="csrf_token" value="{{ csrf_token }}">

      <div class="grid2">
        <div>
          <label>Giriş Kategorileri</label>
          <textarea name="cats_in" rows="5" placeholder="örn: Bilet, Emanet, İkram...">{{ categories_in|join(', ') }}</textarea>
        </div>
        <div>
          <label>Çıkış Kategorileri</label>
          <textarea name="cats_out" rows="5" placeholder="örn: Mazot, Yıkama, Otoyol...">{{ categories_out|join(', ') }}</textarea>
        </div>
      </div>

      <div class="btnrow" style="margin-top:10px">
        <button class="btn primary" type="submit">Kaydet</button>
        <button class="btn ghost" type="reset">Vazgeç</button>
      </div>
    </form>

    <!-- SON HAREKETLER TOOLBAR -->
    <div class="toolbar">
      <div class="left">
        <div class="h" style="margin:0">📋 Son Hareketler</div>
        <span class="muted2">Gösterilen: <span id="moveCount">0</span> kayıt</span>
      </div>

      <div class="right">
        <div class="searchwrap">
          <input id="q" type="text" placeholder="Ara: kategori / açıklama / + / -">
          <button class="btn small" type="button" onclick="clearSearch()">Temizle</button>
        </div>

        <button class="btn small primary" type="button" onclick="shareWhatsapp()">WhatsApp</button>
        <a class="btn small" href="{{ url_for('hesap_moves_csv') }}">CSV</a>
        <button class="btn small" type="button" onclick="window.print()">Yazdır/PDF</button>
      </div>
    </div>

    <!-- SON HAREKETLER: Tablo -->
    <div class="card moves-table">
      <table class="table" id="movesTable">
        <thead>
          <tr>
            <th>Zaman</th><th>Yön</th><th>Kategori</th><th>Açıklama</th><th class="right">Tutar</th>
          </tr>
        </thead>
        <tbody id="movesBody">
          {% for m in moves %}
            <tr class="{{ 'in' if m.direction == '+' else 'out' }}">
              <td>{{ m.created_at }}</td>
              <td>{{ '+' if m.direction == '+' else '-' }}</td>
              <td>{{ m.category }}</td>
              <td class="note">{{ m.note }}</td>
              <td class="amount right">{{ m.amount|tl }}</td>
            </tr>
          {% else %}
            <tr><td colspan="5" class="muted">Henüz hareket yok.</td></tr>
          {% endfor %}
        </tbody>
      </table>
    </div>

    <!-- SON HAREKETLER: Mobil kart -->
    <div class="card moves-cards" id="movesCards">
      {% for m in moves %}
        <div class="move-card {{ 'in' if m.direction == '+' else 'out' }}">
          <div class="move-left">
            <div class="move-top">
              <span class="move-dir">{{ '+' if m.direction == '+' else '-' }}</span>
              <span class="move-cat">{{ m.category }}</span>
            </div>
            {% if m.note %}
              <div class="move-note">{{ m.note }}</div>
            {% endif %}
            <div class="move-time">{{ m.created_at }}</div>
          </div>
          <div class="move-amt">{{ m.amount|tl }}</div>
        </div>
      {% else %}
        <div class="muted">Henüz hareket yok.</div>
      {% endfor %}
    </div>

  </div><!-- /container -->

  <!-- FOOTER -->
  <div class="footerbar">
    <div class="footergrid">
      <a class="btn" href="{{ url_for('seats_page') }}">🎫 Biletler</a>
      <a class="btn" href="{{ url_for('consignments_page') }}">📦 Emanet</a>
      <a class="btn primary" href="{{ url_for('hesap_page') }}">🧾 Hesap</a>
      <form method="post" action="{{ url_for('end_trip') }}" style="margin:0">
        <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
        <button class="btn danger" type="submit">⛔ Seferi Bitir</button>
      </form>
    </div>
  </div>

  <script>
    // --- Helpers ---
    function tl(n){
      const v = Number(n || 0);
      return new Intl.NumberFormat('tr-TR', {style:'currency', currency:'TRY'}).format(v);
    }
    function getEl(id){ return document.getElementById(id); }
    function currentVal(id){
      const el = getEl(id);
      if(!el) return 0;
      const v = parseFloat(String(el.value||'').replace(',','.'));
      return isNaN(v) ? 0 : v;
    }
    function setVal(id, v){
      const el = getEl(id);
      if(el) el.value = String(Math.max(0, Math.round(v))).replace('.', ',');
      el?.focus();
    }

    // --- Quick amounts ---
    function addAmount(id, add){
      const v = currentVal(id);
      setVal(id, v + add);
    }
    function fillAmount(id){
      const el = getEl(id);
      if(!el) return;
      el.focus();
    }

    // ✅ Tabs
    const tabs = Array.from(document.querySelectorAll(".tab"));
    const panels = Array.from(document.querySelectorAll(".tabpanels .panel"));
    function setTab(panelId){
      tabs.forEach(t => t.classList.toggle("active", t.dataset.tab === panelId));
      panels.forEach(p => p.classList.toggle("active", p.id === panelId));
    }
    tabs.forEach(t => t.addEventListener("click", () => setTab(t.dataset.tab)));

    // ✅ Son seçilen kategori hatırlatma
    const catIn  = getEl("cat_in");
    const catOut = getEl("cat_out");
    if(catIn){ catIn.value = localStorage.getItem("cat_in")  || catIn.value; }
    if(catOut){catOut.value= localStorage.getItem("cat_out") || catOut.value;}
    catIn?.addEventListener("change", e => localStorage.setItem("cat_in", e.target.value));
    catOut?.addEventListener("change", e => localStorage.setItem("cat_out", e.target.value));

    // --- Table search filter (tablo + kart sayımı) ---
    const q = getEl('q');
    const movesBody = getEl('movesBody');
    const cardsWrap = getEl('movesCards');

    function normalize(s){ return String(s||'').toLowerCase().trim(); }

    function applySearch(){
      const term = normalize(q.value);

      // tablo satırları
      const rows = Array.from(movesBody?.querySelectorAll('tr') || []);
      let shown = 0;
      rows.forEach(r=>{
        const ok = !term || normalize(r.innerText).includes(term);
        r.style.display = ok ? '' : 'none';
        if(ok) shown++;
      });

      // kartlar
      const cards = Array.from(cardsWrap?.querySelectorAll('.move-card') || []);
      cards.forEach(c=>{
        const ok = !term || normalize(c.innerText).includes(term);
        c.style.display = ok ? '' : 'none';
      });

      getEl('moveCount').textContent = shown || cards.filter(c => c.style.display !== 'none').length || 0;
    }

    function clearSearch(){
      q.value = '';
      applySearch();
      q.focus();
    }
    q?.addEventListener('input', applySearch);

    // init count
    getEl('moveCount').textContent = Array.isArray(MOVES) ? MOVES.length : (movesBody?.querySelectorAll('tr').length || 0);
    applySearch();

    // --- WhatsApp share ---
    function shareWhatsapp(){
      if(!Array.isArray(MOVES) || MOVES.length === 0){
        alert("Paylaşılacak hareket yok.");
        return;
      }
      const lines = [];
      lines.push("🧾 SEFER KASA – Son Hareketler");
      const route = TRIP?.route || "";
      const date  = TRIP?.date || "";
      const dep   = TRIP?.departure_time || "";
      lines.push(`Hat: ${route}  Tarih: ${date}  Kalkış: ${dep}`);
      lines.push("--------------------------------------------------");

      MOVES.slice().reverse().forEach(m=>{
        const dir = (m.direction === '+' || m.direction === 'in') ? '+' : '-';
        const created = m.created_at || m.created || "";
        const cat = m.category || "";
        const note = m.note || "";
        lines.push(`${created}  ${dir}  ${cat}  ${note}  ${tl(m.amount)}`);
      });

      lines.push("--------------------------------------------------");
      lines.push(`Devir:  ${tl(SUMS?.devir)}`);
      lines.push(`Giriş:  ${tl(SUMS?.giris)}`);
      lines.push(`Çıkış:  ${tl(SUMS?.cikis)}`);
      lines.push(`Kalan:  ${tl(SUMS?.kalan)}`);

      const text = encodeURIComponent(lines.join("\n"));
      window.open("https://wa.me/?text=" + text, "_blank");
    }

function fixFooterGap(){
  const fb = document.querySelector('.footerbar');
  if(!fb) return;

  const h = fb.getBoundingClientRect().height || fb.offsetHeight || 0;

  // CSS değişkenine yaz → container padding bunu kullanacak
  document.documentElement.style.setProperty('--footer-h', (h + 16) + 'px');

  // Debug: çalışıyor mu görmek için (1 kere gör, sonra silebilirsin)
  // console.log("footer height:", h);
}

window.addEventListener("load", fixFooterGap, {once:true});
window.addEventListener("resize", fixFooterGap);
window.addEventListener("orientationchange", fixFooterGap);
setTimeout(fixFooterGap, 300);   // adres çubuğu otursun diye
setTimeout(fixFooterGap, 1200);  // bazı cihazlar geç ölçüyor
  </script>
