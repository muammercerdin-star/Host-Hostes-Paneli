{% extends "base.html" %}
{% block content %}
<link rel="stylesheet" href="/static/style.css"/>

<style>
*{
  box-sizing:border-box;
  -webkit-tap-highlight-color:transparent;
}

body{
  background:
    radial-gradient(circle at 18% 0%, rgba(37,99,235,.20), transparent 34%),
    radial-gradient(circle at 96% 28%, rgba(20,184,166,.14), transparent 35%),
    linear-gradient(180deg,#061524,#0b1726 45%,#08111d) !important;
  color:#eaf2ff;
  font-family:system-ui,-apple-system,"Segoe UI",Roboto,Arial,sans-serif;
}

.pax-shell{
  width:min(94vw,760px);
  margin:18px auto 34px;
  padding:18px;
  border-radius:34px;
  background:linear-gradient(180deg,rgba(15,31,49,.96),rgba(8,20,34,.96));
  border:1px solid rgba(148,163,184,.18);
  box-shadow:0 28px 80px rgba(0,0,0,.42);
}

/* HERO */
.pax-hero{
  border-radius:30px;
  padding:20px;
  background:
    radial-gradient(circle at 95% 10%, rgba(255,255,255,.12), transparent 24%),
    linear-gradient(145deg,#12355d,#0d1f35);
  border:1px solid rgba(148,163,184,.18);
  box-shadow:0 18px 42px rgba(0,0,0,.28);
  margin-bottom:14px;
}

.pax-hero-top{
  display:grid;
  grid-template-columns:64px 1fr;
  gap:14px;
  align-items:center;
}

.pax-icon{
  width:64px;
  height:64px;
  border-radius:23px;
  display:grid;
  place-items:center;
  background:linear-gradient(145deg,#1e3a5f,#10243b);
  border:1px solid rgba(148,163,184,.20);
  font-size:34px;
}

.pax-title h1{
  margin:0;
  color:#f8fbff;
  font-size:38px;
  line-height:1;
  font-weight:950;
  letter-spacing:-1px;
}

.pax-title p{
  margin:8px 0 0;
  color:#aab8ca;
  font-size:14px;
  line-height:1.35;
  font-weight:800;
}

.trip-meta{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:10px;
  margin-top:16px;
}

.meta-chip{
  min-height:48px;
  border-radius:18px;
  padding:10px 12px;
  background:rgba(10,22,36,.72);
  border:1px solid rgba(148,163,184,.16);
  color:#dbeafe;
  font-size:14px;
  font-weight:850;
  line-height:1.25;
}

.meta-chip b{
  color:#f8fbff;
}

/* CONTROL CARD */
.control-card{
  border-radius:30px;
  padding:16px;
  background:linear-gradient(180deg,#132338,#0d1a2b);
  border:1px solid rgba(148,163,184,.18);
  box-shadow:0 18px 42px rgba(0,0,0,.28);
  margin-bottom:14px;
}

.control-head{
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:10px;
  margin-bottom:13px;
}

.control-head h2{
  margin:0;
  color:#f8fbff;
  font-size:25px;
  line-height:1;
  font-weight:950;
}

.status-pill{
  min-height:38px;
  padding:0 12px;
  border-radius:999px;
  display:inline-flex;
  align-items:center;
  justify-content:center;
  background:rgba(37,99,235,.16);
  border:1px solid rgba(96,165,250,.30);
  color:#93c5fd;
  font-size:13px;
  font-weight:950;
  white-space:nowrap;
}

.control-buttons{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:10px;
}

.btn{
  min-height:58px;
  border:0;
  border-radius:21px;
  padding:0 12px;
  display:flex;
  align-items:center;
  justify-content:center;
  text-align:center;
  color:#fff;
  font-family:inherit;
  font-size:16px;
  line-height:1;
  font-weight:950;
  cursor:pointer;
  box-shadow:0 14px 28px rgba(0,0,0,.24);
}

.btn.primary{ background:linear-gradient(145deg,#38bdf8,#2563eb); }
.btn.green{ background:linear-gradient(145deg,#22c55e,#16a34a); }
.btn.gray{ background:linear-gradient(180deg,#64748b,#334155); }
.btn.red{ background:linear-gradient(145deg,#fb7185,#ef4444); }

.btn:disabled{
  opacity:.45;
  filter:grayscale(.35);
  cursor:not-allowed;
}

.chips{
  display:grid;
  grid-template-columns:repeat(3,1fr);
  gap:9px;
  margin-top:12px;
}

.chip{
  min-height:56px;
  border-radius:20px;
  display:flex;
  flex-direction:column;
  align-items:center;
  justify-content:center;
  background:#0a1624;
  border:1px solid rgba(148,163,184,.18);
  color:#94a3b8;
  font-size:12px;
  font-weight:900;
  cursor:pointer;
}

.chip b{
  margin-top:4px;
  color:#f8fbff;
  font-size:24px;
  line-height:1;
  font-weight:950;
  font-variant-numeric:tabular-nums;
}

/* STATS */
.stats{
  display:grid;
  grid-template-columns:repeat(4,1fr);
  gap:10px;
  margin-bottom:14px;
}

.stat{
  min-height:92px;
  border-radius:24px;
  padding:14px;
  background:linear-gradient(180deg,#132338,#0d1a2b);
  border:1px solid rgba(148,163,184,.18);
  box-shadow:0 14px 30px rgba(0,0,0,.24);
}

.stat .k{
  color:#94a3b8;
  font-size:13px;
  line-height:1.15;
  font-weight:900;
}

.stat .v{
  margin-top:9px;
  color:#f8fbff;
  font-size:31px;
  line-height:1;
  font-weight:950;
}

/* INFO */
.legend-box{
  margin-bottom:14px;
  padding:14px;
  border-radius:24px;
  background:rgba(37,99,235,.12);
  border:1px solid rgba(96,165,250,.22);
  color:#bfdbfe;
  font-size:14px;
  line-height:1.45;
  font-weight:850;
}

.legend-line{
  display:flex;
  align-items:center;
  gap:9px;
  margin:5px 0;
}

.legend-dot{
  width:13px;
  height:13px;
  border-radius:999px;
  flex:0 0 auto;
}

.legend-dot.wait{ background:#f59e0b; box-shadow:0 0 16px rgba(245,158,11,.55); }
.legend-dot.ok{ background:#22c55e; box-shadow:0 0 16px rgba(34,197,94,.50); }
.legend-dot.bad{ background:#ef4444; box-shadow:0 0 16px rgba(239,68,68,.50); }

/* DECK */
.deck-card{
  border-radius:30px;
  padding:16px;
  background:linear-gradient(180deg,#132338,#0d1a2b);
  border:1px solid rgba(148,163,184,.18);
  box-shadow:0 18px 42px rgba(0,0,0,.28);
}

.deck-head{
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:10px;
  margin-bottom:14px;
}

.deck-head h2{
  margin:0;
  color:#f8fbff;
  font-size:28px;
  line-height:1;
  font-weight:950;
}

.deck-badge{
  min-height:38px;
  padding:0 12px;
  border-radius:999px;
  display:inline-flex;
  align-items:center;
  justify-content:center;
  background:rgba(34,197,94,.14);
  border:1px solid rgba(34,197,94,.28);
  color:#86efac;
  font-size:13px;
  font-weight:950;
  white-space:nowrap;
}

.deck-wrap{
  width:100%;
  overflow-x:auto;
  padding:8px 0 4px;
}

.deck{
  position:relative;
  display:grid;
  grid-template-columns:64px 64px 64px 64px;
  grid-auto-rows:72px;
  gap:18px;
  justify-content:center;
  min-width:310px;
  margin:0 auto;
}

.cell{
  display:flex;
  flex-direction:column;
  align-items:center;
  justify-content:flex-start;
}

.seat{
  position:relative;
  width:60px;
  height:60px;
  border-radius:20px;
  background:#1f6b2d;
  display:flex;
  align-items:center;
  justify-content:center;
  color:#fff;
  font-size:22px;
  font-weight:950;
  box-shadow:0 12px 24px rgba(0,0,0,.32);
  border:1px solid rgba(255,255,255,.08);
  user-select:none;
}

.seat.isAssigned{
  filter:saturate(1.05);
}

.label{
  width:78px;
  margin-top:5px;
  color:#facc15;
  font-size:10px;
  line-height:1.1;
  min-height:22px;
  text-align:center;
  overflow:hidden;
  display:-webkit-box;
  -webkit-line-clamp:2;
  -webkit-box-orient:vertical;
}

.corr{
  grid-column:2;
  grid-row:1/15;
  width:56px;
  border-radius:22px;
  background:linear-gradient(180deg,#7f1d1d,#991b1b);
  display:flex;
  align-items:center;
  justify-content:center;
  color:#fecaca;
  font-size:13px;
  font-weight:950;
  writing-mode:vertical-rl;
  letter-spacing:4px;
  box-shadow:inset 0 0 0 1px rgba(255,255,255,.08), 0 14px 28px rgba(0,0,0,.25);
}

.door{
  grid-column:3/5;
  grid-row:8;
  height:32px;
  align-self:center;
  border-radius:16px;
  background:linear-gradient(145deg,#f59e0b,#b45309);
  color:#fff7ed;
  display:flex;
  align-items:center;
  justify-content:center;
  font-size:13px;
  font-weight:950;
  box-shadow:0 10px 20px rgba(0,0,0,.25);
}

.svc-badge{
  position:absolute;
  right:-7px;
  top:-7px;
  min-width:24px;
  height:24px;
  border-radius:999px;
  display:none;
  align-items:center;
  justify-content:center;
  background:#0ea5e9;
  color:#fff;
  font-size:12px;
  box-shadow:0 8px 18px rgba(14,165,233,.35);
}

.seat.has-service .svc-badge{
  display:flex;
}

/* CONTROL COLORS */
@keyframes lampBlink{
  0%,100%{
    background:#f59e0b;
    box-shadow:0 0 0 0 rgba(245,158,11,.25), 0 12px 24px rgba(0,0,0,.32);
    color:#1f2937;
  }
  50%{
    background:#fde047;
    box-shadow:0 0 20px 8px rgba(234,179,8,.45), 0 12px 24px rgba(0,0,0,.32);
    color:#1f2937;
  }
}

.seat.blink{
  animation:lampBlink 1s ease-in-out infinite;
  background:#f59e0b !important;
  color:#1f2937 !important;
}

.seat.present{
  animation:none;
  background:#16a34a !important;
  box-shadow:0 0 0 3px rgba(134,239,172,.35) inset, 0 0 22px rgba(34,197,94,.28), 0 12px 24px rgba(0,0,0,.32);
}

.seat.missing{
  animation:none;
  background:#dc2626 !important;
  box-shadow:0 0 0 3px rgba(254,202,202,.28) inset, 0 0 22px rgba(239,68,68,.28), 0 12px 24px rgba(0,0,0,.32);
}

/* MODAL */
#leftBackdrop{
  display:none;
  position:fixed;
  inset:0;
  background:rgba(2,6,23,.72);
  backdrop-filter:blur(12px);
  z-index:3000;
}

#leftModal{
  display:none;
  position:fixed;
  z-index:3010;
  left:50%;
  top:50%;
  transform:translate(-50%,-50%);
  width:min(94vw,560px);
  max-height:74vh;
  overflow:auto;
  background:linear-gradient(180deg,#132338,#0d1a2b);
  color:#eaf2ff;
  border:1px solid rgba(148,163,184,.18);
  border-radius:30px;
  box-shadow:0 30px 90px rgba(0,0,0,.45);
  padding:18px;
}

.modal-head{
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:10px;
  margin-bottom:10px;
}

#leftModal h3{
  margin:0;
  color:#f8fbff;
  font-size:26px;
  font-weight:950;
}

#leftInfo{
  color:#aab8ca;
  font-size:15px;
  font-weight:850;
  margin-bottom:10px;
}

#leftList .left-row{
  display:grid;
  grid-template-columns:64px 1fr;
  gap:10px;
  align-items:center;
  padding:10px 0;
  border-bottom:1px dashed rgba(255,255,255,.08);
}

#leftList .left-row:last-child{
  border-bottom:none;
}

.left-no{
  min-width:58px;
  height:42px;
  border-radius:16px;
  background:#f59e0b;
  color:#1f2937;
  font-size:18px;
  font-weight:950;
  display:flex;
  align-items:center;
  justify-content:center;
}

.left-route{
  color:#f8fbff;
  font-size:15px;
  font-weight:850;
  line-height:1.3;
  text-align:left;
}

.close-btn{
  min-height:52px;
  border:0;
  border-radius:20px;
  padding:0 18px;
  background:linear-gradient(180deg,#64748b,#334155);
  color:#fff;
  font-family:inherit;
  font-size:16px;
  font-weight:950;
  cursor:pointer;
}

@media(max-width:430px){
  .pax-shell{
    width:calc(100vw - 24px);
    padding:16px;
    border-radius:30px;
  }

  .pax-hero{
    padding:16px;
    border-radius:28px;
  }

  .pax-hero-top{
    grid-template-columns:58px 1fr;
  }

  .pax-icon{
    width:58px;
    height:58px;
    border-radius:21px;
    font-size:30px;
  }

  .pax-title h1{
    font-size:32px;
  }

  .trip-meta{
    grid-template-columns:1fr;
  }

  .control-buttons{
    grid-template-columns:1fr 1fr;
    gap:9px;
  }

  .btn{
    min-height:56px;
    font-size:15px;
    border-radius:20px;
  }

  .chips{
    gap:8px;
  }

  .chip{
    min-height:54px;
    font-size:11px;
  }

  .chip b{
    font-size:22px;
  }

  .stats{
    grid-template-columns:1fr 1fr;
    gap:10px;
  }

  .stat{
    min-height:86px;
  }

  .deck{
    grid-template-columns:58px 58px 58px 58px;
    grid-auto-rows:70px;
    gap:16px;
    min-width:280px;
  }

  .seat{
    width:56px;
    height:56px;
    border-radius:18px;
    font-size:20px;
  }

  .corr{
    width:50px;
  }

  .label{
    width:72px;
    font-size:9px;
  }
}
</style>

<!-- Kalan yolcu modalı -->
<div id="leftBackdrop"></div>

<div id="leftModal" role="dialog" aria-modal="true" aria-labelledby="leftTitle">
  <div class="modal-head">
    <h3 id="leftTitle">Kalan Yolcular</h3>
    <button class="close-btn" id="leftClose">Kapat</button>
  </div>
  <div id="leftInfo">—</div>
  <div id="leftList"></div>
</div>

{% set seats_map = {
  1:[1,1],3:[1,3],4:[1,4], 5:[2,1],7:[2,3],8:[2,4],
  9:[3,1],11:[3,3],12:[3,4], 13:[4,1],15:[4,3],16:[4,4],
  17:[5,1],19:[5,3],20:[5,4], 21:[6,1],23:[6,3],24:[6,4],
  25:[7,1],27:[7,3],28:[7,4], 29:[8,1],
  31:[9,1],33:[9,3],34:[9,4],
  35:[10,1],37:[10,3],38:[10,4],
  39:[11,1],41:[11,3],42:[11,4],
  43:[12,1],45:[12,3],46:[12,4],
  49:[13,3],50:[13,4],
  51:[14,1],52:[14,2],53:[14,3],54:[14,4]
} %}

<main class="pax-shell">

  <section class="pax-hero">
    <div class="pax-hero-top">
      <div class="pax-icon">👥</div>
      <div class="pax-title">
        <h1>Yolcu Kontrolü</h1>
        <p>Sefer içi yoklama, kalan yolcu ve koltuk durum takibi.</p>
      </div>
    </div>

    <div class="trip-meta">
      <div class="meta-chip">🚌 Sefer: <b>{{ trip['route'] }}</b></div>
      <div class="meta-chip">🔢 Plaka: <b>{{ trip['plate'] }}</b></div>
      <div class="meta-chip">👨‍✈️ 1. Kaptan: <b>{{ trip['captain1'] or '-' }}</b></div>
      <div class="meta-chip">👨‍✈️ 2. Kaptan: <b>{{ trip['captain2'] or '-' }}</b></div>
      <div class="meta-chip">🧑‍💼 Muavin: <b>{{ trip['attendant'] or '-' }}</b></div>
      <div class="meta-chip">📅 Tarih: <b>{{ trip['date'] or '-' }}</b></div>
    </div>
  </section>

  <section class="control-card">
    <div class="control-head">
      <h2>Kontrol Paneli</h2>
      <span class="status-pill" id="controlStatus">Hazır</span>
    </div>

    <div class="control-buttons">
      <button id="btnStart" class="btn primary">Kontrolü Başlat</button>
      <button id="btnStop"  class="btn gray" disabled>Bitir</button>
      <button id="btnReset" class="btn red"  disabled>Sıfırla</button>
      <button id="btnLeft"  class="btn green" disabled>Kalanları Vurgula</button>
      <button onclick="window.location.href='{{ url_for('index') }}'" class="btn gray">Ana Sayfa</button>
      <button onclick="window.location.href='{{ url_for('seats_page') }}'" class="btn primary">Koltuklar</button>
    </div>

    <div class="chips">
      <span class="chip">Toplam <b id="chipTotal">0</b></span>
      <span class="chip">Yoklanan <b id="chipDone">0</b></span>
      <span class="chip">Kalan <b id="chipLeft">0</b></span>
    </div>
  </section>

  <section class="stats">
    <div class="stat"><div class="k">Toplam Yolcu</div><div class="v" id="st_totalPax">0</div></div>
    <div class="stat"><div class="k">Boş Koltuk</div><div class="v" id="st_empty">0</div></div>
    <div class="stat"><div class="k">Doluluk</div><div class="v" id="st_occupancy">0%</div></div>
    <div class="stat"><div class="k">Ayakta</div><div class="v" id="st_standing">0</div></div>
  </section>

  <section class="legend-box">
    <div class="legend-line"><span class="legend-dot wait"></span> Sarı yanıp sönüyor: kontrol bekliyor</div>
    <div class="legend-line"><span class="legend-dot ok"></span> Yeşil: yolcu yerinde</div>
    <div class="legend-line"><span class="legend-dot bad"></span> Kırmızı: eksik yolcu</div>
  </section>

  <section class="deck-card">
    <div class="deck-head">
      <h2>Koltuk Planı</h2>
      <span class="deck-badge">Canlı kontrol</span>
    </div>

    <div class="deck-wrap">
      <div class="deck" id="deck">
        <div class="corr">KORİDOR</div>

        {% for n, pos in seats_map.items() %}
          {% if n == 29 %}
            <div class="door">KAPI</div>
          {% endif %}

          <div class="cell" style="grid-row:{{ pos[0] }};grid-column:{{ pos[1] }};">
            <div class="seat" id="seat-{{ n }}" data-seat="{{ n }}">
              {{ n }}
              <span class="svc-badge">🚌</span>
            </div>
            <div class="label" id="label-{{ n }}"></div>
          </div>
        {% endfor %}
      </div>
    </div>
  </section>

</main>

<script>
function paintSeatBase(el, gender, assigned){
  if(!el) return;

  if(gender === 'bay'){
    el.style.background = '#2563eb';
  }else if(gender === 'bayan'){
    el.style.background = '#e75480';
  }else{
    el.style.background = assigned ? '#475569' : '#1f6b2d';
  }

  el.classList.toggle('isAssigned', !!assigned);
}

function setSvc(el, has){
  if(!el) return;
  el.classList.toggle('has-service', !!has);
}

const TRIP_ID = "{{ (trip['route'] ~ '|' ~ trip['plate'])|replace(' ', '_') }}";
const LSKEY   = 'paxcheck:' + TRIP_ID;

const seatMeta = new Map();
let controlActive = false;
let assignedSet   = new Set();
let presentSet    = new Set();

function saveState(){
  try{
    localStorage.setItem(LSKEY, JSON.stringify({
      active: controlActive,
      present: [...presentSet]
    }));
  }catch(_){}
}

function loadState(){
  try{
    const obj = JSON.parse(localStorage.getItem(LSKEY) || 'null');
    if(obj){
      controlActive = !!obj.active;
      presentSet = new Set(obj.present || []);
    }
  }catch(_){}
}

function setStatusText(){
  const el = document.getElementById('controlStatus');
  if(!el) return;

  if(controlActive){
    el.textContent = 'Kontrol aktif';
  }else if(presentSet.size > 0){
    el.textContent = 'Kontrol durdu';
  }else{
    el.textContent = 'Hazır';
  }
}

function refreshChips(){
  const total = assignedSet.size;
  const done  = presentSet.size;
  const left  = Math.max(0, total - done);

  document.getElementById('chipTotal').textContent = total;
  document.getElementById('chipDone').textContent  = done;
  document.getElementById('chipLeft').textContent  = left;

  setStatusText();
}

function startControl(){
  controlActive = true;

  assignedSet.forEach(n=>{
    const el = document.getElementById('seat-' + n);
    if(!el) return;

    el.classList.remove('missing','present');

    if(presentSet.has(n)){
      el.classList.add('present');
      el.classList.remove('blink');
    }else{
      el.classList.add('blink');
    }
  });

  document.getElementById('btnStart').disabled = true;
  document.getElementById('btnStop').disabled  = false;
  document.getElementById('btnReset').disabled = false;
  document.getElementById('btnLeft').disabled  = false;

  saveState();
  refreshChips();
}

function stopControl(){
  if(!controlActive) return;

  controlActive = false;

  assignedSet.forEach(n=>{
    const el = document.getElementById('seat-' + n);
    if(!el) return;

    el.classList.remove('blink');

    if(!presentSet.has(n)){
      el.classList.add('missing');
    }
  });

  document.getElementById('btnStart').disabled = false;
  document.getElementById('btnStop').disabled  = true;

  saveState();
  refreshChips();
}

function resetControl(){
  presentSet.clear();

  assignedSet.forEach(n=>{
    const el = document.getElementById('seat-' + n);
    if(!el) return;
    el.classList.remove('present','missing','blink');
  });

  controlActive = false;

  document.getElementById('btnStart').disabled = false;
  document.getElementById('btnStop').disabled  = true;
  document.getElementById('btnReset').disabled = true;
  document.getElementById('btnLeft').disabled  = true;

  saveState();
  refreshChips();
}

function highlightLeft(){
  if(!controlActive) return;

  assignedSet.forEach(n=>{
    const el = document.getElementById('seat-' + n);
    if(!el) return;

    if(!presentSet.has(n)){
      el.classList.add('blink');
      el.classList.remove('present','missing');
    }
  });
}

document.getElementById('btnStart').addEventListener('click', startControl);
document.getElementById('btnStop').addEventListener('click',  stopControl);
document.getElementById('btnReset').addEventListener('click', resetControl);
document.getElementById('btnLeft').addEventListener('click',  highlightLeft);

document.getElementById('deck').addEventListener('click', (e)=>{
  const el = e.target.closest('.seat');
  if(!el) return;

  const n = Number(el.dataset.seat);

  if(!assignedSet.has(n)) return;
  if(!controlActive) return;

  if(presentSet.has(n)){
    presentSet.delete(n);
    el.classList.remove('present');
    el.classList.add('blink');
  }else{
    presentSet.add(n);
    el.classList.remove('blink','missing');
    el.classList.add('present');
  }

  saveState();
  refreshChips();
});

async function loadSeats(){
  const r = await fetch('/api/seats/list');
  const j = await r.json();

  if(!j.ok) return;

  assignedSet.clear();
  seatMeta.clear();

  let filled = 0;

  j.items.forEach(row=>{
    const n = Number(row.seat_no);
    const el = document.getElementById('seat-' + n);
    const lb = document.getElementById('label-' + n);

    const assigned = !!row.stop;

    if(assigned){
      assignedSet.add(n);
      filled++;
    }

    paintSeatBase(el, row.gender || '', assigned);
    setSvc(el, !!row.service);

    const from = row.from || row.board || row.pickup || '';
    const to   = row.stop || '';

    if(lb){
      lb.textContent = assigned ? ((from ? from + ' → ' : '') + to) : '';
    }

    seatMeta.set(n, { from, to });
  });

  const total = {{ seats_map|length }};
  document.getElementById('st_totalPax').textContent = filled;
  document.getElementById('st_empty').textContent = total - filled;
  document.getElementById('st_occupancy').textContent = total ? Math.round(filled / total * 100) + '%' : '0%';
  document.getElementById('st_standing').textContent = '0';

  refreshChips();
  loadState();

  if(controlActive){
    document.getElementById('btnStart').disabled = true;
    document.getElementById('btnStop').disabled  = false;
    document.getElementById('btnReset').disabled = false;
    document.getElementById('btnLeft').disabled  = false;

    assignedSet.forEach(n=>{
      const el = document.getElementById('seat-' + n);
      if(!el) return;

      el.classList.remove('missing','present','blink');

      if(presentSet.has(n)){
        el.classList.add('present');
      }else{
        el.classList.add('blink');
      }
    });
  }else{
    document.getElementById('btnStart').disabled = false;
    document.getElementById('btnStop').disabled  = true;
    document.getElementById('btnReset').disabled = assignedSet.size > 0 ? false : true;
    document.getElementById('btnLeft').disabled  = true;

    assignedSet.forEach(n=>{
      const el = document.getElementById('seat-' + n);
      if(!el) return;
      el.classList.remove('blink','present','missing');
    });
  }

  refreshChips();
}

function getRemainingSeats(){
  const arr = [];

  assignedSet.forEach(n=>{
    if(!presentSet.has(n)){
      arr.push(n);
    }
  });

  return arr.sort((a,b)=>a-b);
}

function openLeftModal(){
  const left = getRemainingSeats();
  const backdrop = document.getElementById('leftBackdrop');
  const modal    = document.getElementById('leftModal');
  const info     = document.getElementById('leftInfo');
  const list     = document.getElementById('leftList');

  info.textContent = left.length ? `${left.length} yolcu kaldı:` : 'Kalan yolcu yok.';
  list.innerHTML = '';

  left.forEach(n=>{
    const meta = seatMeta.get(n) || {from:'', to:''};
    const row = document.createElement('div');
    row.className = 'left-row';

    row.innerHTML = `
      <div class="left-no">${n}</div>
      <div class="left-route">${(meta.from ? meta.from + ' → ' : '') + (meta.to || '—')}</div>
    `;

    list.appendChild(row);
  });

  backdrop.style.display = 'block';
  modal.style.display = 'block';
}

function closeLeftModal(){
  document.getElementById('leftBackdrop').style.display = 'none';
  document.getElementById('leftModal').style.display    = 'none';
}

document.getElementById('leftClose')?.addEventListener('click', closeLeftModal);
document.getElementById('leftBackdrop')?.addEventListener('click', closeLeftModal);
document.getElementById('chipLeft')?.parentElement.addEventListener('click', openLeftModal);

loadSeats();
</script>
{% endblock %}
