  body.drive-quick-active #driveQuickDock{
    grid-template-columns:repeat(5, 34px) !important;
    gap:6px !important;
    padding:6px !important;
    border-radius:20px !important;
    margin-top:8px !important;
  }

  #driveQuickDock .dq-btn{
    width:34px !important;
    height:34px !important;
    min-width:34px !important;
    min-height:34px !important;
    border-radius:13px !important;
    font-size:20px !important;
  }
}
</style>

<script id="drive-quick-solid-final-js">
(function(){
  function isDriveMode(){
    const btn = document.getElementById("driveModeToggle");
    const txt = (btn ? btn.textContent : "").toLowerCase();

    if(txt.includes("normal")) return true;

    const bodyCls = document.body.className.toLowerCase();
    const htmlCls = document.documentElement.className.toLowerCase();

    return (
      bodyCls.includes("drive") ||
      bodyCls.includes("surus") ||
      htmlCls.includes("drive") ||
      htmlCls.includes("surus")
    );
  }

  function syncDriveDock(){
    document.body.classList.toggle("drive-quick-active", isDriveMode());
  }

  function clickFirst(selectors){
    for(const sel of selectors){
      const el = document.querySelector(sel);
      if(el){
        el.click();
        return true;
      }
    }
    return false;
  }

  function bindButtons(){
    const ai = document.getElementById("dqAiBtn");
    const end = document.getElementById("dqEndBtn");

    if(ai && !ai.dataset.bound){
      ai.dataset.bound = "1";
      ai.addEventListener("click", function(){
        clickFirst([
          "#btnDeckAI",
          "[data-tab='ai']",
          "#aiBtn",
          "#btnAI"
        ]);
      });
    }

    if(end && !end.dataset.bound){
      end.dataset.bound = "1";
      end.addEventListener("click", function(){
        if(!confirm("Seferi bitirme ekranına geçilsin mi?")) return;

        const clicked = clickFirst([
          "#endTripBtn",
          "#btnEndTrip",
          "[data-action='end-trip']",
          "a[href*='end_trip']",
          "a[href*='sefer-bitir']"
        ]);

        if(!clicked){
          window.location.href = "/end_trip";
        }
      });
    }
  }

  function boot(){
    bindButtons();
    syncDriveDock();

    const btn = document.getElementById("driveModeToggle");

    if(btn){
      btn.addEventListener("click", function(){
        setTimeout(syncDriveDock, 50);
        setTimeout(syncDriveDock, 250);
        setTimeout(syncDriveDock, 600);
      });

      new MutationObserver(syncDriveDock).observe(btn, {
        childList:true,
        subtree:true,
        characterData:true,
        attributes:true
      });
    }

    new MutationObserver(syncDriveDock).observe(document.body, {
      attributes:true,
      attributeFilter:["class"]
    });

    let n = 0;
    const t = setInterval(function(){
      bindButtons();
      syncDriveDock();
      n++;
      if(n > 20) clearInterval(t);
    }, 250);
  }

  if(document.readyState === "loading"){
    document.addEventListener("DOMContentLoaded", boot);
  }else{
    boot();
  }
})();
</script>

{% endblock %}
