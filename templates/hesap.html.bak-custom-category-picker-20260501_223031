<!doctype html>
<html lang="tr">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover">
  <title>Hesap — Sefer Kasa</title>

  <style>
    :root{
      --bg:#eef4fb;
      --bg2:#f8fbff;
      --card:#ffffffdd;
      --card2:#f7fbff;
      --border:#dce7f2;
      --border2:#cbd8e6;
      --text:#0f172a;
      --muted:#64748b;
      --muted2:#94a3b8;

      --primary:#16a34a;
      --primary2:#0f8f3e;
      --danger:#ef4444;
      --danger2:#dc2626;
      --blue:#2563eb;
      --warn:#d4a100;

      --shadow:0 18px 42px rgba(15,23,42,.13);
      --shadow2:0 8px 24px rgba(15,23,42,.10);
      --radius:28px;
      --radius2:22px;
      --pad:18px;
      --tap:46px;
    }

    *{box-sizing:border-box}
    html,body{height:100%}

    body{
      margin:0;
      font-family:system-ui,-apple-system,Roboto,Segoe UI,Arial;
      background:
        radial-gradient(circle at top left, #dbeafe 0, transparent 36%),
        radial-gradient(circle at top right, #dcfce7 0, transparent 32%),
        linear-gradient(180deg,#f8fbff 0%,#eef4fb 45%,#eaf1f8 100%);
      color:var(--text);
      -webkit-font-smoothing:antialiased;
      padding-bottom:0 !important;
    }

    a{color:inherit;text-decoration:none}

    .container{
      max-width:980px;
      margin:auto;
      padding:16px 14px calc(18px + var(--footer-h, 150px));
    }

    .row{
      display:flex;
      gap:10px;
      align-items:center;
      justify-content:space-between;
      flex-wrap:wrap;
    }

    /* ÜST BAR */
    .topbar{
      position:sticky;
      top:0;
      z-index:20;
      background:rgba(248,251,255,.78);
      backdrop-filter:blur(16px);
      border-bottom:1px solid rgba(203,216,230,.75);
      padding:12px 0;
      margin:0 0 14px;
      box-shadow:0 8px 26px rgba(15,23,42,.06);
    }

    .topbar-inner{
      max-width:980px;
      margin:auto;
      padding:0 14px;
      display:flex;
      gap:12px;
      align-items:center;
      justify-content:space-between;
      flex-wrap:wrap;
    }

    .topbar-left{
      display:flex;
      gap:12px;
      align-items:center;
      flex-wrap:wrap;
    }

    .topbar-title{
      font-weight:1000;
      letter-spacing:.2px;
      font-size:18px;
      color:#0f172a;
    }

    .meta-line{
      display:flex;
      gap:7px;
      flex-wrap:wrap;
      align-items:center;
      margin-top:5px;
    }

    .pill{
      font-size:12px;
      color:#475569;
      border:1px solid #dbe5ef;
      background:#ffffffcc;
      padding:7px 10px;
      border-radius:999px;
      box-shadow:0 5px 14px rgba(15,23,42,.05);
      font-weight:800;
    }

    .kalan-pill{
      display:flex;
      gap:8px;
      align-items:center;
      border:1px solid #d7e3ee;
      background:linear-gradient(180deg,#ffffff,#f4f8fc);
      padding:12px 15px;
      border-radius:999px;
      box-shadow:var(--shadow2);
      font-weight:1000;
      color:#0f172a;
    }

    .kalan-pill small{
      color:#64748b;
      font-weight:900;
      font-size:11px;
      letter-spacing:.4px;
    }

    .pos{color:#0ea35a}
    .neg{color:#ef4444}
    .warn{color:var(--warn)}

    /* KARTLAR */
    .card{
      background:var(--card);
      border:1px solid rgba(220,231,242,.92);
      border-radius:var(--radius);
      padding:var(--pad);
      margin:14px 0;
      box-shadow:var(--shadow);
      backdrop-filter:blur(14px);
    }

    .muted{color:var(--muted);font-size:12px}
    .muted2{color:var(--muted2);font-size:12px}

    .h{
      font-weight:1000;
      letter-spacing:.2px;
      margin:0 0 10px;
      font-size:16px;
      color:#0f172a;
    }

    .badge{
      display:inline-flex;
      gap:6px;
      align-items:center;
      background:#ffffff;
      border:1px solid #dbe5ef;
      color:#475569;
      padding:7px 10px;
      border-radius:999px;
      font-size:12px;
      margin:6px 6px 0 0;
      box-shadow:0 5px 14px rgba(15,23,42,.05);
    }

    /* ÖZET */
    .kasa{
      display:grid;
      grid-template-columns:repeat(4,1fr);
      gap:12px;
      margin-bottom:4px;
    }

    .box{
      background:linear-gradient(180deg,#ffffff,#f7fbff);
      border:1px solid #dce7f2;
      border-radius:24px;
      padding:14px 14px 12px;
      min-height:88px;
      display:flex;
      flex-direction:column;
      justify-content:space-between;
      box-shadow:0 10px 24px rgba(15,23,42,.08);
    }

    .box .label{
      font-size:12px;
      color:#64748b;
      font-weight:850;
    }

    .box .num{
      font-size:20px;
      font-weight:1000;
      letter-spacing:.2px;
      color:#0f172a;
    }

    .alertbar{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:10px;
      padding:13px 14px;
      border-radius:20px;
      margin-top:12px;
      border:1px solid #fecaca;
      background:linear-gradient(180deg,#fff5f5,#ffecec);
      box-shadow:0 8px 22px rgba(239,68,68,.12);
    }

    .alertbar strong{color:#dc2626}
    .alertbar .mini{font-size:12px;color:#991b1b}

    label{
      font-size:12px;
      color:#64748b;
      display:block;
      margin:12px 0 7px;
      font-weight:900;
    }

    input,select,textarea,button{
      width:100%;
      padding:13px 13px;
      border-radius:18px;
      border:1px solid #d5e1ec;
      background:#ffffff;
      color:#0f172a;
      outline:none;
      min-height:var(--tap);
      font:inherit;
    }

    textarea{resize:vertical}

    input:focus,
    select:focus,
    textarea:focus{
      border-color:#93c5fd;
      box-shadow:0 0 0 4px rgba(37,99,235,.12);
    }

    .grid2{
      display:grid;
      grid-template-columns:1fr 1fr;
      gap:12px;
    }

    @media (max-width:900px){
      .kasa{grid-template-columns:repeat(2,1fr)}
      .grid2{grid-template-columns:1fr}
    }

    /* BUTONLAR */
    .btnrow{
      display:flex;
      gap:9px;
      flex-wrap:wrap;
    }

    .btn{
      width:auto;
      display:inline-flex;
      align-items:center;
      justify-content:center;
      min-height:var(--tap);
      padding:11px 14px;
      border-radius:18px;
      border:1px solid #d5e1ec;
      background:#ffffff;
      color:#0f172a;
      cursor:pointer;
      user-select:none;
      transition:.15s;
      font-weight:950;
      font-size:14px;
      box-shadow:0 6px 16px rgba(15,23,42,.07);
    }

    .btn:hover{transform:translateY(-1px)}

    .btn.primary{
      background:linear-gradient(180deg,#22c55e,#16a34a);
      border-color:#16a34a;
      color:#fff;
    }

    .btn.primary:hover{background:linear-gradient(180deg,#16a34a,#0f8f3e)}

    .btn.danger{
      background:linear-gradient(180deg,#ff5a5a,#ef4444);
      border-color:#ef4444;
      color:#fff;
    }

    .btn.danger:hover{background:linear-gradient(180deg,#ef4444,#dc2626)}

    .btn.ghost{
      background:#ffffffaa;
      color:#334155;
    }

    .btn.small{
      font-size:12px;
      padding:9px 11px;
      min-height:40px;
      border-radius:15px;
      font-weight:950;
    }

    /* HIZLI TUTAR */
    .quick{
      display:flex;
      gap:8px;
      flex-wrap:wrap;
      margin-top:10px;
    }

    .chip{
      border:1px solid #d5e1ec;
      background:#ffffff;
      color:#2563eb;
      padding:9px 12px;
      border-radius:999px;
      font-size:12px;
      cursor:pointer;
      user-select:none;
      transition:.15s;
      font-weight:1000;
      box-shadow:0 5px 14px rgba(15,23,42,.06);
    }

    .chip:hover{
      transform:translateY(-1px);
      border-color:#bfdbfe;
      background:#eff6ff;
    }

    .chip.warn{
      border-color:#fde68a;
      background:#fffbeb;
      color:#b45309;
    }

    /* TABLAR */
    .tabs{
      display:flex;
      gap:9px;
      flex-wrap:wrap;
      margin:0 0 12px;
      background:#eef5fb;
      border:1px solid #dce7f2;
      padding:7px;
      border-radius:999px;
    }

    .tab{
      width:auto;
      flex:1 1 auto;
      border:0;
      background:transparent;
      color:#475569;
      padding:11px 13px;
      border-radius:999px;
      font-weight:1000;
      font-size:13px;
      cursor:pointer;
      user-select:none;
      transition:.15s;
      box-shadow:none;
    }

    .tab.active{
      background:linear-gradient(180deg,#ffffff,#f7fbff);
      color:#0f172a;
      box-shadow:0 8px 18px rgba(15,23,42,.10);
      border:1px solid #dce7f2;
    }

    .tab small{
      color:#64748b;
      font-weight:850;
    }

    .tabpanels > .panel{display:none}
    .tabpanels > .panel.active{display:block}

    /* TOOLBAR */
    .toolbar{
      display:flex;
      gap:10px;
      flex-wrap:wrap;
      align-items:center;
      justify-content:space-between;
      margin:16px 0 8px;
    }

    .toolbar .left{
      display:flex;
      gap:8px;
      align-items:center;
      flex-wrap:wrap;
    }

    .toolbar .right{
      display:flex;
      gap:8px;
      align-items:center;
      flex-wrap:wrap;
    }

    .searchwrap{
      display:flex;
      gap:8px;
      align-items:center;
      flex-wrap:wrap;
      width:min(540px,100%);
    }

    .searchwrap input{
      min-height:42px;
      padding:11px 13px;
      border-radius:17px;
    }

    /* TABLO */
    .table{
      width:100%;
      border-collapse:separate;
      border-spacing:0;
    }

    th,td{
      border-bottom:1px solid #e2eaf3;
      padding:11px 8px;
      text-align:left;
      font-size:13px;
      vertical-align:top;
    }

    th{
      color:#64748b;
      font-weight:1000;
    }

    tr.in td{color:#0ea35a}
    tr.out td{color:#ef4444}

    td.amount{
      white-space:nowrap;
      font-weight:1000;
    }

    td.note{color:#0f172a}

    .right{
      display:flex;
      gap:8px;
      align-items:center;
      justify-content:flex-end;
    }

    /* MOBİL KART HAREKETLER */
    .moves-cards{display:none}

    .move-card{
      background:linear-gradient(180deg,#ffffff,#f8fbff);
      border:1px solid #dce7f2;
      border-radius:24px;
      padding:14px;
      display:flex;
      gap:10px;
      align-items:flex-start;
      justify-content:space-between;
      margin:10px 0;
      box-shadow:0 8px 22px rgba(15,23,42,.07);
      position:relative;
      overflow:hidden;
    }

    .move-card::before{
      content:"";
      position:absolute;
      left:0;
      top:12px;
      bottom:12px;
      width:5px;
      border-radius:999px;
      background:#94a3b8;
    }

    .move-card.in::before{background:#16a34a}
    .move-card.out::before{background:#ef4444}

    .move-card.in .move-amt,
    .move-card.in .move-dir{color:#16a34a}

    .move-card.out .move-amt,
    .move-card.out .move-dir{color:#ef4444}

    .move-left{min-width:0;padding-left:6px}

    .move-top{
      display:flex;
      gap:8px;
      align-items:center;
      flex-wrap:wrap;
    }

    .move-dir{
      font-weight:1000;
      font-size:18px;
    }

    .move-cat{
      font-weight:1000;
      color:#0f172a;
    }

    .move-note{
      color:#334155;
      opacity:.96;
      margin-top:5px;
      font-size:13px;
      word-break:break-word;
      font-weight:700;
    }

    .move-time{
      color:#94a3b8;
      font-size:12px;
      margin-top:7px;
      font-weight:750;
    }

    .move-amt{
      font-weight:1000;
      white-space:nowrap;
      color:#0f172a;
    }

    @media (max-width:720px){
      .moves-table{display:none}
      .moves-cards{display:block}

      .topbar-inner{
        align-items:flex-start;
      }

      .kalan-pill{
        width:100%;
        justify-content:space-between;
      }

      .tabs{
        border-radius:24px;
      }

      .tab{
        flex:1 1 100%;
      }

      .toolbar .right,
      .searchwrap{
        width:100%;
      }

      .searchwrap input{
        flex:1 1 100%;
      }

      .searchwrap .btn,
      .toolbar .right > .btn,
      .toolbar .right > a{
        flex:1 1 calc(50% - 8px);
      }
    }

    /* FOOTER */
    .footerbar{
      position:fixed;
      left:0;
      right:0;
      bottom:0;
      background:rgba(248,251,255,.88);
      backdrop-filter:blur(18px);
      border-top:1px solid rgba(203,216,230,.9);
      padding:10px max(10px, env(safe-area-inset-left)) calc(10px + env(safe-area-inset-bottom)) max(10px, env(safe-area-inset-right));
      box-shadow:0 -12px 34px rgba(15,23,42,.10);
      z-index:30;
    }

    .footergrid{
      max-width:980px;
      margin:auto;
      display:grid;
      grid-template-columns:repeat(4,1fr);
      gap:8px;
    }

    .footergrid .btn{
      width:100%;
      font-size:13px;
      padding:12px 8px;
      border-radius:18px;
      min-height:50px;
    }

    .footergrid form{
      margin:0;
    }

    .footergrid form .btn{
      width:100%;
    }

    @media (max-width:520px){
      .footergrid{
        grid-template-columns:repeat(2,1fr);
      }
    }

    .fadeIn{animation:fadein .35s ease}

    @keyframes fadein{
      from{opacity:0;transform:translateY(6px)}
      to{opacity:1;transform:none}
    }
  
/* =========================================================
   KASA KUTULARINI BELİRGİNLEŞTİRME
   Açık tema kalsın ama kartlar daha net ayrılsın
========================================================= */

.card{
  background:
    linear-gradient(180deg, rgba(255,255,255,.94), rgba(243,248,254,.92));
  border:1px solid #cbd9e8;
  box-shadow:
    0 18px 38px rgba(15,23,42,.16),
    inset 0 1px 0 rgba(255,255,255,.9);
}

.kasa{
  gap:14px;
}

.box{
  position:relative;
  overflow:hidden;
  border:1px solid #c5d5e6;
  background:
    linear-gradient(180deg,#ffffff 0%,#eef5fc 100%);
  box-shadow:
    0 12px 26px rgba(15,23,42,.13),
    inset 0 1px 0 rgba(255,255,255,.95);
}

.box::before{
  content:"";
  position:absolute;
  left:0;
  top:0;
  width:100%;
  height:5px;
  background:#94a3b8;
}

.box:nth-child(1)::before{
  background:#2563eb;
}

.box:nth-child(2)::before{
  background:#16a34a;
}

.box:nth-child(3)::before{
  background:#ef4444;
}

.box:nth-child(4)::before{
  background:#0ea35a;
}

.box:nth-child(1){
  background:linear-gradient(180deg,#ffffff 0%,#eff6ff 100%);
}

.box:nth-child(2){
  background:linear-gradient(180deg,#ffffff 0%,#ecfdf5 100%);
}

.box:nth-child(3){
  background:linear-gradient(180deg,#ffffff 0%,#fff1f2 100%);
}

.box:nth-child(4){
  background:linear-gradient(180deg,#ffffff 0%,#ecfdf5 100%);
}

.box .label{
  color:#64748b;
  font-size:13px;
  font-weight:950;
}

.box .num{
  color:#0f172a;
  text-shadow:0 1px 0 rgba(255,255,255,.7);
}

.box:nth-child(2) .num{
  color:#0f9f55;
}

.box:nth-child(3) .num{
  color:#ef4444;
}

.box:nth-child(4) .num{
  color:#0ea35a;
}

.kalan-pill{
  background:
    linear-gradient(180deg,#ffffff 0%,#ecfdf5 100%);
  border:1px solid #b7e4ca;
  box-shadow:
    0 12px 26px rgba(14,163,90,.14),
    inset 0 1px 0 rgba(255,255,255,.95);
}

.kalan-pill span{
  font-size:20px;
}

.tabs{
  background:#dfeaf5;
  border-color:#c7d8e8;
}

.tab.active{
  background:linear-gradient(180deg,#ffffff,#edf5fd);
  border:1px solid #cbd9e8;
}

.move-card{
  border-color:#cbd9e8;
  box-shadow:
    0 10px 24px rgba(15,23,42,.12),
    inset 0 1px 0 rgba(255,255,255,.9);
}

  </style>
</head>

<body>
  <!-- ✅ Sticky Topbar -->
  <div class="topbar">
    <div class="topbar-inner">
      <div class="topbar-left">
        <a href="/" class="btn small ghost">🏠 Ana Sayfa</a>
        <div>
          <div class="topbar-title">🧾 Hesap / Aktif Sefer</div>
          <div class="meta-line">
            {% if trip.route %}<span class="pill">🚌 {{ trip.route }}</span>{% endif %}
            {% if trip.date %}<span class="pill">📅 {{ trip.date }}</span>{% endif %}
            {% if trip.departure_time %}<span class="pill">⏱️ {{ trip.departure_time }}</span>{% endif %}
          </div>
        </div>
      </div>

      <div class="kalan-pill">
        <small>KALAN</small>
        <span class="{{ 'pos' if sums.kalan >= 0 else 'neg' }}">{{ sums.kalan|tl }}</span>
      </div>
    </div>
  </div>

  <div class="container fadeIn">

    <!-- ✅ Sunucudan gelen verileri JS’e güvenli şekilde aktar -->
    <script>
      const MOVES = {{ moves|tojson|safe }};
      const SUMS  = {{ sums|tojson|safe }};
      const TRIP  = {{ trip|tojson|safe }};
    </script>

    <!-- ÖZET -->
    <div class="card">
      <div class="kasa">
        <div class="box">
          <div class="label">Başlangıç (Devir)</div>
          <div class="num">{{ sums.devir|tl }}</div>
        </div>
        <div class="box">
          <div class="label">Toplam Giriş</div>
          <div class="num pos">{{ sums.giris|tl }}</div>
        </div>
        <div class="box">
          <div class="label">Toplam Çıkış</div>
          <div class="num neg">{{ sums.cikis|tl }}</div>
        </div>
        <div class="box">
          <div class="label">Kalan</div>
          <div class="num {{ 'pos' if sums.kalan >= 0 else 'neg' }}">{{ sums.kalan|tl }}</div>
        </div>
      </div>

      {% if sums.kalan < 0 %}
      <div class="alertbar">
        <div>
          <div><strong>⚠️ KASA EKSİ!</strong> <span class="mini">Giriş/çıkışları kontrol et.</span></div>
          <div class="muted2">Kalan: {{ sums.kalan|tl }}</div>
        </div>
        <button class="btn small ghost" type="button"
          onclick="window.scrollTo({top: document.body.scrollHeight, behavior:'smooth'})">Aşağı in</button>
      </div>
      {% endif %}
    </div>

    <!-- ✅ HIZLI İŞLEM (Tab’li tek panel) -->
    <div class="card">
      <div class="row" style="margin-bottom:10px">
        <div class="h" style="margin:0">⚡ Hızlı İşlem</div>
        <span class="muted2">Devir / Giriş / Çıkış</span>
      </div>

      <div class="tabs" role="tablist" aria-label="Hızlı işlem sekmeleri">
        <button class="tab active" type="button" data-tab="panel-in">➕ Giriş <small>(hasılat)</small></button>
        <button class="tab" type="button" data-tab="panel-out">➖ Çıkış <small>(masraf)</small></button>
        <button class="tab" type="button" data-tab="panel-devir">⬆️ Devir <small>(başlangıç)</small></button>
      </div>

      <div class="tabpanels">
        <!-- GİRİŞ -->
        <div class="panel active" id="panel-in">
          <form method="post" action="{{ url_for('hesap_giris') }}">
            <input type="hidden" name="csrf_token" value="{{ csrf_token }}">

            <label>Kategori</label>
            <select name="category" id="cat_in">
              {% for k in categories_in %}<option value="{{k}}">{{k}}</option>{% endfor %}
            </select>

            <label>Tutar (TL)</label>
            <input id="in_amount" type="number" name="amount" min="0" step="1" inputmode="numeric" placeholder="0" required>

            <div class="quick">
              <span class="chip" onclick="addAmount('in_amount', 10)">+10</span>
              <span class="chip" onclick="addAmount('in_amount', 20)">+20</span>
              <span class="chip" onclick="addAmount('in_amount', 50)">+50</span>
              <span class="chip" onclick="addAmount('in_amount', 100)">+100</span>
              <span class="chip" onclick="addAmount('in_amount', 200)">+200</span>
              <span class="chip warn" onclick="fillAmount('in_amount')">Tutar yaz</span>
            </div>

            <label>Açıklama</label>
            <input type="text" name="note" placeholder="örn. Harem hesabı">

            <div class="btnrow" style="margin-top:10px">
              <button class="btn primary" type="submit">✅ Kaydet</button>
              <button class="btn ghost" type="reset">Temizle</button>
            </div>
          </form>
        </div>

        <!-- ÇIKIŞ -->
        <div class="panel" id="panel-out">
          <form method="post" action="{{ url_for('hesap_cikis') }}">
            <input type="hidden" name="csrf_token" value="{{ csrf_token }}">

            <label>Kategori</label>
            <select name="category" id="cat_out">
              {% for k in categories_out %}<option value="{{k}}">{{k}}</option>{% endfor %}
            </select>

            <label>Tutar (TL)</label>
            <input id="out_amount" type="number" name="amount" min="0" step="1" inputmode="numeric" placeholder="0" required>

            <div class="quick">
              <span class="chip" onclick="addAmount('out_amount', 10)">+10</span>
              <span class="chip" onclick="addAmount('out_amount', 20)">+20</span>
              <span class="chip" onclick="addAmount('out_amount', 50)">+50</span>
              <span class="chip" onclick="addAmount('out_amount', 100)">+100</span>
              <span class="chip" onclick="addAmount('out_amount', 200)">+200</span>
              <span class="chip warn" onclick="fillAmount('out_amount')">Tutar yaz</span>
            </div>

            <label>Açıklama</label>
            <input type="text" name="note" placeholder="örn. Yıkama">

            <div class="btnrow" style="margin-top:10px">
              <button class="btn primary" type="submit">✅ Kaydet</button>
              <button class="btn ghost" type="reset">Temizle</button>
            </div>
          </form>
        </div>

        <!-- DEVİR -->
        <div class="panel" id="panel-devir">
          <form method="post" action="{{ url_for('hesap_devir') }}">
            <input type="hidden" name="csrf_token" value="{{ csrf_token }}">

            <label>Tutar (TL)</label>
            <input id="devir_amount" type="number" name="amount" min="0" step="1" inputmode="numeric" placeholder="0" required>

            <div class="quick" aria-label="Hızlı tutar seçenekleri">
              <span class="chip" onclick="addAmount('devir_amount', 10)">+10</span>
              <span class="chip" onclick="addAmount('devir_amount', 20)">+20</span>
              <span class="chip" onclick="addAmount('devir_amount', 50)">+50</span>
              <span class="chip" onclick="addAmount('devir_amount', 100)">+100</span>
              <span class="chip" onclick="addAmount('devir_amount', 200)">+200</span>
              <span class="chip warn" onclick="fillAmount('devir_amount')">Tutar yaz</span>
            </div>

            <label>Not (opsiyonel)</label>
            <input type="text" name="note" placeholder="Garaj avansı">

            <div class="btnrow" style="margin-top:10px">
              <button class="btn primary" type="submit">✅ Kaydet</button>
              <button class="btn ghost" type="reset">Temizle</button>
            </div>
          </form>
        </div>
      </div>
    </div>

    <!-- KATEGORİLER -->
    <form class="card" method="post" action="{{ url_for('hesap_kategoriler_kaydet') }}">
      <div class="row">
        <div class="h">⚙️ Kategoriler</div>
        <span class="muted2">Virgülle ayır • hızlı düzenle</span>
      </div>

      <input type="hidden" name="csrf_token" value="{{ csrf_token }}">

      <div class="grid2">
        <div>
          <label>Giriş Kategorileri</label>
          <textarea name="cats_in" rows="5" placeholder="örn: Bilet, Emanet, İkram...">{{ categories_in|join(', ') }}</textarea>
        </div>
        <div>
          <label>Çıkış Kategorileri</label>
          <textarea name="cats_out" rows="5" placeholder="örn: Mazot, Yıkama, Otoyol...">{{ categories_out|join(', ') }}</textarea>
        </div>
      </div>

      <div class="btnrow" style="margin-top:10px">
        <button class="btn primary" type="submit">Kaydet</button>
        <button class="btn ghost" type="reset">Vazgeç</button>
      </div>
    </form>

    <!-- SON HAREKETLER TOOLBAR -->
    <div class="toolbar">
      <div class="left">
        <div class="h" style="margin:0">📋 İşlem Dökümü</div>
        <span class="muted2">Gösterilen: <span id="moveCount">0</span> kayıt</span>
      </div>

      <div class="right">
        <div class="searchwrap">
          <input id="q" type="text" placeholder="Ara: kategori / açıklama / + / -">
          <button class="btn small" type="button" onclick="clearSearch()">Temizle</button>
        </div>

        <button class="btn small primary" type="button" onclick="shareWhatsapp()">WhatsApp</button>
        <a class="btn small" href="{{ url_for('hesap_moves_csv') }}">CSV</a>
        <button class="btn small" type="button" onclick="window.print()">Yazdır/PDF</button>
      </div>
    </div>

    <!-- SON HAREKETLER: Tablo -->
    <div class="card moves-table">
      <table class="table" id="movesTable">
        <thead>
          <tr>
            <th>Zaman</th><th>Yön</th><th>Kategori</th><th>Açıklama</th><th class="right">Tutar</th>
          </tr>
        </thead>
        <tbody id="movesBody">
          {% for m in moves %}
            <tr class="{{ 'in' if m.direction == '+' else 'out' }}">
              <td>{{ m.created_at }}</td>
              <td>{{ '+' if m.direction == '+' else '-' }}</td>
              <td>{{ m.category }}</td>
              <td class="note">{{ m.note }}</td>
              <td class="amount right">{{ m.amount|tl }}</td>
            </tr>
          {% else %}
            <tr><td colspan="5" class="muted">Henüz hareket yok.</td></tr>
          {% endfor %}
        </tbody>
      </table>
    </div>

    <!-- SON HAREKETLER: Mobil kart -->
    <div class="card moves-cards" id="movesCards">
      {% for m in moves %}
        <div class="move-card {{ 'in' if m.direction == '+' else 'out' }}">
          <div class="move-left">
            <div class="move-top">
              <span class="move-dir">{{ '+' if m.direction == '+' else '-' }}</span>
              <span class="move-cat">{{ m.category }}</span>
            </div>
            {% if m.note %}
              <div class="move-note">{{ m.note }}</div>
            {% endif %}
            <div class="move-time">{{ m.created_at }}</div>
          </div>
          <div class="move-amt">{{ m.amount|tl }}</div>
        </div>
      {% else %}
        <div class="muted">Henüz hareket yok.</div>
      {% endfor %}
    </div>

  </div><!-- /container -->

  <!-- FOOTER -->
  <div class="footerbar">
    <div class="footergrid">
      <a class="btn" href="{{ url_for('seats_page') }}">🎫 Biletler</a>
      <a class="btn" href="{{ url_for('consignments_page') }}">📦 Emanet</a>
      <a class="btn primary" href="{{ url_for('hesap_page') }}">🧾 Hesap</a>
      <form method="post" action="{{ url_for('end_trip') }}" style="margin:0">
        <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
        <button class="btn danger" type="submit" onclick="return confirm(\'Seferi bitirmek istediğine emin misin?\')">⛔ Seferi Bitir</button>
      </form>
    </div>
  </div>

  <script>
    // --- Helpers ---
    function tl(n){
      const v = Number(n || 0);
      return new Intl.NumberFormat('tr-TR', {style:'currency', currency:'TRY'}).format(v);
    }
    function getEl(id){ return document.getElementById(id); }
    function currentVal(id){
      const el = getEl(id);
      if(!el) return 0;
      const v = parseFloat(String(el.value||'').replace(',','.'));
      return isNaN(v) ? 0 : v;
    }
    function setVal(id, v){
      const el = getEl(id);
      if(el) el.value = String(Math.max(0, Math.round(v))).replace('.', ',');
      el?.focus();
    }

    // --- Quick amounts ---
    function addAmount(id, add){
      const v = currentVal(id);
      setVal(id, v + add);
    }
    function fillAmount(id){
      const el = getEl(id);
      if(!el) return;
      el.focus();
    }

    // ✅ Tabs
    const tabs = Array.from(document.querySelectorAll(".tab"));
    const panels = Array.from(document.querySelectorAll(".tabpanels .panel"));
    function setTab(panelId){
      tabs.forEach(t => t.classList.toggle("active", t.dataset.tab === panelId));
      panels.forEach(p => p.classList.toggle("active", p.id === panelId));
    }
    tabs.forEach(t => t.addEventListener("click", () => setTab(t.dataset.tab)));

    // ✅ Son seçilen kategori hatırlatma
    const catIn  = getEl("cat_in");
    const catOut = getEl("cat_out");
    if(catIn){ catIn.value = localStorage.getItem("cat_in")  || catIn.value; }
    if(catOut){catOut.value= localStorage.getItem("cat_out") || catOut.value;}
    catIn?.addEventListener("change", e => localStorage.setItem("cat_in", e.target.value));
    catOut?.addEventListener("change", e => localStorage.setItem("cat_out", e.target.value));

    // --- Table search filter (tablo + kart sayımı) ---
    const q = getEl('q');
    const movesBody = getEl('movesBody');
    const cardsWrap = getEl('movesCards');

    function normalize(s){ return String(s||'').toLowerCase().trim(); }

    function applySearch(){
      const term = normalize(q.value);

      // tablo satırları
      const rows = Array.from(movesBody?.querySelectorAll('tr') || []);
      let shown = 0;
      rows.forEach(r=>{
        const ok = !term || normalize(r.innerText).includes(term);
        r.style.display = ok ? '' : 'none';
        if(ok) shown++;
      });

      // kartlar
      const cards = Array.from(cardsWrap?.querySelectorAll('.move-card') || []);
      cards.forEach(c=>{
        const ok = !term || normalize(c.innerText).includes(term);
        c.style.display = ok ? '' : 'none';
      });

      getEl('moveCount').textContent = shown || cards.filter(c => c.style.display !== 'none').length || 0;
    }

    function clearSearch(){
      q.value = '';
      applySearch();
      q.focus();
    }
    q?.addEventListener('input', applySearch);

    // init count
    getEl('moveCount').textContent = Array.isArray(MOVES) ? MOVES.length : (movesBody?.querySelectorAll('tr').length || 0);
    applySearch();

    // --- WhatsApp share ---
    function shareWhatsapp(){
      if(!Array.isArray(MOVES) || MOVES.length === 0){
        alert("Paylaşılacak hareket yok.");
        return;
      }
      const lines = [];
      lines.push("🧾 SEFER KASA – İşlem Dökümü");
      const route = TRIP?.route || "";
      const date  = TRIP?.date || "";
      const dep   = TRIP?.departure_time || "";
      lines.push(`Hat: ${route}  Tarih: ${date}  Kalkış: ${dep}`);
      lines.push("--------------------------------------------------");

      MOVES.slice().reverse().forEach(m=>{
        const dir = (m.direction === '+' || m.direction === 'in') ? '+' : '-';
        const created = m.created_at || m.created || "";
        const cat = m.category || "";
        const note = m.note || "";
        lines.push(`${created}  ${dir}  ${cat}  ${note}  ${tl(m.amount)}`);
      });

      lines.push("--------------------------------------------------");
      lines.push(`Devir:  ${tl(SUMS?.devir)}`);
      lines.push(`Giriş:  ${tl(SUMS?.giris)}`);
      lines.push(`Çıkış:  ${tl(SUMS?.cikis)}`);
      lines.push(`Kalan:  ${tl(SUMS?.kalan)}`);

      const text = encodeURIComponent(lines.join("\n"));
      window.open("https://wa.me/?text=" + text, "_blank");
    }

function fixFooterGap(){
  const fb = document.querySelector('.footerbar');
  if(!fb) return;

  const h = fb.getBoundingClientRect().height || fb.offsetHeight || 0;

  // CSS değişkenine yaz → container padding bunu kullanacak
  document.documentElement.style.setProperty('--footer-h', (h + 16) + 'px');

  // Debug: çalışıyor mu görmek için (1 kere gör, sonra silebilirsin)
  // console.log("footer height:", h);
}

window.addEventListener("load", fixFooterGap, {once:true});
window.addEventListener("resize", fixFooterGap);
window.addEventListener("orientationchange", fixFooterGap);
setTimeout(fixFooterGap, 300);   // adres çubuğu otursun diye
setTimeout(fixFooterGap, 1200);  // bazı cihazlar geç ölçüyor
  </script>
</body>
</html>
