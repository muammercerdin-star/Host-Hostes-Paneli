<script id="drive-quick-final-js">
(function(){
  function isDriveMode(){
    const btn = document.getElementById("driveModeToggle");
    const txt = (btn ? btn.textContent : "").toLowerCase();

    /*
      Normal ekranda buton "Sürüş" yazar.
      Sürüş modunda buton "Normal" yazar.
    */
    if(txt.includes("normal")) return true;

    const bodyCls = document.body.className.toLowerCase();
    const htmlCls = document.documentElement.className.toLowerCase();

    return (
      bodyCls.includes("drive") ||
      bodyCls.includes("surus") ||
      htmlCls.includes("drive") ||
      htmlCls.includes("surus")
    );
  }

  function placeDriveQuickDock(){
    const dock = document.getElementById("driveQuickDock");
    const board = document.querySelector(".board-inner");
    const speed = document.getElementById("driveSpeedChip");

    const active = isDriveMode();
    document.body.classList.toggle("drive-quick-active", active);

    if(!dock || !board || !speed || !active) return;

    const boardBox = board.getBoundingClientRect();
    const speedBox = speed.getBoundingClientRect();

    const dockWidth = dock.offsetWidth || 170;

    /*
      Hız kutusunun altındaki sağ boş alana koy.
      Sağdan taşmasın diye board genişliği içinde sınırla.
    */
    let left = speedBox.left - boardBox.left;
    let top = speedBox.bottom - boardBox.top + 8;

    const minLeft = 12;
    const maxLeft = boardBox.width - dockWidth - 12;

    if(left < minLeft) left = minLeft;
    if(left > maxLeft) left = maxLeft;

    dock.style.left = left + "px";
    dock.style.top = top + "px";
  }

  function bootDriveQuickDock(){
    placeDriveQuickDock();

    const btn = document.getElementById("driveModeToggle");

    if(btn){
      btn.addEventListener("click", function(){
        setTimeout(placeDriveQuickDock, 60);
        setTimeout(placeDriveQuickDock, 250);
        setTimeout(placeDriveQuickDock, 600);
      });

      new MutationObserver(placeDriveQuickDock).observe(btn, {
        childList:true,
        subtree:true,
        characterData:true,
        attributes:true
      });
    }

    window.addEventListener("resize", placeDriveQuickDock);
    window.addEventListener("orientationchange", function(){
      setTimeout(placeDriveQuickDock, 300);
    });

    new MutationObserver(placeDriveQuickDock).observe(document.body, {
      attributes:true,
      attributeFilter:["class"]
    });

    let n = 0;
    const t = setInterval(function(){
      placeDriveQuickDock();
      n++;
      if(n > 20) clearInterval(t);
    }, 250);
  }

  if(document.readyState === "loading"){
    document.addEventListener("DOMContentLoaded", bootDriveQuickDock);
  }else{
    bootDriveQuickDock();
  }
})();
</script>


