<script id="premium-fab-top-js">
(function(){
  function makeDock(){
    if(document.getElementById("seatPremiumActionDock")) return;

    const boardHead = document.querySelector(".board-head");
    const routeFlow = document.querySelector(".route-flow, #routeFlow, .route-flow-wrap");
    const boardInner = document.querySelector(".board-inner");

    if(!boardInner) return;

    const dock = document.createElement("div");
    dock.id = "seatPremiumActionDock";
    dock.innerHTML = `
      <button class="premium-fab-btn blue" type="button" id="premiumBulkBtn" title="Toplu giriş">＋</button>
      <button class="premium-fab-btn green" type="button" id="premiumCashBtn" title="Hızlı tahsilat">₺</button>
      <button class="premium-fab-btn orange" type="button" id="premiumOffloadBtn" title="İnecekleri indir">⇩</button>
    `;

    if(routeFlow){
      routeFlow.insertAdjacentElement("beforebegin", dock);
    }else if(boardHead){
      boardHead.insertAdjacentElement("afterend", dock);
    }else{
      boardInner.prepend(dock);
    }

    bindDockButtons();
    hideOldBottomDock();
  }

  function clickFirst(selectors){
    for(const sel of selectors){
      const el = document.querySelector(sel);
      if(el){
        el.click();
        return true;
      }
    }
    return false;
  }

  function bindDockButtons(){
    const bulk = document.getElementById("premiumBulkBtn");
    const cash = document.getElementById("premiumCashBtn");
    const off  = document.getElementById("premiumOffloadBtn");

    if(bulk && !bulk.dataset.bound){
      bulk.dataset.bound = "1";
      bulk.addEventListener("click", function(){
        clickFirst([
          "#fabBulk",
          "#fabBulkPane",
          "[data-action='bulk']",
          "[data-open='bulk']",
          ".fab-bulk"
        ]);
      });
    }

    if(cash && !cash.dataset.bound){
      cash.dataset.bound = "1";
      cash.addEventListener("click", function(){
        clickFirst([
          "#fabCash",
          "#fabCashPane",
          "[data-action='cash']",
          "[data-open='cash']",
          ".fab-cash"
        ]);
      });
    }

    if(off && !off.dataset.bound){
      off.dataset.bound = "1";
      off.addEventListener("click", function(){
        clickFirst([
          "#btnOffloadNow",
          "#btnOffloadNowPane",
          "#ghostOffloadBtn",
          "[data-action='offload']",
          ".fab-offload"
        ]);
      });
    }
  }

  function hideOldBottomDock(){
    /*
      Eski alttaki 3'lü buton grubunu yakalamaya çalışır.
      Yeni dock içindekileri değil, sayfanın alt kısmındaki eski grubu gizler.
    */
    const all = Array.from(document.querySelectorAll("button, a"));
    const candidates = all.filter(el => {
      if(el.closest("#seatPremiumActionDock")) return false;

      const txt = (el.textContent || "").trim();
      const id = (el.id || "").toLowerCase();
      const cls = (el.className || "").toString().toLowerCase();

      return (
        txt === "+" ||
        txt === "＋" ||
        txt === "₺" ||
        txt === "⇩" ||
        txt === "↓" ||
        id.includes("fab") ||
        cls.includes("fab")
      );
    });

    candidates.forEach(el => {
      const parent = el.parentElement;
      if(parent && parent.children.length <= 5){
        const rect = parent.getBoundingClientRect();
        if(rect.top > window.innerHeight * 0.45){
          parent.classList.add("seat-old-fab-hidden");
        }
      }
    });
  }

  function boot(){
    makeDock();
    setTimeout(hideOldBottomDock, 300);
    setTimeout(hideOldBottomDock, 800);
  }

  if(document.readyState === "loading"){
    document.addEventListener("DOMContentLoaded", boot);
  }else{
    boot();
  }
})();
</script>

{% endblock %}
