.finish-modal-actions{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:12px;
  margin-top:18px;
}

.finish-btn{
  height:62px;
  border:0;
  border-radius:22px;
  font-size:18px;
  font-weight:950;
  cursor:pointer;
}

.finish-btn.cancel{
  color:#2563eb;
  background:#f8fbff;
  border:1px solid rgba(148,163,184,.24);
  box-shadow:0 12px 26px rgba(15,23,42,.08);
}

.finish-btn.done{
  color:#fff;
  background:linear-gradient(145deg,#38bdf8,#2563eb);
  box-shadow:0 16px 34px rgba(37,99,235,.28);
}

@media(max-width:430px){
  .finish-modal-card{
    padding:26px 20px 20px;
    border-radius:32px;
  }

  .finish-modal-card h2{
    font-size:34px;
  }

  .finish-modal-text{
    font-size:16px;
  }

  .finish-modal-trip{
    grid-template-columns:1fr;
  }

  .finish-btn{
    height:58px;
    font-size:16px;
  }
}
</style>

<script id="finish-trip-premium-modal-js">
function openFinishTripModal(){
  const modal = document.getElementById("finishTripPremiumModal");
  if(!modal) return;
  modal.classList.add("show");
  modal.setAttribute("aria-hidden", "false");
}

function closeFinishTripModal(){
  const modal = document.getElementById("finishTripPremiumModal");
  if(!modal) return;
  modal.classList.remove("show");
  modal.setAttribute("aria-hidden", "true");
}

document.addEventListener("DOMContentLoaded", function(){
  document.getElementById("finishTripCloseBtn")?.addEventListener("click", closeFinishTripModal);
  document.getElementById("finishTripCancelBtn")?.addEventListener("click", closeFinishTripModal);

  document.getElementById("finishTripPremiumModal")?.addEventListener("click", function(e){
    if(e.target.id === "finishTripPremiumModal"){
      closeFinishTripModal();
    }
  });

  document.getElementById("finishTripGoBtn")?.addEventListener("click", function(){
    window.location.href = "/end_trip";
  });
});
</script>

{% endblock %}
