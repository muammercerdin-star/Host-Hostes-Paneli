  #driveModeActionsDock{
    width:218px;
    height:46px;
    padding:6px;
    gap:6px;
    border-radius:20px;
  }

  #driveModeActionsDock .dma-btn{
    width:34px;
    height:34px;
    min-width:34px;
    min-height:34px;
    border-radius:13px;
    font-size:20px;
  }
}
</style>

<script id="drive-mode-actions-independent-js">
(function(){
  function isDriveMode(){
    const btn = document.getElementById("driveModeToggle");
    const txt = (btn ? btn.textContent : "").toLowerCase();

    // Sürüş modunda buton "Normal" oluyor
    if(txt.includes("normal")) return true;

    const bodyCls = document.body.className.toLowerCase();
    const htmlCls = document.documentElement.className.toLowerCase();

    return (
      bodyCls.includes("drive") ||
      bodyCls.includes("surus") ||
      htmlCls.includes("drive") ||
      htmlCls.includes("surus")
    );
  }

  function ensureDock(){
    let dock = document.getElementById("driveModeActionsDock");
    if(dock) return dock;

    dock = document.createElement("div");
    dock.id = "driveModeActionsDock";
    dock.innerHTML = `
      <a class="dma-btn" href="{{ url_for('index') }}" title="Ana Sayfa">🏠</a>
      <a class="dma-btn" href="{{ url_for('hesap_page') }}" title="Hesap">💵</a>
      <a class="dma-btn" href="{{ url_for('consignments_page') }}" title="Emanetler">📦</a>
      <button class="dma-btn" type="button" id="dmaAiBtn" title="Asistan">🧠</button>
      <button class="dma-btn danger" type="button" id="dmaEndBtn" title="Seferi bitir">⛔</button>
    `;

    const board = document.querySelector(".board-inner");
    if(board){
      board.appendChild(dock);
    }

    return dock;
  }

  function clickFirst(selectors){
    for(const sel of selectors){
      const el = document.querySelector(sel);
      if(el){
        el.click();
        return true;
      }
    }
    return false;
  }

  function bindButtons(){
    const ai = document.getElementById("dmaAiBtn");
    const end = document.getElementById("dmaEndBtn");

    if(ai && !ai.dataset.bound){
      ai.dataset.bound = "1";
      ai.addEventListener("click", function(){
        /*
          🧠 Asistan butonu sesli komut değildir.
          Önce üst bardaki AI Console linkini arar.
          Bulamazsa sağ paneldeki Asistan sekmesini açar.
        */
        const opened = clickFirst([
          "a[title='AI Console']",
          "a[title='AI']",
          "a[href*='ai']",
          "a[href*='asistan']"
        ]);

        if(opened) return;

        const tab = document.querySelector(".tab-btn[data-tab='ai']");
        if(tab){
          tab.click();
          return;
        }

        alert("AI/asistan ekranı bulunamadı.");
      });
    }

    if(end && !end.dataset.bound){
      end.dataset.bound = "1";
      end.addEventListener("click", function(){
        if(!confirm("Seferi bitirme ekranına geçilsin mi?")) return;

        const clicked = clickFirst([
          "#endTripBtn",
          "#btnEndTrip",
          "[data-action='end-trip']",
          "a[href*='end_trip']",
          "a[href*='sefer-bitir']"
        ]);

        if(!clicked){
          window.location.href = "/end_trip";
        }
      });
    }
  }

  function placeDock(){
    const dock = ensureDock();
    const board = document.querySelector(".board-inner");
    const speed = document.getElementById("driveSpeedChip");

    if(!dock || !board || !speed) return;

    const active = isDriveMode();

    if(!active){
      dock.style.display = "none";
      return;
    }

    dock.style.display = "flex";

    const b = board.getBoundingClientRect();
    const sp = speed.getBoundingClientRect();

    const dockW = dock.offsetWidth || 218;

    /*
      Hız kutusunun altındaki boş sağ banda koyar.
      Taşarsa otomatik sola çeker.
    */
    let left = (sp.right - b.left) - dockW;
    let top = (sp.bottom - b.top) + 8;

    const minLeft = 14;
    const maxLeft = b.width - dockW - 14;

    if(left < minLeft) left = minLeft;
    if(left > maxLeft) left = maxLeft;

    dock.style.left = left + "px";
    dock.style.top = top + "px";
  }

  function boot(){
    ensureDock();
    bindButtons();
    placeDock();

    const btn = document.getElementById("driveModeToggle");
    if(btn){
      btn.addEventListener("click", function(){
        setTimeout(placeDock, 50);
        setTimeout(placeDock, 250);
        setTimeout(placeDock, 700);
      });

      new MutationObserver(placeDock).observe(btn, {
        childList:true,
        subtree:true,
        characterData:true,
        attributes:true
      });
    }

    new MutationObserver(placeDock).observe(document.body, {
      attributes:true,
      attributeFilter:["class"]
    });

    window.addEventListener("resize", placeDock);
    window.addEventListener("orientationchange", function(){
      setTimeout(placeDock, 300);
    });

    let n = 0;
    const t = setInterval(function(){
      ensureDock();
      bindButtons();
      placeDock();
      n++;
      if(n > 30) clearInterval(t);
    }, 250);
  }

  if(document.readyState === "loading"){
    document.addEventListener("DOMContentLoaded", boot);
  }else{
    boot();
  }
})();
</script>

{% endblock %}
