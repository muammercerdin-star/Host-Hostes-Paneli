<style id="drive-mode-actions-independent-style">
/* =========================================================
   SÜRÜŞ MODU ÜST HIZLI MENÜ - BAĞIMSIZ FINAL
   driveInlineDock içine girmez, kendi kendine görünür.
========================================================= */

.board-inner{
  position:relative !important;
}

#driveModeActionsDock{
  display:none;
  position:absolute;
  z-index:9999;

  width:238px;
  height:50px;
  padding:7px;

  border-radius:22px;
  background:rgba(5,15,28,.95);
  border:1px solid rgba(96,165,250,.28);
  box-shadow:
    inset 0 0 0 1px rgba(255,255,255,.05),
    0 16px 34px rgba(0,0,0,.38);

  align-items:center;
  justify-content:center;
  gap:7px;
}

#driveModeActionsDock .dma-btn{
  width:38px;
  height:38px;
  min-width:38px;
  min-height:38px;

  border-radius:15px;
  border:1px solid rgba(148,163,184,.20);
  background:linear-gradient(180deg,rgba(31,63,102,.98),rgba(13,28,48,.98));
  box-shadow:
    inset 0 1px 0 rgba(255,255,255,.16),
    0 9px 18px rgba(0,0,0,.24);

  display:flex;
  align-items:center;
  justify-content:center;

  color:#fff;
  text-decoration:none;
  font-size:21px;
  line-height:1;
  cursor:pointer;
  padding:0;
}

#driveModeActionsDock .dma-btn.danger{
  background:linear-gradient(180deg,rgba(239,68,68,.95),rgba(127,29,29,.95));
  border-color:rgba(248,113,113,.35);
}

#driveModeActionsDock .dma-btn:active{
  transform:scale(.94);
}

