<script id="local-coords-ui-js">
document.addEventListener("DOMContentLoaded", function(){
  const form = document.querySelector("form");
  const textarea = document.querySelector("textarea[name='stops'], textarea");
  const nameInput = document.querySelector("input[name='name']");

  if(!form || !textarea || document.getElementById("localCoordsBox")) return;

  const box = document.createElement("div");
  box.id = "localCoordsBox";
  box.className = "local-coords-box";
  box.innerHTML = `
    <div class="local-coords-head">
      <h3>📍 Kayıtlı Koordinatlar</h3>
      <p>İnternetten aramaz. Daha önce kayıtlı durak koordinatlarını baz alır. Eksik olanları elle girersin.</p>
    </div>

    <div class="local-coords-actions">
      <button type="button" class="local-coords-btn primary" id="btnLocalCoordCheck">Koordinatları Kontrol Et</button>
      <button type="button" class="local-coords-btn green" id="btnLocalCoordCopy">Kayıtlılardan Doldur</button>
    </div>

    <div class="local-coords-progress" id="localCoordsProgress">
      Hazır. Önce “Koordinatları Kontrol Et” diyebilirsin.
    </div>

    <div class="local-coords-list" id="localCoordsList"></div>
  `;

  textarea.insertAdjacentElement("afterend", box);

  const progress = document.getElementById("localCoordsProgress");
  const list = document.getElementById("localCoordsList");

  function parseStops(){
    return textarea.value
      .split(/\n|,/)
      .map(x => x.trim())
      .filter(Boolean);
  }

  function esc(x){
    return String(x || "")
      .replaceAll("&","&amp;")
      .replaceAll("<","&lt;")
      .replaceAll(">","&gt;")
      .replaceAll('"',"&quot;");
  }

  function iconFor(status){
    if(status === "saved") return "✓";
    if(status === "copied") return "✓";
    if(status === "candidate") return "!";
    return "×";
  }

  function itemHtml(item){
    const cls = item.status || "missing";
    const coord = item.lat && item.lng ? `${item.lat}, ${item.lng}` : "";
    const source = item.source_route ? `Kaynak: ${item.source_route} / ${item.source_stop || item.stop}` : "";

    const manual = item.status === "missing" ? `
      <div class="local-coord-manual">
        <input type="number" step="0.000001" placeholder="Lat" data-lat-for="${esc(item.stop)}">
        <input type="number" step="0.000001" placeholder="Lng" data-lng-for="${esc(item.stop)}">
        <button type="button" class="local-coord-save" data-save-stop="${esc(item.stop)}">Kaydet</button>
      </div>
    ` : "";

    return `
      <div class="local-coord-item">
        <div class="local-coord-icon ${cls}">${iconFor(item.status)}</div>
        <div class="local-coord-main">
          <b>${esc(item.stop)}</b>
          <span>${esc(item.msg || "")}${coord ? " · " + coord : ""}</span>
          ${source ? `<small>${esc(source)}</small>` : ""}
          ${manual}
        </div>
      </div>
    `;
  }

  async function loadStatus(autoCopy){
    const routeName = nameInput ? nameInput.value.trim() : "";
    const stops = parseStops();

    if(!routeName){
      alert("Önce hat adını yaz.");
      return;
    }

    if(stops.length === 0){
      alert("Durak listesi boş.");
      return;
    }

    progress.textContent = autoCopy
      ? "Kayıtlı durak koordinatları bu hatta kopyalanıyor..."
      : "Koordinatlar kontrol ediliyor...";

    list.innerHTML = "";

    try{
      const res = await fetch({{ url_for('api_route_coord_status', rid=route['id']) | tojson }}, {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          "X-CSRF-Token": {{ csrf_token | tojson }}
        },
        body: JSON.stringify({
          route_name: routeName,
          stops: stops,
          auto_copy: autoCopy
        })
      });

      const j = await res.json();

      if(!j.ok){
        progress.textContent = "Hata: " + (j.msg || "İşlem başarısız");
        return;
      }

      progress.textContent =
        `Sonuç: ${j.total} durak · ${j.saved} kayıtlı · ${j.copied} kopyalandı · ${j.missing} eksik`;

      list.innerHTML = j.items.map(itemHtml).join("");
      bindManualButtons();

    }catch(e){
      progress.textContent = "Bağlantı hatası: " + e.message;
    }
  }

  function bindManualButtons(){
    document.querySelectorAll("[data-save-stop]").forEach(btn => {
      if(btn.dataset.bound) return;
      btn.dataset.bound = "1";

      btn.addEventListener("click", async function(){
        const stop = this.dataset.saveStop;
        const routeName = nameInput ? nameInput.value.trim() : "";

        const latEl = document.querySelector(`[data-lat-for="${CSS.escape(stop)}"]`);
        const lngEl = document.querySelector(`[data-lng-for="${CSS.escape(stop)}"]`);

        const lat = latEl ? latEl.value : "";
        const lng = lngEl ? lngEl.value : "";

        if(!lat || !lng){
          alert("Lat ve Lng gir.");
          return;
        }

        try{
          const res = await fetch({{ url_for('api_route_coord_save_manual', rid=route['id']) | tojson }}, {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
              "X-CSRF-Token": {{ csrf_token | tojson }}
            },
            body: JSON.stringify({
              route_name: routeName,
              stop: stop,
              lat: lat,
              lng: lng
            })
          });

          const j = await res.json();

          if(!j.ok){
            alert(j.msg || "Kayıt hatası");
            return;
          }

          progress.textContent = `${stop} koordinatı kaydedildi.`;
          loadStatus(false);

        }catch(e){
          alert("Bağlantı hatası: " + e.message);
        }
      });
    });
  }

  document.getElementById("btnLocalCoordCheck").addEventListener("click", function(){
    loadStatus(false);
  });

  document.getElementById("btnLocalCoordCopy").addEventListener("click", function(){
    if(!confirm("Aynı isimle daha önce kayıtlı durak koordinatları bu hatta kopyalansın mı?")) return;
    loadStatus(true);
  });
});
</script>
