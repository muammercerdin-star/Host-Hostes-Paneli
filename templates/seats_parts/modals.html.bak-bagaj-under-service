<div class="modal-backdrop" id="seatBackdrop"></div>
<div class="modal glass" id="seatModal">
  <h3 id="seatTitle">Koltuk</h3>

  <div class="field-grid">
    <div class="field-row">
      <label class="field">
        <span>Biniş Yeri</span>
        <select id="pickup"><option value="">—</option></select>
      </label>
      <label class="field">
        <span>İniş Yeri</span>
        <select id="dropoff"><option value="">—</option></select>
      </label>
    </div>

    <div>
      <div class="muted" style="margin-bottom:8px">Bilet Türü</div>
      <div class="radio-row">
        <label><input type="radio" name="ticket" value="biletli"> Biletli</label>
        <label><input type="radio" name="ticket" value="biletsiz" checked> Biletsiz</label>
        <label><input type="radio" name="ticket" value="ucretsiz"> Ücretsiz</label>
      </div>
    </div>

    <div>
      <div class="muted" style="margin-bottom:8px">Cinsiyet</div>
      <div class="radio-row">
        <label><input type="radio" name="gender" value="bay"> Bay</label>
        <label><input type="radio" name="gender" value="bayan"> Bayan</label>
        <label><input type="radio" name="gender" value=""> Boş</label>
      </div>
    </div>

    <div class="check-row">
      <label><input type="checkbox" id="pairOk"> Yan yana istisna</label>
      <label><input type="checkbox" id="service"> Servis kullanacak</label>
    </div>

    <div class="field-row">
      <label class="field">
        <span>Tutar (₺)</span>
        <input type="number" id="price" value="0.00" step="0.01">
      </label>
      <label class="field">
        <span>Servis Notu</span>
        <input type="text" id="service_note" placeholder="Not / konum / açıklama">
      </label>
    </div>

    <div>
      <div class="muted" style="margin-bottom:8px">Ödeme</div>
      <div class="radio-row">
        <label><input type="radio" name="pay" value="nakit" checked> Nakit</label>
        <label><input type="radio" name="pay" value="iban"> IBAN</label>
        <label><input type="radio" name="pay" value="online"> Online</label>
        <label><input type="radio" name="pay" value="pos"> POS</label>
        <label><input type="radio" name="pay" value="ucretsiz"> Ücretsiz</label>
      </div>
    </div>

    <div class="action-grid">
      <button class="btn primary" type="button" id="btnBagAdd">🧳 Bagaj Ekle</button>
      <button class="btn dark" type="button" id="btnBagView">📸 Bagaj Gör</button>
    </div>
  </div>

  <div class="modal-actions">
    <button class="btn green" type="button" id="btnSeatSave">Kaydet</button>
    <button class="btn danger" type="button" id="btnSeatOffload">İniş (Boşalt)</button>
    <button class="btn ghost" type="button" id="btnSeatClose">Kapat</button>
  </div>
</div>

<div class="modal-backdrop" id="bulkBackdrop"></div>
<div class="sheet-modal glass" id="bulkModal">
  <h3>Toplu Giriş</h3>

  <div class="field-grid">
    <div class="field-row">
      <label class="field">
        <span>Nereden</span>
        <select id="bulkFrom"><option value="">—</option></select>
      </label>
      <label class="field">
        <span>Nereye</span>
        <select id="bulkTo"><option value="">—</option></select>
      </label>
    </div>

    <div class="field-row">
      <label class="field">
        <span>Adet</span>
        <input type="number" id="bulkCount" min="1" value="1">
      </label>

      <div class="field">
        <span>Bilet</span>
        <div class="radio-row" style="padding-top:8px">
          <label><input type="radio" name="bulkTicket" value="biletsiz" checked> Biletsiz</label>
          <label><input type="radio" name="bulkTicket" value="biletli"> Biletli</label>
        </div>
      </div>
    </div>

    <div class="check-row">
      <label><input type="checkbox" id="multiPick"> Çoklu seçim</label>
      <label><input type="checkbox" id="bulkService"> Servis</label>
    </div>

    <div class="muted">Çoklu seçim açıksa koltukları elle seçersin. Kapalıysa sistem boş koltuklardan yerleştirir.</div>
  </div>

  <div class="modal-actions">
    <button class="btn ghost" type="button" id="bulkClose">Kapat</button>
    <button class="btn primary" type="button" id="bulkSave">Kaydet</button>
  </div>
</div>

<div class="modal-backdrop" id="cashBackdrop"></div>
<div class="sheet-modal glass" id="cashModal">
  <h3>Hızlı Tahsilat (Ayakta)</h3>

  <div class="field-grid">
    <div class="field-row">
      <label class="field">
        <span>Adet</span>
        <input type="number" id="cashCount" min="1" value="1">
      </label>
      <label class="field">
        <span>Tutar (₺ / kişi)</span>
        <input type="number" id="cashPrice" min="0" step="0.01" value="0">
      </label>
    </div>

    <div class="field-row">
      <label class="field">
        <span>Nereden</span>
        <select id="cashFrom"><option value="">—</option></select>
      </label>
      <label class="field">
        <span>Nereye</span>
        <select id="cashTo"><option value="">—</option></select>
      </label>
    </div>

    <label class="field">
      <span>Ödeme</span>
      <select id="cashPay">
        <option value="nakit">Nakit</option>
        <option value="iban">IBAN</option>
        <option value="pos">POS</option>
        <option value="online">Online</option>
      </select>
    </label>

    <label class="field">
      <span>Not</span>
      <input type="text" id="cashNote" placeholder="Kısa not">
    </label>
  </div>

  <div class="modal-actions">
    <button class="btn ghost" type="button" id="cashClose">Kapat</button>
    <button class="btn primary" type="button" id="cashSave">Ekle</button>
  </div>
</div>

<div class="modal-backdrop" id="approachBackdrop"></div>
<div class="sheet-modal glass" id="approachModal">
  <h3 id="approachTitle">Durak Yaklaşıyor</h3>
  <div class="muted" id="approachInfo">—</div>
  <div class="approach-list" id="approachList"></div>

  <div class="modal-actions">
    <button class="btn danger" type="button" id="approachOffload">Toplu İndir</button>
    <button class="btn ghost" type="button" id="approachSnooze">Ertele (5 dk)</button>
    <button class="btn ghost" type="button" id="approachClose">Kapat</button>
  </div>
</div>

<div class="modal-backdrop" id="standingBackdrop"></div>
<div class="sheet-modal glass" id="standingModal">
  <h3>Ayakta Yolcular</h3>
  <div class="muted" id="standingSummary">—</div>
  <div class="standing-list" id="standingList" style="margin-top:12px;"></div>

  <div class="modal-actions">
    <button class="btn danger" type="button" id="standingBulkOff" style="display:none">Toplu İndir</button>
    <button class="btn ghost" type="button" id="standingClose">Kapat</button>
  </div>
</div>

<div id="toast"></div>
