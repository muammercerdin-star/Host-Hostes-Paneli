<script id="drive-quick-menu-final-js">
(function(){
  function makeDock(){
    if(document.getElementById("driveQuickDock")) return;

    const speedChip = document.getElementById("driveSpeedChip");
    const dockParent = speedChip ? speedChip.parentElement : null;

    if(!dockParent) return;

    const dock = document.createElement("div");
    dock.id = "driveQuickDock";
    dock.innerHTML = `
      <a class="dq-btn" href="/">🏠<span>Ana</span></a>
      <a class="dq-btn" href="/hesap">💵<span>Hesap</span></a>
      <a class="dq-btn" href="/emanetler">📦<span>Emanet</span></a>
      <a class="dq-btn" href="/yolcu-kontrolu">👥<span>Yolcu</span></a>
    `;

    speedChip.insertAdjacentElement("afterend", dock);
  }

  function isDriveMode(){
    const btn = document.getElementById("driveModeToggle");
    const txt = (btn ? btn.textContent : "").toLowerCase();

    // Sürüş modunda buton genelde "Normal" yazar
    if(txt.includes("normal")) return true;

    // Bazı sürümlerde body/html classı olabilir
    const bodyCls = document.body.className.toLowerCase();
    const htmlCls = document.documentElement.className.toLowerCase();

    return (
      bodyCls.includes("drive") ||
      bodyCls.includes("surus") ||
      htmlCls.includes("drive") ||
      htmlCls.includes("surus")
    );
  }

  function sync(){
    makeDock();
    document.body.classList.toggle("drive-quick-active", isDriveMode());
  }

  document.addEventListener("DOMContentLoaded", function(){
    sync();

    const btn = document.getElementById("driveModeToggle");
    if(btn){
      btn.addEventListener("click", function(){
        setTimeout(sync, 50);
        setTimeout(sync, 200);
        setTimeout(sync, 500);
      });

      new MutationObserver(sync).observe(btn, {
        childList:true,
        subtree:true,
        characterData:true,
        attributes:true
      });
    }

    new MutationObserver(sync).observe(document.body, {
      attributes:true,
      attributeFilter:["class"]
    });

    // İlk açılışta veya geç yüklenen JS varsa yakalasın
    let n = 0;
    const t = setInterval(function(){
      sync();
      n++;
      if(n > 20) clearInterval(t);
    }, 250);
  });
})();
</script>


