    padding:8px 10px !important;
  }
}
</style>


<style id="seat-visual-card-final">
.primary-actions .seat-visual-card{
  position:relative !important;
  min-height:154px !important;
  border-radius:30px !important;
  overflow:hidden !important;
  padding:24px 26px !important;
  display:flex !important;
  align-items:center !important;
  gap:24px !important;
  color:#fff !important;
  text-decoration:none !important;
  isolation:isolate !important;
  background:
    linear-gradient(90deg,
      rgba(0,102,255,.98) 0%,
      rgba(0,102,255,.88) 34%,
      rgba(0,102,255,.45) 56%,
      rgba(0,0,0,.14) 100%
    ),
    url("/static/img/seat-card.jpg") center right / cover no-repeat !important;
  box-shadow:
    0 18px 42px rgba(0,88,220,.26),
    inset 0 1px 0 rgba(255,255,255,.22) !important;
}

.primary-actions .seat-visual-card::before{
  content:"";
  position:absolute;
  inset:0;
  z-index:-1;
  background:
    radial-gradient(circle at 18% 12%, rgba(255,255,255,.22), transparent 28%),
    linear-gradient(180deg, rgba(255,255,255,.06), rgba(0,0,0,.12));
}

.primary-actions .seat-visual-ico{
  width:96px;
  height:96px;
  min-width:96px;
  border-radius:30px;
  display:flex;
  align-items:center;
  justify-content:center;
  background:rgba(255,255,255,.14);
  border:1px solid rgba(255,255,255,.22);
  backdrop-filter:blur(8px);
  box-shadow:inset 0 1px 0 rgba(255,255,255,.20);
  z-index:2;
}

.primary-actions .seat-visual-ico span{
  font-size:54px;
  filter:drop-shadow(0 8px 12px rgba(0,0,0,.22));
}

.primary-actions .seat-visual-text{
  position:relative;
  z-index:2;
  display:flex;
  flex-direction:column;
  max-width:360px;
  padding-right:82px;
}

.primary-actions .seat-visual-card .big-title{
  color:#fff !important;
  font-size:35px !important;
  line-height:1.02 !important;
  font-weight:950 !important;
  letter-spacing:.3px !important;
  text-shadow:0 2px 10px rgba(0,0,0,.20);
}

.primary-actions .seat-visual-card .big-desc{
  margin-top:8px !important;
  color:rgba(255,255,255,.95) !important;
  font-size:20px !important;
  line-height:1.22 !important;
  font-weight:650 !important;
  text-shadow:0 2px 8px rgba(0,0,0,.18);
}

.primary-actions .seat-visual-arrow{
  position:absolute;
  right:34px;
  top:50%;
  transform:translateY(-50%);
  width:78px;
  height:78px;
  border-radius:999px;
  background:#fff;
  color:#1874e8;
  display:flex;
  align-items:center;
  justify-content:center;
  font-size:58px;
  font-weight:900;
  line-height:1;
  box-shadow:0 14px 28px rgba(0,0,0,.22);
  z-index:3;
}

@media(max-width:700px){
  .primary-actions .seat-visual-card{
    min-height:152px !important;
    border-radius:28px !important;
    padding:22px 24px !important;
    gap:20px !important;
    background:
      linear-gradient(90deg,
        rgba(0,102,255,.98) 0%,
        rgba(0,102,255,.88) 46%,
        rgba(0,102,255,.36) 68%,
        rgba(0,0,0,.18) 100%
      ),
      url("/static/img/seat-card.jpg") center right / cover no-repeat !important;
  }

  .primary-actions .seat-visual-ico{
    width:92px;
    height:92px;
    min-width:92px;
  }

  .primary-actions .seat-visual-ico span{
    font-size:50px;
  }

  .primary-actions .seat-visual-text{
    max-width:260px;
    padding-right:72px;
  }

  .primary-actions .seat-visual-card .big-title{
    font-size:31px !important;
  }

  .primary-actions .seat-visual-card .big-desc{
    font-size:19px !important;
  }

  .primary-actions .seat-visual-arrow{
    right:26px;
    width:72px;
    height:72px;
    font-size:54px;
  }
}

@media(max-width:420px){
  .primary-actions .seat-visual-card{
    min-height:142px !important;
    padding:20px 18px !important;
    gap:16px !important;
  }

  .primary-actions .seat-visual-ico{
    width:78px;
    height:78px;
    min-width:78px;
    border-radius:24px;
  }

  .primary-actions .seat-visual-ico span{
    font-size:44px;
  }

  .primary-actions .seat-visual-text{
    padding-right:58px;
  }

  .primary-actions .seat-visual-card .big-title{
    font-size:27px !important;
  }

  .primary-actions .seat-visual-card .big-desc{
    font-size:17px !important;
  }

  .primary-actions .seat-visual-arrow{
    right:18px;
    width:58px;
    height:58px;
    font-size:44px;
  }
}
</style>


<style id="end-trip-modal-final">
.end-trip-overlay{
  position:fixed;
  inset:0;
  z-index:99999;
  display:none;
  align-items:center;
  justify-content:center;
  padding:22px;
  background:rgba(9,15,28,.68);
  backdrop-filter:blur(12px);
}

.end-trip-overlay.show{
  display:flex;
}

.end-trip-box{
  width:min(92vw, 430px);
  border-radius:34px;
  overflow:hidden;
  background:
    linear-gradient(180deg, rgba(255,255,255,.98), rgba(242,246,255,.97));
  border:1px solid rgba(255,255,255,.75);
  box-shadow:
    0 30px 80px rgba(0,0,0,.38),
    inset 0 1px 0 rgba(255,255,255,.9);
  animation:endTripIn .18s ease-out both;
}

@keyframes endTripIn{
  from{ transform:translateY(18px) scale(.96); opacity:0; }
  to{ transform:translateY(0) scale(1); opacity:1; }
}

.end-trip-top{
  padding:24px 24px 14px;
  display:flex;
  align-items:center;
  gap:14px;
}

.end-trip-mark{
  width:60px;
  height:60px;
  border-radius:22px;
  display:flex;
  align-items:center;
  justify-content:center;
  font-size:31px;
  background:linear-gradient(135deg, #ffe8ed, #ffd4dd);
  box-shadow:inset 0 1px 0 rgba(255,255,255,.9);
}

.end-trip-title{
  margin:0;
  color:#111827;
  font-size:25px;
  line-height:1.05;
  font-weight:950;
  letter-spacing:-.3px;
}

.end-trip-small{
  margin:5px 0 0;
  color:#64748b;
  font-size:14px;
  font-weight:750;
}

.end-trip-content{
  padding:4px 24px 22px;
}

.end-trip-text{
  margin:0;
  color:#334155;
  font-size:17px;
  line-height:1.45;
  font-weight:650;
}

.end-trip-note{
  margin-top:14px;
  padding:13px 14px;
  border-radius:18px;
  background:rgba(239,68,68,.08);
  color:#991b1b;
  font-size:14px;
  line-height:1.35;
  font-weight:800;
}

.end-trip-actions{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:12px;
  padding:0 24px 24px;
}

.end-trip-btn{
  height:55px;
  border:0;
  border-radius:19px;
  font-size:16px;
  font-weight:950;
  cursor:pointer;
}

.end-trip-cancel{
  background:#eef2f7;
  color:#334155;
  box-shadow:inset 0 1px 0 rgba(255,255,255,.9);
}

.end-trip-ok{
  color:#fff;
  background:linear-gradient(135deg, #ef4444, #b91c1c);
  box-shadow:0 14px 28px rgba(185,28,28,.25);
}

.end-trip-btn:active{
  transform:scale(.98);
}

@media(max-width:420px){
  .end-trip-box{ border-radius:28px; }
  .end-trip-top{ padding:22px 20px 12px; }
  .end-trip-content{ padding:4px 20px 20px; }
  .end-trip-actions{ padding:0 20px 22px; }
  .end-trip-title{ font-size:23px; }
}
</style>


<style id="drive-card-image-final">
/* Sürüş Modunu Aç kartı görsel tasarım */
.big-action.drive{
  background:
    linear-gradient(90deg, rgba(0,0,0,.10), rgba(0,0,0,.04)),
    url("/static/img/drive-mode-card.png") center / cover no-repeat !important;
  min-height:130px !important;
  border-radius:26px !important;
  color:#fff !important;
  box-shadow:0 18px 42px rgba(14,165,233,.24) !important;
}

/* Görselin içinde yazı olduğu için mevcut yazıları gizle */
.big-action.drive .big-ico,
.big-action.drive .big-title,
.big-action.drive .big-desc,
.big-action.drive .arrow{
  opacity:0 !important;
}

@media(max-width:430px){
  .big-action.drive{
    min-height:118px !important;
    border-radius:24px !important;
  }
}
</style>

</head>

<body>
  <main class="shell">

    <section class="hero">
      <div class="kicker">🟢 Devam Eden Sefer</div>
      <h1>{{ trip["route"] }}</h1>
      <p>Aktif sefer hazır. İstediğin ekrana hızlıca geç.</p>

      <div class="trip-pill">
        🚌 {{ trip["plate"] or "Plaka yok" }} · 
        {% if trip["date"] and "-" in trip["date"] %}
          {{ trip["date"].split("-")[2] }}.{{ trip["date"].split("-")[1] }}.{{ trip["date"].split("-")[0] }}
        {% else %}
          {{ trip["date"] }}
        {% endif %}
        · {{ trip["departure_time"] }}
      </div>
    </section>

    <section class="primary-actions">
      <a class="big-action seat-visual-card" href="{{ url_for('seats_page') }}">
        <span class="seat-visual-ico">
          <span>💺</span>
        </span>

        <span class="seat-visual-text">
          <span class="big-title">Koltuklara Git</span>
          <span class="big-desc">Yolcu, koltuk ve iniş-biniş işlemleri</span>
        </span>

        <span class="seat-visual-arrow">›</span>
      </a>

      <a class="big-action drive" href="{{ url_for('seats_page') }}?drive=1">
        <span class="big-ico">🚌</span>
        <span>
          <span class="big-title">Sürüş Modunu Aç</span>
          <span class="big-desc">Durak akışı, hız ve sesli takip ekranı</span>
        </span>
        <span class="arrow">›</span>
      </a>

      <a class="big-action cash" href="{{ url_for('hesap_page') }}">
        <span class="big-ico">💵</span>
        <span>
          <span class="big-title">Hesap / Kasa</span>
          <span class="big-desc">Giriş-çıkış, kalan ve sefer kasası</span>
        </span>
        <span class="arrow">›</span>
      </a>
    </section>

    <section class="quick-list">
      <a class="quick-item" href="{{ url_for('passenger_control') }}">
        <span class="qico">👥</span>
        <span>
          <span class="qtitle">Yolcu Kontrolü</span>
          <span class="qdesc">Binen-inen ve kontrol ekranı</span>
        </span>
        <span class="qarr">›</span>
      </a>

      <a class="quick-item" href="{{ url_for('consignments_page') }}">
        <span class="qico">📦</span>
        <span>
          <span class="qtitle">Emanetler</span>
          <span class="qdesc">Emanet kayıt ve teslim işlemleri</span>
        </span>
        <span class="qarr">›</span>
      </a>

      <a class="quick-item" href="/sefer-raporu-son">
        <span class="qico">📁</span>
        <span>
          <span class="qtitle">Sefer Raporları</span>
          <span class="qdesc">Biten sefer raporlarını aç</span>
        </span>
        <span class="qarr">›</span>
      </a>
    </section>

    <section class="danger-zone">
      <form id="endTripForm" method="post" action="{{ url_for('end_trip') }}">
        {% if csrf_token is defined %}
          <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
        {% endif %}
        <button class="danger-btn" type="submit">⛔ Seferi Bitir</button>
      </form>
    </section>

    <a class="bottom-home" href="/">← Ana ekrana dön</a>

  </main>

<!-- END TRIP MODAL FINAL START -->
<div class="end-trip-overlay" id="endTripOverlay" aria-hidden="true">
  <div class="end-trip-box" role="dialog" aria-modal="true">
    <div class="end-trip-top">
      <div class="end-trip-mark">⛔</div>
      <div>
        <h2 class="end-trip-title">Seferi bitirelim mi?</h2>
        <p class="end-trip-small">Aktif sefer sonlandırılacak.</p>
      </div>
    </div>

    <div class="end-trip-content">
      <p class="end-trip-text">
        Sefer tamamlandıysa işlemi bitirebilirsin. Emin değilsen iptal edip ekrana dönebilirsin.
      </p>
      <div class="end-trip-note">
        Bitirilen sefer aktif ekrandan kalkar, raporlardan görüntülenir.
      </div>
    </div>

    <div class="end-trip-actions">
      <button type="button" class="end-trip-btn end-trip-cancel" id="endTripCancel">İptal</button>
      <button type="button" class="end-trip-btn end-trip-ok" id="endTripOk">Seferi Bitir</button>
    </div>
  </div>
</div>
<!-- END TRIP MODAL FINAL END -->


<script id="end-trip-modal-final-js">
(function(){
  const form = document.getElementById("endTripForm");
  const overlay = document.getElementById("endTripOverlay");
  const cancel = document.getElementById("endTripCancel");
  const ok = document.getElementById("endTripOk");

  if(!form || !overlay || !cancel || !ok){
    console.log("End trip modal elemanları bulunamadı.");
    return;
  }

  let confirmed = false;

  function openModal(){
    overlay.classList.add("show");
    overlay.setAttribute("aria-hidden", "false");
    document.body.style.overflow = "hidden";
  }

  function closeModal(){
    overlay.classList.remove("show");
    overlay.setAttribute("aria-hidden", "true");
    document.body.style.overflow = "";
  }

  form.addEventListener("submit", function(e){
    if(confirmed) return;
    e.preventDefault();
    openModal();
  });

  cancel.addEventListener("click", closeModal);

  overlay.addEventListener("click", function(e){
    if(e.target === overlay) closeModal();
  });

  document.addEventListener("keydown", function(e){
    if(e.key === "Escape" && overlay.classList.contains("show")){
      closeModal();
    }
  });

  ok.addEventListener("click", function(){
    confirmed = true;
    closeModal();
    form.submit();
  });
})();
</script>

</body>
</html>

