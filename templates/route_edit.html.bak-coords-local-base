{% extends "base.html" %}
{% block content %}
<link rel="stylesheet" href="/static/style.css">

<style>
*{
  box-sizing:border-box;
  -webkit-tap-highlight-color:transparent;
}

body{
  background:
    radial-gradient(circle at 18% 0%, rgba(37,99,235,.20), transparent 34%),
    radial-gradient(circle at 96% 28%, rgba(20,184,166,.14), transparent 35%),
    linear-gradient(180deg,#061524,#0b1726 45%,#08111d) !important;
  color:#eaf2ff;
  font-family:system-ui,-apple-system,"Segoe UI",Roboto,Arial,sans-serif;
}

.route-edit-shell{
  width:min(94vw,720px);
  margin:18px auto 34px;
  padding:18px;
  border-radius:34px;
  background:linear-gradient(180deg,rgba(15,31,49,.96),rgba(8,20,34,.96));
  border:1px solid rgba(148,163,184,.18);
  box-shadow:0 28px 80px rgba(0,0,0,.42);
}

.route-edit-top{
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:12px;
  margin-bottom:18px;
}

.back-btn{
  min-height:58px;
  padding:0 22px;
  border-radius:22px;
  display:inline-flex;
  align-items:center;
  justify-content:center;
  gap:8px;
  text-decoration:none;
  background:linear-gradient(180deg,#334155,#1e293b);
  border:1px solid rgba(148,163,184,.22);
  color:#f8fbff;
  font-size:18px;
  font-weight:950;
  box-shadow:0 14px 28px rgba(0,0,0,.24);
}

.route-pill{
  min-height:42px;
  padding:0 14px;
  border-radius:999px;
  display:inline-flex;
  align-items:center;
  justify-content:center;
  background:rgba(37,99,235,.16);
  border:1px solid rgba(96,165,250,.30);
  color:#93c5fd;
  font-size:13px;
  font-weight:950;
  letter-spacing:.35px;
}

.route-hero{
  margin-bottom:18px;
}

.route-hero h1{
  margin:0;
  color:#f8fbff;
  font-size:44px;
  line-height:1;
  font-weight:950;
  letter-spacing:-1.2px;
}

.route-hero p{
  margin:10px 0 0;
  color:#aab8ca;
  font-size:15px;
  line-height:1.35;
  font-weight:800;
}

.route-card{
  border-radius:30px;
  padding:18px;
  background:linear-gradient(180deg,#132338,#0d1a2b);
  border:1px solid rgba(148,163,184,.18);
  box-shadow:0 18px 42px rgba(0,0,0,.28);
}

.error-box{
  margin-bottom:14px;
  padding:14px;
  border-radius:20px;
  background:rgba(239,68,68,.14);
  border:1px solid rgba(248,113,113,.28);
  color:#fecaca;
  font-size:15px;
  font-weight:850;
}

.form-group{
  margin-bottom:18px;
}

.route-label{
  display:block;
  margin:0 0 10px;
  color:#dbeafe;
  font-size:18px;
  line-height:1.1;
  font-weight:950;
}

.route-input,
.route-textarea{
  width:100%;
  background:#0a1624;
  border:1px solid rgba(148,163,184,.24);
  color:#f8fbff;
  border-radius:24px;
  padding:17px 18px;
  outline:none;
  box-shadow:
    inset 0 0 0 1px rgba(255,255,255,.03),
    0 12px 28px rgba(0,0,0,.18);
}

.route-input{
  min-height:64px;
  font-size:18px;
  font-weight:900;
}

.route-textarea{
  min-height:330px;
  max-height:52vh;
  resize:vertical;
  font-family:ui-monospace,SFMono-Regular,Menlo,Consolas,monospace;
  font-size:16px;
  line-height:1.38;
  font-weight:750;
}

.route-input::placeholder,
.route-textarea::placeholder{
  color:#7f8ea3;
}

.route-input:focus,
.route-textarea:focus{
  background:#0d1d30;
  border-color:#60a5fa;
  box-shadow:
    0 0 0 4px rgba(96,165,250,.14),
    0 14px 30px rgba(0,0,0,.22);
}

.preview-box{
  margin-top:14px;
  padding:16px;
  border-radius:26px;
  background:rgba(15,35,58,.92);
  border:1px solid rgba(34,197,94,.22);
  box-shadow:0 14px 30px rgba(0,0,0,.22);
}

.preview-head{
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:10px;
  margin-bottom:12px;
}

.preview-title{
  color:#dbeafe;
  font-size:17px;
  font-weight:950;
  line-height:1.15;
}

.preview-count{
  padding:8px 12px;
  border-radius:999px;
  background:rgba(34,197,94,.14);
  border:1px solid rgba(34,197,94,.28);
  color:#86efac;
  font-size:14px;
  font-weight:950;
  white-space:nowrap;
}

.preview-list{
  display:grid;
  gap:9px;
  max-height:260px;
  overflow:auto;
  padding-right:4px;
}

.preview-item{
  min-height:46px;
  display:grid;
  grid-template-columns:20px 1fr;
  align-items:center;
  gap:11px;
  padding:10px 13px;
  border-radius:19px;
  background:#0a1624;
  border:1px solid rgba(148,163,184,.16);
  color:#f8fbff;
  font-size:16px;
  font-weight:900;
  line-height:1.25;
}

.preview-dot{
  width:12px;
  height:12px;
  border-radius:999px;
  background:#22c55e;
  box-shadow:
    0 0 0 5px rgba(34,197,94,.14),
    0 0 18px rgba(34,197,94,.55);
}

.preview-empty{
  padding:14px;
  border-radius:18px;
  background:#0a1624;
  border:1px dashed rgba(148,163,184,.22);
  color:#94a3b8;
  font-size:15px;
  font-weight:850;
}

.form-actions{
  width:100%;
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:16px;
  margin-top:24px;
}

.cancel-btn,
.save-btn{
  width:100%;
  height:76px;
  min-height:76px;
  border:0;
  border-radius:26px;
  display:flex;
  align-items:center;
  justify-content:center;
  text-align:center;
  text-decoration:none;
  font-family:inherit;
  font-size:22px;
  font-weight:950;
  line-height:1;
  cursor:pointer;
}

.cancel-btn{
  background:linear-gradient(180deg,#334155,#1e293b);
  border:1px solid rgba(148,163,184,.22);
  color:#f8fbff;
  box-shadow:0 16px 30px rgba(0,0,0,.25);
}

.save-btn{
  background:linear-gradient(145deg,#38bdf8,#2563eb);
  color:#fff;
  box-shadow:0 18px 34px rgba(37,99,235,.30);
}

@media(max-width:430px){
  .route-edit-shell{
    width:calc(100vw - 24px);
    padding:16px;
    border-radius:30px;
  }

  .route-edit-top{
    align-items:stretch;
  }

  .back-btn{
    min-height:56px;
    padding:0 18px;
  }

  .route-pill{
    display:none;
  }

  .route-hero h1{
    font-size:38px;
  }

  .route-card{
    padding:16px;
    border-radius:28px;
  }

  .route-input{
    min-height:62px;
    font-size:17px;
  }

  .route-textarea{
    min-height:300px;
    max-height:46vh;
    font-size:15px;
  }

  .preview-list{
    max-height:230px;
  }

  .form-actions{
    gap:14px;
  }

  .cancel-btn,
  .save-btn{
    height:72px;
    min-height:72px;
    border-radius:24px;
    font-size:20px;
  }
}
</style>

<main class="route-edit-shell">

  <div class="route-edit-top">
    <a class="back-btn" href="{{ url_for('routes_list') }}">← Hatlar</a>
    <div class="route-pill">🛣️ Hat düzenleme</div>
  </div>

  <section class="route-hero">
    <h1>Hattı Düzenle</h1>
    <p>Hat adını ve durak sırasını buradan güncelle. Her satır bir durak olarak kaydedilir.</p>
  </section>

  <section class="route-card">
    {% if error %}
      <div class="error-box">{{ error }}</div>
    {% endif %}

    <form method="post" action="{{ url_for('route_edit', rid=route['id']) }}">
      <input type="hidden" name="csrf_token" value="{{ csrf_token }}">

      <div class="form-group">
        <label class="route-label" for="routeName">Hat adı</label>
        <input
          class="route-input"
          id="routeName"
          type="text"
          name="name"
          value="{{ route['name'] if route else '' }}"
          placeholder="Örn: Denizli – İstanbul"
          required
        >
      </div>

      <div class="form-group">
        <label class="route-label" for="routeStops">Duraklar</label>
        <textarea
          class="route-textarea"
          id="routeStops"
          name="stops"
          rows="12"
          placeholder="Denizli Otogar&#10;Sarayköy&#10;Buldan&#10;..."
        >{{ stops_text or '' }}</textarea>

        <div class="preview-box">
          <div class="preview-head">
            <div class="preview-title">🟢 Hat durak önizlemesi</div>
            <div class="preview-count" id="routeStopCount">0 durak</div>
          </div>
          <div class="preview-list" id="routeStopList"></div>
        </div>
      </div>

      <div class="form-actions">
        <a class="cancel-btn" href="{{ url_for('routes_list') }}">Vazgeç</a>
        <button class="save-btn" type="submit">Kaydet</button>
      </div>
    </form>
  </section>

</main>

<script>
document.addEventListener("DOMContentLoaded", function(){
  const textarea = document.getElementById("routeStops");
  const list = document.getElementById("routeStopList");
  const count = document.getElementById("routeStopCount");

  function escapeHtml(text){
    return text
      .replaceAll("&", "&amp;")
      .replaceAll("<", "&lt;")
      .replaceAll(">", "&gt;")
      .replaceAll('"', "&quot;")
      .replaceAll("'", "&#039;");
  }

  function renderStops(){
    const stops = textarea.value
      .split(/\n+/)
      .map(x => x.trim())
      .filter(Boolean);

    count.textContent = stops.length + " durak";

    if(stops.length === 0){
      list.innerHTML = '<div class="preview-empty">Durak yazınca burada yeşil noktalı hat önizlemesi oluşacak.</div>';
      return;
    }

    list.innerHTML = stops.map(stop => `
      <div class="preview-item">
        <span class="preview-dot"></span>
        <span>${escapeHtml(stop)}</span>
      </div>
    `).join("");
  }

  textarea.addEventListener("input", renderStops);
  renderStops();
});
</script>

<!-- AUTO COORDS UI START -->
<style id="auto-coords-ui-style">
.auto-coords-box{
  margin-top:18px;
  padding:16px;
  border-radius:24px;
  background:rgba(8,18,32,.72);
  border:1px solid rgba(96,165,250,.25);
  box-shadow:0 16px 34px rgba(0,0,0,.25);
  color:#eaf2ff;
}

.auto-coords-head{
  display:flex;
  align-items:flex-start;
  justify-content:space-between;
  gap:12px;
  margin-bottom:12px;
}

.auto-coords-head h3{
  margin:0;
  color:#f8fbff;
  font-size:22px;
  line-height:1.1;
  font-weight:950;
}

.auto-coords-head p{
  margin:6px 0 0;
  color:#94a3b8;
  font-size:14px;
  line-height:1.3;
  font-weight:800;
}

.auto-coords-actions{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:10px;
  margin-top:12px;
}

.auto-coords-btn{
  min-height:58px;
  border:0;
  border-radius:20px;
  padding:0 14px;
  font-size:16px;
  font-weight:950;
  color:#fff;
  cursor:pointer;
}

.auto-coords-btn.primary{
  background:linear-gradient(145deg,#38bdf8,#2563eb);
  box-shadow:0 14px 28px rgba(37,99,235,.25);
}

.auto-coords-btn.dark{
  background:linear-gradient(180deg,#334155,#1e293b);
  border:1px solid rgba(148,163,184,.18);
}

.auto-coords-progress{
  margin-top:12px;
  padding:12px 14px;
  border-radius:18px;
  background:#071423;
  border:1px solid rgba(148,163,184,.16);
  color:#cbd5e1;
  font-size:14px;
  font-weight:850;
}

.auto-coords-list{
  margin-top:12px;
  display:grid;
  gap:8px;
  max-height:360px;
  overflow:auto;
  padding-right:3px;
}

.auto-coord-item{
  display:grid;
  grid-template-columns:28px 1fr;
  gap:10px;
  align-items:start;
  padding:12px;
  border-radius:18px;
  background:#071423;
  border:1px solid rgba(148,163,184,.14);
}

.auto-coord-icon{
  width:24px;
  height:24px;
  border-radius:999px;
  display:flex;
  align-items:center;
  justify-content:center;
  font-size:14px;
}

.auto-coord-icon.ok{background:rgba(34,197,94,.18);color:#86efac;}
.auto-coord-icon.warn{background:rgba(245,158,11,.18);color:#fbbf24;}
.auto-coord-icon.err{background:rgba(239,68,68,.18);color:#fca5a5;}
.auto-coord-icon.skip{background:rgba(96,165,250,.18);color:#93c5fd;}

.auto-coord-main b{
  display:block;
  color:#f8fbff;
  font-size:15px;
  line-height:1.2;
  font-weight:950;
}

.auto-coord-main span{
  display:block;
  margin-top:4px;
  color:#94a3b8;
  font-size:13px;
  line-height:1.25;
  font-weight:750;
}

.auto-coord-main small{
  display:block;
  margin-top:5px;
  color:#60a5fa;
  font-size:12px;
  line-height:1.25;
  font-weight:800;
}

@media(max-width:430px){
  .auto-coords-actions{
    grid-template-columns:1fr;
  }
}
</style>

<script id="auto-coords-ui-js">
document.addEventListener("DOMContentLoaded", function(){
  const form = document.querySelector("form");
  const textarea = document.querySelector("textarea[name='stops'], textarea");
  const nameInput = document.querySelector("input[name='name']");

  if(!form || !textarea || document.getElementById("autoCoordsBox")) return;

  const box = document.createElement("div");
  box.id = "autoCoordsBox";
  box.className = "auto-coords-box";
  box.innerHTML = `
    <div class="auto-coords-head">
      <div>
        <h3>📍 Durak Koordinatları</h3>
        <p>Listedeki durakları internetten bulur ve GPS durak akışı için kaydeder.</p>
      </div>
    </div>

    <div class="auto-coords-actions">
      <button type="button" class="auto-coords-btn primary" id="btnAutoCoordsMissing">Eksikleri Otomatik Bul</button>
      <button type="button" class="auto-coords-btn dark" id="btnAutoCoordsAll">Tümünü Yeniden Bul</button>
    </div>

    <div class="auto-coords-progress" id="autoCoordsProgress">
      Hazır. Önce hattı kaydettiysen daha sağlıklı çalışır.
    </div>

    <div class="auto-coords-list" id="autoCoordsList"></div>
  `;

  textarea.insertAdjacentElement("afterend", box);

  const progress = document.getElementById("autoCoordsProgress");
  const list = document.getElementById("autoCoordsList");

  function parseStops(){
    return textarea.value
      .split(/\n|,/)
      .map(x => x.trim())
      .filter(Boolean);
  }

  function esc(x){
    return String(x || "")
      .replaceAll("&","&amp;")
      .replaceAll("<","&lt;")
      .replaceAll(">","&gt;")
      .replaceAll('"',"&quot;");
  }

  function itemHtml(item){
    let cls = "err";
    let icon = "×";

    if(item.status === "found"){
      cls = item.confidence === "high" ? "ok" : "warn";
      icon = item.confidence === "high" ? "✓" : "!";
    }else if(item.status === "skipped"){
      cls = "skip";
      icon = "•";
    }

    const coord = item.lat && item.lng ? `${item.lat}, ${item.lng}` : "";
    const display = item.display_name ? esc(item.display_name) : esc(item.msg || "");

    return `
      <div class="auto-coord-item">
        <div class="auto-coord-icon ${cls}">${icon}</div>
        <div class="auto-coord-main">
          <b>${esc(item.stop)}</b>
          <span>${esc(item.msg || "")}${coord ? " · " + coord : ""}</span>
          ${display ? `<small>${display}</small>` : ""}
        </div>
      </div>
    `;
  }

  async function runAutoCoords(onlyMissing){
    const stops = parseStops();
    const routeName = nameInput ? nameInput.value.trim() : "";

    if(!routeName){
      alert("Önce hat adını yaz.");
      return;
    }

    if(stops.length === 0){
      alert("Durak listesi boş.");
      return;
    }

    const msg = onlyMissing
      ? "Eksik koordinatlar otomatik bulunsun mu? Bu işlem internet kullanır ve durak başına yaklaşık 1 saniye sürebilir."
      : "Tüm koordinatlar yeniden bulunsun mu? Eski kayıtların üzerine yazılabilir.";

    if(!confirm(msg)) return;

    list.innerHTML = "";
    progress.textContent = `Başladı: ${stops.length} durak kontrol ediliyor...`;

    document.getElementById("btnAutoCoordsMissing").disabled = true;
    document.getElementById("btnAutoCoordsAll").disabled = true;

    try{
      const res = await fetch({{ url_for('api_route_auto_coords', rid=route['id']) | tojson }}, {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          "X-CSRF-Token": {{ csrf_token | tojson }}
        },
        body: JSON.stringify({
          route_name: routeName,
          stops: stops,
          only_missing: onlyMissing,
          save: true
        })
      });

      const j = await res.json();

      if(!j.ok){
        progress.textContent = "Hata: " + (j.msg || "İşlem başarısız");
        return;
      }

      progress.textContent =
        `Tamamlandı: ${j.total} durak · ${j.found} bulundu · ${j.skipped} zaten vardı · ${j.failed} bulunamadı`;

      list.innerHTML = j.items.map(itemHtml).join("");

    }catch(e){
      progress.textContent = "Bağlantı hatası: " + e.message;
    }finally{
      document.getElementById("btnAutoCoordsMissing").disabled = false;
      document.getElementById("btnAutoCoordsAll").disabled = false;
    }
  }

  document.getElementById("btnAutoCoordsMissing").addEventListener("click", function(){
    runAutoCoords(true);
  });

  document.getElementById("btnAutoCoordsAll").addEventListener("click", function(){
    runAutoCoords(false);
  });
});
</script>
<!-- AUTO COORDS UI END -->

{% endblock %}
